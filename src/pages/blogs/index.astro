---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

import BlogImg1 from '../../assets/backend-services/cloud.jpg'; 
import BlogImg2 from '../../assets/backend-services/security.jpg'; 
import BlogImg3 from '../../assets/backend-services/Backend.jpg'; 
import BlogImg4 from '../../assets/backend-services/scaling.jpg'; 

const genres = [
  "All", "Engineering Deep Dives", "Frontend Systems", "Performance & Web Vitals", 
  "Architecture & Scalability"
];

const blogs = [
  { id: "01", title: "Garbage Collection in High-Load Systems", img: BlogImg1, description: "Analyzing memory management overhead in Node.js clusters.", category: "Engineering Deep Dives", date: "JAN 14", time: "12 MIN" },
  { id: "02", title: "Atomic Design at Scale", img: BlogImg2, description: "Managing 500+ components in a multi-tenant environment.", category: "Frontend Systems", date: "JAN 08", time: "8 MIN" },
  { id: "03", title: "Crushing Interaction to Next Paint", img: BlogImg3, description: "Technical strategies to reduce INP for heavy e-commerce.", category: "Performance & Web Vitals", date: "DEC 28", time: "6 MIN" },
  { id: "04", title: "Event-Driven Microservices", img: BlogImg4, description: "Building resilient systems using Kafka and RabbitMQ.", category: "Architecture & Scalability", date: "DEC 15", time: "14 MIN" },
  { id: "05", title: "The Anatomy of a Compiler", img: BlogImg1, description: "How modern JIT engines optimize JavaScript at runtime.", category: "Engineering Deep Dives", date: "JAN 12", time: "15 MIN" },
  { id: "06", title: "State Machines in React", img: BlogImg2, description: "Why XState is replacing useEffect for complex logic.", category: "Frontend Systems", date: "JAN 05", time: "9 MIN" },
];
---

<Layout title="Engineering Vault // Editorial">
  <section class="bg-[#FCFCFC] text-[#111111] min-h-screen py-12 px-6 md:px-12 font-sans selection:bg-[#FB8500] selection:text-white">
    
    <nav class="max-w-7xl mx-auto mb-20 sticky">


        <div class="flex gap-3 overflow-x-auto no-scrollbar py-2">
          {genres.map((genre) => (
            <button 
              class="genre-btn px-6 py-2.5 border border-gray-200 rounded-full text-[10px] font-black uppercase tracking-widest whitespace-nowrap transition-all duration-300 hover:border-[#111111] active:scale-95"
              data-genre={genre}
            >
              {genre}
            </button>
          ))}
        </div>
      </div>
    </nav>

    <div class="max-w-7xl mx-auto">
      <div id="blog-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-16">
        {blogs.map((post) => (
          <a href={`/blogs/${post.id}`} 
             class="group flex flex-col blog-card opacity-0" 
             data-category={post.category}
          >
            <div class="relative aspect-[4/3] overflow-hidden rounded-[2.5rem] mb-8 border border-gray-100 transition-all duration-500 group-hover:shadow-2xl group-hover:shadow-orange-500/10">
              <Image src={post.img} alt={post.title} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" />
              <div class="absolute bottom-6 left-6 bg-white/90 backdrop-blur-md px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-[0.1em] shadow-sm border border-white/50">
                {post.category}
              </div>
            </div>

            <div class="px-2 flex flex-col flex-grow">
              <div class="flex items-center gap-4 mb-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                <span>{post.date}</span>
                <span class="text-[#FB8500] font-black">•</span>
                <span>{post.time} READ</span>
              </div>
              
              <h2 class="text-2xl font-black text-[#111111] tracking-tight mb-4 leading-[1.15] uppercase group-hover:text-[#FB8500] transition-colors duration-300 line-clamp-2">
                {post.title}
              </h2>
              
              <p class="text-gray-500 text-[15px] leading-relaxed mb-8 line-clamp-2 font-medium italic">
                "{post.description}"
              </p>
              
              <div class="mt-auto flex items-center justify-between pt-6 border-t border-gray-100 relative">
                <div class="flex flex-col">
                  <span class="text-[11px] font-black uppercase tracking-[0.2em] text-[#111111]">
                    Read Brief
                  </span>
                  <span class="text-[9px] font-bold text-[#FB8500] uppercase tracking-widest overflow-hidden h-0 group-hover:h-4 transition-all duration-300">
                    Full Analysis &rarr;
                  </span>
                </div>

                <div class="w-12 h-12 flex items-center justify-center rounded-2xl border border-[#111111] bg-[#111111] group-hover:bg-[#111111] group-hover:border-[#111111] transition-all duration-300 group-hover:rotate-[360deg]">
                  <svg xmlns="http://www.w3.org/2000/svg" 
                       class="w-5 h-5 text-gray-400 group-hover:text-[#FB8500] transition-colors" 
                       fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll('.genre-btn');
  const cards = document.querySelectorAll('.blog-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const selectedGenre = btn.getAttribute('data-genre');
      
      // Nav UI Update
      buttons.forEach(b => {
        b.classList.remove('bg-[#111111]', 'text-[#FB8500]', 'border-[#111111]', 'shadow-lg');
      });
      btn.classList.add('bg-[#111111]', 'text-[#FB8500]', 'border-[#111111]', 'shadow-lg');

      // Filter with staggered animation
      let count = 0;
      cards.forEach((card) => {
        const category = card.getAttribute('data-category');
        const isVisible = selectedGenre === 'All' || category === selectedGenre;
        
        const cardEl = card as HTMLElement;
        
        if (isVisible) {
          cardEl.style.display = 'flex';
          // Reset animation
          cardEl.classList.remove('animate-slide-up');
          void cardEl.offsetWidth; // Trigger reflow
          cardEl.style.animationDelay = `${count * 0.1}s`;
          cardEl.classList.add('animate-slide-up');
          count++;
        } else {
          cardEl.style.display = 'none';
          cardEl.classList.remove('animate-slide-up');
        }
      });
    });
  });

  // Init
  (document.querySelector('[data-genre="All"]') as HTMLElement)?.click();
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }

  @keyframes slideUp {
    from { 
      opacity: 0; 
      transform: translateY(30px) scale(0.98); 
    }
    to { 
      opacity: 1; 
      transform: translateY(0) scale(1); 
    }
  }
  
  .animate-slide-up { 
    animation: slideUp 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards; 
  }

  .genre-btn.bg-\[\#111111\] {
    transform: translateY(-2px);
  }
</style>