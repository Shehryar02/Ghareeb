    personas={backendPersonas} 
    requirementsList={["High Traffic Potential", "Security Standards", "Cloud Native"]}
  />

  <ServiceWhatIsIncluded items={serviceFeatures} />
  
  <ServiceDeliverables deliverables={deliverables} />
  
  <ServiceTechStack 
    title="ENGINE" 
    titleAccent="STACK." 
    categories={backendCategories} 
  />

  <ServiceCaseStudies 
    title="SYSTEM" 
    titleAccent="RELEASES." 
