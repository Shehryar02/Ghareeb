---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Kinetic Fitness | Case Study">
  <section class="relative min-h-screen py-20 bg-[#050505] flex flex-col items-center justify-center px-4 overflow-hidden">
    


    <div class="relative z-10 w-full max-w-[1100px] flex flex-col items-center">
      <div class="text-center mb-20">
        <h2 class="text-7xl md:text-9xl font-black leading-[0.75] tracking-[-0.06em] uppercase text-white">
          Our <span class="text-[#FB8500]">Projects</span>
        </h2>
        <p class="mt-8 max-w-2xl mx-auto text-lg md:text-2xl font-light tracking-tight text-gray-400">
          Engineering a <span class="text-white font-normal">high-performance whiwala whiwala SaaS</span> ecosystem.
        </p>
      </div>

      <div class="flex flex-col md:flex-row items-center justify-center w-full gap-8 md:gap-10 relative z-20">
        {
          [
            { id: "01", title: "Interface", img: "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=800" },
            { id: "02", title: "Biometrics", img: "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=800" },
            { id: "03", title: "Analytics", img: "https://images.unsplash.com/photo-1540497077202-7c8a3999166f?q=80&w=800" },
          ].map((item) => (
            <div
              class={`group relative transition-all duration-500 
              ${
                item.id === "02"
                  ? "z-30 w-full md:w-[38%] scale-105" // Center slightly larger
                  : "z-10 w-[85%] md:w-[28%] opacity-60 hover:opacity-100" // Sides smaller and dimmer
              }`}
            >
              <div class="relative aspect-video md:aspect-[4/3] w-full rounded-2xl overflow-hidden border border-white/10 bg-neutral-900 shadow-xl transition-all duration-500 ease-out group-hover:scale-[1.03] group-hover:border-[#FB8500]/50 group-hover:shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
                
                <img
                  src={item.img}
                  alt={item.title}
                  class="w-full h-full object-cover opacity-80 transition-all duration-700 group-hover:opacity-100"
                />

                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent" />

                <div class="absolute bottom-6 left-6 z-20 transition-transform duration-500 group-hover:translate-x-1">
                  <p class="text-[10px] font-bold text-[#FB8500] uppercase tracking-[0.2em]">
                    {item.title} // {item.id}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>