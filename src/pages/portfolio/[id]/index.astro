---
import Hero from '@/components/portfolio/Hero.astro';
import Layout from '@/layouts/Layout.astro';
import Problems from '@/components/portfolio/Problems.astro';
import Constraints from '@/components/portfolio/Constraints.astro';
import Strategy from '@/components/portfolio/Strategy.astro';
import Execution from '@/components/portfolio/Execution.astro';
import Thumbnail from '@/components/portfolio/Thumbnail.astro';
import { getProject, getAllProjectIds } from '@/data/projects';

export async function getStaticPaths() {
  return getAllProjectIds().map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const project = getProject(id!);

if (!project) {
  return Astro.redirect('/portfolio');
}
---

<Layout title={project.seo.title}>
    <Hero
      title={project.hero.title}
      subtitle={project.hero.subtitle}
      tech={project.tech}
      images={project.hero.images}
    />
    <Problems
      title_1st_half={project.problem.title_1st_half}
      title_2nd_half={project.problem.title_2nd_half}
      subtitle={project.problem.subtitle}
      description={project.problem.description}
      painPoints={project.problem.painPoints}
      images={project.problem.images}
    />
    <Constraints
      header={project.constraints.header}
      constraints={project.constraints.constraints}
      gallery={project.constraints.gallery}
      verdict={project.constraints.verdict}
    />
    <Strategy
      header={project.strategy.header}
      steps={project.strategy.steps}
      finale={project.strategy.finale}
    />
    <Execution
      header={project.execution.header}
      stats={project.execution.stats}
      images={project.execution.images}
      conclusion={project.execution.conclusion}
    />
    <Thumbnail projects={project.relatedProjects} />
</Layout>
