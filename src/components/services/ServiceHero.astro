---
/**
 * ServiceHero.astro
 * Aesthetic: Obsidian Glass on Surgical White
 */
interface Props {
  title: string;
  subtitle?: string;
  tag?: string;
  description: string;
  mainImage: string;
  imageAlt?: string;
  specs?: Array<{ label: string; value: string }>;
  primaryCTA?: { text: string; link: string };
  secondaryCTA?: { text: string; link: string };
}

const { 
  title, 
  subtitle,
  tag = "System_Deployment_v1",
  description, 
  mainImage,
  imageAlt = "Service Illustration",
  specs = [
    { label: "Latency", value: "<40ms" },
    { label: "Protocol", value: "gRPC/REST" },
    { label: "Security", value: "AES-256" }
  ],
  primaryCTA = { text: "Initiate Project", link: "#initiate" },
  secondaryCTA = { text: "View Specs", link: "#specs" }
} = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center bg-[#FFFFFF] overflow-hidden pt-20">
  <div class="absolute inset-0 bg-[radial-gradient(#00000005_1px,transparent_1px)] [background-size:32px_32px]"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-24 w-full relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-14 lg:gap-48 xl:gap-64 items-center">
      
      <div class="space-y-8 reveal">
        <div class="inline-flex items-center gap-3 px-4 py-2 bg-black/[0.03] border border-black/[0.05] rounded-full">
            <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            <span class="text-[10px] font-black uppercase tracking-[0.3em] text-black">{tag}</span>
        </div>

        <h1 class="text-5xl md:text-7xl lg:text-8xl font-[1000] text-black uppercase tracking-tighter leading-[0.85]">
          {title} <br />
          {subtitle && <span class="text-orange-500 italic">{subtitle}</span>}
        </h1>

        <p class="text-lg text-gray-500 font-medium leading-relaxed max-w-md">
          {description}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a href={primaryCTA.link} class="px-10 py-5 bg-black text-white rounded-2xl font-black uppercase text-xs tracking-widest hover:bg-orange-500 hover:shadow-[0_20px_40px_rgba(251,133,0,0.3)] transition-all duration-500 text-center">
            {primaryCTA.text}
          </a>
          <a href={secondaryCTA.link} class="px-10 py-5 bg-white border border-black/10 text-black rounded-2xl font-black uppercase text-xs tracking-widest hover:bg-gray-50 transition-all text-center">
            {secondaryCTA.text}
          </a>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 pt-12 border-t border-black/[0.05]">
            {specs.map((spec) => (
              <div>
                <span class="block text-[10px] font-black text-gray-300 uppercase mb-1">{spec.label}</span>
                <span class="text-xl font-bold text-black tracking-tighter">{spec.value}</span>
              </div>
            ))}
        </div>
      </div>

      <div class="relative reveal w-full" style="transition-delay: 300ms;">
        <div class="relative aspect-square w-full max-w-[420px] mx-auto lg:ml-auto lg:mr-0 group">
          <div class="absolute inset-0 bg-black rounded-[3rem] shadow-2xl rotate-3 transition-transform hover:rotate-0 duration-1000 overflow-hidden">
              <img
                  src={mainImage}
                  alt={imageAlt}
                  class="absolute inset-0 w-full h-full object-cover opacity-60 grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-[1s]"
                  loading="eager"
              />
          </div>

          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-white/40 backdrop-blur-2xl border border-white rounded-3xl shadow-xl flex items-center justify-center animate-bounce-slow z-20">
              <span class="text-orange-500 font-black text-2xl">01</span>
          </div>
          
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s ease-in-out infinite;
  }
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1.2s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  function initHeroReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }
  document.addEventListener('astro:page-load', initHeroReveal);
  document.addEventListener('astro:page-load', initHeroReveal);
</script>