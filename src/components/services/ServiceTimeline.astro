---
interface Props {
  title?: string;
  timeline: Array<{
    phase: string;
    duration: string;
    description: string;
  }>;
}

const { 
  title = "Timeline",
  timeline 
} = Astro.props;
---

<section class="py-16 md:py-32 bg-white text-black relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-24 relative z-10">
    <div class="mb-16">
      <p class="text-[#FB8500] font-black tracking-[0.4em] uppercase text-[10px] mb-4">Project Timeline</p>
      <h2 class="text-4xl md:text-5xl lg:text-7xl font-extrabold tracking-tighter leading-none uppercase">
        {title}
      </h2>
    </div>

    <div class="relative">
      <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-gray-200 hidden md:block"></div>
      
      <div class="space-y-12">
        {timeline.map((item, index) => (
          <div class="relative flex items-start gap-8">
            <div class="flex-shrink-0 w-16 h-16 bg-black text-white rounded-full flex items-center justify-center text-2xl font-black z-10 group-hover:bg-[#FB8500] transition-colors duration-500">
              {index + 1}
            </div>
            <div class="flex-1 pt-2">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-3">
                <h3 class="text-2xl font-bold uppercase tracking-tight">{item.phase}</h3>
                <span class="text-[#FB8500] font-bold text-sm uppercase tracking-widest">
                  {item.duration}
                </span>
              </div>
              <p class="text-gray-600 text-base leading-relaxed font-light">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

