---
/**
 * ServiceTechStack - Refined Surgical Hybrid
 * Aesthetic: Obsidian Black Headers / Laboratory White Cards
 */

interface TechItem {
  name: string;
  icon: string;
  color: string;
}

interface TechCategory {
  id: string;
  label: string; // Formatting Tip: Use "Word_Word" for the two-tone effect
  techs: TechItem[];
}

interface Props {
  tag?: string;
  title?: string;
  titleAccent?: string;
  categories: TechCategory[];
}

const { 
  tag = "Infrastructure_Manifest_2026",
  title = "TECH",
  titleAccent = "SYSTEMS.",
  categories = [] 
} = Astro.props;
---

<section class="py-14 sm:py-20 md:py-28 lg:py-40 bg-[#FFFFFF] text-black relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.02] pointer-events-none" 
       style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 60px 60px;">
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-24 relative z-10">
    
    <div class="mb-14 sm:mb-20 md:mb-24 lg:mb-32 reveal">
      <div class="flex items-center gap-3 sm:gap-4 mb-5 sm:mb-8">
        <div class="flex gap-1">
          <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-orange-500 animate-pulse"></span>
          <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-black/10"></span>
        </div>
        <span class="text-black/40 font-black uppercase text-[8px] sm:text-[10px] tracking-[0.4em] sm:tracking-[0.6em] font-mono">{tag}</span>
      </div>
      <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-9xl font-[1000] text-black uppercase tracking-tighter leading-[0.8]">
        {title} <span class="text-orange-500 italic">{titleAccent}</span>
      </h2>
    </div>

    <div class="space-y-6 sm:space-y-8 md:space-y-10 lg:space-y-12">
      {categories.map((cat, catIndex) => (
        <div class="reveal group/section flex flex-col lg:flex-row gap-4 sm:gap-5 md:gap-6 lg:gap-8" style={`transition-delay: ${catIndex * 150}ms`}>
          
          <div class="lg:w-1/3 bg-[#0a0a0a] rounded-2xl sm:rounded-3xl lg:rounded-[2.5rem] p-5 sm:p-7 md:p-8 lg:p-10 flex flex-col justify-between relative overflow-hidden shadow-[0_30px_60px_rgba(0,0,0,0.15)] group-hover/section:-translate-y-1 transition-transform duration-700 min-h-[140px] sm:min-h-[160px]">
             <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-orange-500/40 to-transparent"></div>
             
             <div class="relative z-10">
                <span class="text-orange-500 font-mono text-[9px] sm:text-[10px] font-bold uppercase tracking-[0.3em] sm:tracking-[0.4em] block mb-2 sm:mb-4 italic">MODULE_{cat.id}</span>
                <h3 class="text-2xl sm:text-3xl md:text-3xl lg:text-4xl font-[1000] uppercase tracking-tighter text-white leading-none">
                   {cat.label.split('_')[0]} <br/> 
                   {cat.label.includes('_') && (
                     <span class="text-orange-500 italic text-lg sm:text-xl lg:text-2xl lowercase font-light">{cat.label.split('_')[1]}</span>
                   )}
                </h3>
             </div>

             <div class="relative z-10 mt-6 sm:mt-8 lg:mt-12 flex items-center justify-between border-t border-white/10 pt-4 sm:pt-6">
                <span class="text-[8px] sm:text-[9px] font-mono text-white/30 uppercase tracking-widest leading-none">Status: Primary_Active</span>
                <div class="w-1.5 h-1.5 rounded-full bg-orange-500 shadow-[0_0_10px_#FB8500]"></div>
             </div>
          </div>

          <div class="lg:w-2/3 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2.5 sm:gap-3 md:gap-4">
            {cat.techs.map((tech) => (
              <div class="group/card relative bg-white border border-black/10 rounded-xl sm:rounded-2xl lg:rounded-[2.2rem] py-5 px-3 sm:p-5 md:p-6 lg:p-8 transition-all duration-500 hover:shadow-[0_25px_50px_rgba(0,0,0,0.06)] hover:-translate-y-2 flex flex-col items-center justify-center text-center overflow-hidden">
                
                <div class="absolute inset-0 opacity-0 group-hover/card:opacity-[0.03] transition-opacity duration-700 pointer-events-none" style={`background-color: #${tech.color}`}></div>
                
                <div class="relative z-10 w-7 h-7 sm:w-9 sm:h-9 md:w-10 md:h-10 lg:w-12 lg:h-12 mb-2.5 sm:mb-3 md:mb-4 lg:mb-6 flex items-center justify-center">
                  <img 
                    src={tech.icon.startsWith('http') ? tech.icon : `https://cdn.simpleicons.org/${tech.icon}/${tech.color}`} 
                    alt={tech.name}
                    class="w-full h-full object-contain tech-icon"
                    loading="lazy"
                  />
                </div>

                <div class="relative z-10">
                  <span class="block text-[7px] sm:text-[8px] md:text-[9px] lg:text-[10px] font-black uppercase tracking-wider text-black/30 group-hover/card:text-black transition-colors duration-300 leading-tight">
                    {tech.name}
                  </span>
                </div>

                <div class="absolute bottom-2.5 sm:bottom-3 md:bottom-4 lg:bottom-6 left-1/2 -translate-x-1/2 w-3 sm:w-4 h-[2px] bg-black/5 group-hover/card:w-6 sm:group-hover/card:w-10 transition-all duration-700 ease-out" style={`background-color: #${tech.color}`}></div>
              </div>
            ))}
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  function initTechStack() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }
  document.addEventListener('astro:page-load', initTechStack);
  document.addEventListener('astro:page-load', initTechStack);
</script>