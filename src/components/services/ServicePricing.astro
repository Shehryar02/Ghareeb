---
interface Props {
  title?: string;
  startingFrom?: string;
  price?: string;
  description?: string;
  note?: string;
}

const { 
  title = "Pricing",
  startingFrom,
  price,
  description,
  note
} = Astro.props;
---

<section class="py-16 md:py-32 bg-[#0a0a0a] text-white relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
       style="background-image: radial-gradient(#FB8500 0.5px, transparent 0.5px); background-size: 30px 30px;">
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-24 relative z-10">
    <div class="mb-16 text-center">
      <p class="text-[#FB8500] font-black tracking-[0.4em] uppercase text-[10px] mb-4">Investment</p>
      <h2 class="text-4xl md:text-5xl lg:text-7xl font-extrabold tracking-tighter leading-none uppercase mb-6">
        {title}
      </h2>
      {description && (
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          {description}
        </p>
      )}
    </div>

    <div class="max-w-2xl mx-auto">
      <div class="bg-[#0a0a0a] border-2 border-[#FB8500] p-8 md:p-12 text-center">
        {startingFrom && (
          <p class="text-[#FB8500] font-bold uppercase tracking-widest text-sm mb-4">
            {startingFrom}
          </p>
        )}
        {price && (
          <div class="mb-6">
            <span class="text-5xl md:text-6xl lg:text-8xl font-black text-white">
              {price}
            </span>
          </div>
        )}
        {note && (
          <p class="text-gray-400 text-sm font-light">
            {note}
          </p>
        )}
        <a 
          href="/contact"
          class="mt-8 inline-block border-2 border-[#FB8500] bg-[#FB8500] text-black px-8 py-4 font-bold uppercase tracking-widest text-sm hover:bg-transparent hover:text-[#FB8500] transition-all duration-500"
        >
          Get Started
        </a>
      </div>
    </div>
  </div>
</section>

