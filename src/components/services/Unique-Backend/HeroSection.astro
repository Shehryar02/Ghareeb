---
import { Image } from 'astro:assets';
// Assuming these are your paths based on previous context
import CloudImg from "../../../assets/backend-services/backend2.jpg";
import SecurityImg from "../../../assets/backend-services/security.jpg";
import DBImg from "../../../assets/backend-services/db.jpg";

const techStack = [
  { name: 'Node.js', path: 'M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71L12 2z' },
  { name: 'PostgreSQL', path: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5' },
  { name: 'Docker', path: 'M22 10H2v10h20V10zM18 14h-2v-2h2v2z' },
  { name: 'Redis', path: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' }
];

const mainFeatures = [
  { img: CloudImg, label: "Cloud Sync", sub: "Distributed Nodes", code: "v4.2" },
  { img: SecurityImg, label: "Secured API", sub: "Auth Guard v3", code: "SSL" },
];
---

<section class="relative w-full min-h-screen flex items-center bg-white py-12 overflow-hidden">
  <div class="absolute inset-0 z-0 opacity-[0.04] pointer-events-none" 
       style="background-image: linear-gradient(#000 1.5px, transparent 1.5px), linear-gradient(90deg, #000 1.5px, transparent 1.5px); background-size: 80px 80px;">
  </div>

  <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center relative z-10">
    
    <div class="max-w-xl">
      <div class="flex items-center gap-4 mb-10">
        <div class="h-[2px] w-12 bg-orange-600"></div>
        <span class="text-[11px] font-black uppercase tracking-[0.5em] text-gray-400">Core Infrastructure</span>
      </div>
      
      <h1 class="text-7xl lg:text-8xl font-black text-black leading-[0.85] tracking-tighter mb-8">
        SCALABLE <br/> 
        <span class="text-orange-600">BACKEND.</span>
      </h1>
      
      <p class="text-lg text-gray-600 font-medium leading-relaxed mb-12">
        We deploy high-availability backend clusters with zero-latency edge computation and hardened security protocols.
      </p>

      <div class="flex items-center gap-8 mb-16">
        <button class="px-10 py-5 bg-black text-white font-bold uppercase tracking-widest hover:bg-orange-600 transition-all shadow-xl">
          Launch Deployment
        </button>
        <div class="flex flex-col border-l-2 border-gray-100 pl-6">
            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Global Uptime</span>
            <span class="text-sm font-mono font-bold text-black">99.998% ACROSS 12 REGIONS</span>
        </div>
      </div>

      <div class="pt-8 border-t border-gray-100">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-6">Optimized Stack</p>
        <div class="flex items-center gap-8 grayscale opacity-40">
            {techStack.map(logo => (
                <div class="group cursor-help">
                    <svg class="w-7 h-7 text-black hover:text-orange-600 transition-colors" viewBox="0 0 24 24" fill="currentColor">
                        <path d={logo.path} />
                    </svg>
                </div>
            ))}
        </div>
      </div>
    </div>

    <div class="relative w-full h-[650px] flex items-center justify-center lg:justify-end">
      
      <div class="relative z-20 w-full max-w-[440px] h-[550px] bg-white rounded-[3rem] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.15)] border border-gray-100 p-4 overflow-hidden group">
        <div class="h-full w-full rounded-[2.5rem] overflow-hidden relative">
            <img src={CloudImg.src} alt="Cloud Architecture" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            
            <div class="absolute bottom-10 left-10 right-10">
                <div class="flex items-center gap-3 mb-4">
                    <span class="px-3 py-1 bg-orange-600 text-[10px] font-black text-white uppercase tracking-widest rounded-full">Active Module</span>
                    <span class="text-white/40 font-mono text-[10px]">#0x4F2A</span>
                </div>
                <h3 class="text-4xl font-black text-white tracking-tighter uppercase mb-2">Cloud Synced</h3>
                <p class="text-white/60 text-sm font-medium leading-relaxed">Distributed edge nodes ensuring real-time consistency across global clusters.</p>
            </div>
        </div>
      </div>

      <div class="absolute z-10 -left-12 bottom-12 w-[320px] h-[400px] bg-white rounded-[2.5rem] shadow-2xl border border-gray-100 p-3 hidden xl:block">
        <div class="h-full w-full rounded-[2rem] overflow-hidden relative">
            <img src={SecurityImg.src} alt="Security" class="w-full h-full object-cover grayscale" />
            <div class="absolute inset-0 bg-orange-600/10 mix-blend-multiply"></div>
            <div class="absolute inset-0 p-8 flex flex-col justify-end">
                <h4 class="text-xl font-black text-white uppercase tracking-tighter">Auth Guard v3</h4>
                <div class="h-1 w-12 bg-orange-600 mt-2"></div>
            </div>
        </div>
      </div>

      <div class="absolute -top-10 -right-10 w-64 h-64 bg-orange-600/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-10 flex gap-2">
         <div class="w-12 h-12 rounded-2xl bg-black flex items-center justify-center text-white shadow-xl">
             <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
         </div>
         <div class="px-6 py-3 bg-white rounded-2xl border border-gray-100 shadow-xl flex items-center">
             <span class="text-[10px] font-black uppercase tracking-widest text-black">Low Latency Verified</span>
         </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* Optional smooth float animation */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }
  
</style>