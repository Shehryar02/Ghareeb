---
/**
 * ServiceCaseStudies - Card Grid Edition
 */
interface Project {
  tag: string;
  title: string;
  desc: string;
  image: string;
  link: string;
}

interface Props {
  tag?: string;
  title?: string;
  titleAccent?: string;
  projects: Project[];
}

const {
  tag = "Precision_Engineering",
  title = "DIGITAL",
  titleAccent = "MASTERY.",
  projects = []
} = Astro.props;
---

<section class="py-16 md:py-24 lg:py-32 bg-[#020D0A] overflow-hidden relative">
  <div class="max-w-7xl mx-auto px-5 sm:px-6">

    <div class="mb-10 md:mb-14 lg:mb-20 cs-header">
      <div class="flex items-center gap-3 mb-4 md:mb-6">
        <div class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></div>
        <p class="text-[9px] md:text-[10px] font-mono font-black uppercase tracking-[0.5em] text-white/30">{tag}</p>
      </div>
      <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-[1000] text-white uppercase tracking-tighter leading-[0.85]">
        {title} <br />
        <span class="text-orange-500 italic">{titleAccent}</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 md:gap-6">
      {projects.map((project, i) => (
        <a href={project.link} class="cs-card group relative rounded-2xl sm:rounded-3xl overflow-hidden bg-[#0A0A0A] border border-white/[0.06] hover:border-orange-500/30 transition-all duration-500">
          
          <div class="relative aspect-[4/3] overflow-hidden">
            <img 
              src={project.image} 
              alt={project.title}
              class="w-full h-full object-cover opacity-60 grayscale-[30%] transition-all duration-700 group-hover:scale-110 group-hover:grayscale-0 group-hover:opacity-80"
              loading={i < 3 ? "eager" : "lazy"}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0A] via-[#0A0A0A]/30 to-transparent"></div>
            
            <div class="absolute top-3 right-3 sm:top-4 sm:right-4 w-9 h-9 sm:w-10 sm:h-10 border border-white/10 rounded-lg sm:rounded-xl flex items-center justify-center backdrop-blur-md bg-black/20">
              <span class="text-white/30 font-mono text-[10px] sm:text-xs">0{i+1}</span>
            </div>

            <div class="absolute bottom-3 left-3 sm:bottom-4 sm:left-4">
              <span class="text-orange-500 font-mono font-bold uppercase tracking-[0.3em] text-[8px] sm:text-[9px]">
                Case_{i + 1}
              </span>
            </div>
          </div>

          <div class="p-4 sm:p-5 md:p-6 flex flex-col gap-3 sm:gap-4">
            <h3 class="text-white text-base sm:text-lg md:text-xl font-black uppercase tracking-tight leading-tight group-hover:text-orange-500 transition-colors duration-300">
              {project.title}
            </h3>
            
            <p class="text-white/40 text-xs sm:text-[13px] leading-relaxed line-clamp-3">
              {project.desc}
            </p>
            
            <div class="flex items-center gap-2 pt-2 sm:pt-3 border-t border-white/[0.06]">
              <span class="text-[9px] sm:text-[10px] font-black uppercase tracking-[0.2em] text-orange-500 group-hover:text-white transition-colors duration-300">
                Explore Case Study
              </span>
              <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5 text-orange-500 group-hover:translate-x-1 group-hover:text-white transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </div>

          <div class="absolute inset-0 rounded-2xl sm:rounded-3xl ring-1 ring-inset ring-white/[0.04] group-hover:ring-orange-500/20 transition-all duration-500 pointer-events-none"></div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .cs-header {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .cs-header.active {
    opacity: 1;
    transform: translateY(0);
  }

  .cs-card {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.19, 1, 0.22, 1),
                transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .cs-card.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initCaseStudyCards() {
    const section = document.querySelector('#apple-hover-carousel') || document.querySelector('section:has(.cs-header)');
    if (!section) return;

    if (section.classList.contains('cs-init')) return;
    section.classList.add('cs-init');

    const header = section.querySelector('.cs-header');
    const cards = section.querySelectorAll('.cs-card');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    if (header) observer.observe(header);

    cards.forEach((card, i) => {
      (card as HTMLElement).style.transitionDelay = `${i * 100}ms`;
      observer.observe(card);
    });
  }

  document.addEventListener('astro:page-load', initCaseStudyCards);
</script>