---
import { Image } from 'astro:assets';
import CloudImg from "../../../assets/frontend-services/frontend.jpg";
import SecurityImg from "../../../assets/frontend-services/frontend.jpg";

const techStack = [
  // React / Component-based icon
  { name: 'React', path: 'M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71L12 2z' }, 
  // Tailwind / CSS icon
  { name: 'Tailwind', path: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5' },
  // Framer Motion / Animation icon
  { name: 'Animations', path: 'M22 10H2v10h20V10zM18 14h-2v-2h2v2z' },
  // Typescript icon
  { name: 'TypeScript', path: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' }
];

const mainFeatures = [
  { img: CloudImg, label: "UI Design", sub: "Atomic Components", code: "v6.0" },
  { img: SecurityImg, label: "Motion Engine", sub: "60fps Fluidity", code: "GPU" },
];
---

<section class="relative w-full min-h-screen flex items-center bg-white py-12 overflow-hidden">
  <div class="absolute inset-0 z-0 opacity-[0.04] pointer-events-none" 
       style="background-image: linear-gradient(#000 1.5px, transparent 1.5px), linear-gradient(90deg, #000 1.5px, transparent 1.5px); background-size: 80px 80px;">
  </div>

  <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center relative z-10">
    
    <div class="max-w-xl">
      <div class="flex items-center gap-4 mb-10">
        <div class="h-[2px] w-12 bg-orange-600"></div>
        <span class="text-[11px] font-black uppercase tracking-[0.5em] text-gray-400">Visual Experience</span>
      </div>
      
      <h1 class="text-7xl lg:text-8xl font-black text-black leading-[0.85] tracking-tighter mb-8">
        IMMERSIVE <br/> 
        <span class="text-orange-600">FRONTEND.</span>
      </h1>
      
      <p class="text-lg text-gray-600 font-medium leading-relaxed mb-12">
        We craft high-performance user interfaces with pixel-perfect precision, fluid motion systems, and accessible design patterns.
      </p>

      <div class="flex items-center gap-8 mb-16">
        <button class="px-10 py-5 bg-black text-white font-bold uppercase tracking-widest hover:bg-orange-600 transition-all shadow-xl">
          View Portfolio
        </button>
        <div class="flex flex-col border-l-2 border-gray-100 pl-6">
            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Performance Score</span>
            <span class="text-sm font-mono font-bold text-black">100 LIGHTHOUSE OPTIMIZED</span>
        </div>
      </div>

      <div class="pt-8 border-t border-gray-100">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-6">Mastered Technologies</p>
        <div class="flex items-center gap-8 grayscale opacity-40">
            {techStack.map(logo => (
                <div class="group cursor-help">
                    <svg class="w-7 h-7 text-black hover:text-orange-600 transition-colors" viewBox="0 0 24 24" fill="currentColor">
                        <path d={logo.path} />
                    </svg>
                </div>
            ))}
        </div>
      </div>
    </div>

    <div class="relative w-full h-[650px] flex items-center justify-center lg:justify-end">
      
      <div class="relative z-20 w-full max-w-[440px] h-[550px] bg-white rounded-[3rem] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.15)] border border-gray-100 p-4 overflow-hidden group">
        <div class="h-full w-full rounded-[2.5rem] overflow-hidden relative">
            <img src={CloudImg.src} alt="Modern Interface Design" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            
            <div class="absolute bottom-10 left-10 right-10">
                <div class="flex items-center gap-3 mb-4">
                    <span class="px-3 py-1 bg-orange-600 text-[10px] font-black text-white uppercase tracking-widest rounded-full">Atomic Component</span>
                    <span class="text-white/40 font-mono text-[10px]">#REACT-UI</span>
                </div>
                <h3 class="text-4xl font-black text-white tracking-tighter uppercase mb-2">Design Systems</h3>
                <p class="text-white/60 text-sm font-medium leading-relaxed">Scalable design tokens and component libraries for cohesive brand experiences.</p>
            </div>
        </div>
      </div>

      <div class="absolute z-10 -left-12 bottom-12 w-[320px] h-[400px] bg-white rounded-[2.5rem] shadow-2xl border border-gray-100 p-3 hidden xl:block animate-float">
        <div class="h-full w-full rounded-[2rem] overflow-hidden relative">
            <img src={SecurityImg.src} alt="Fluid Animations" class="w-full h-full object-cover grayscale" />
            <div class="absolute inset-0 bg-orange-600/10 mix-blend-multiply"></div>
            <div class="absolute inset-0 p-8 flex flex-col justify-end">
                <h4 class="text-xl font-black text-white uppercase tracking-tighter leading-tight">Motion <br/> Engine v2</h4>
                <div class="h-1 w-12 bg-orange-600 mt-2"></div>
            </div>
        </div>
      </div>

      <div class="absolute -top-10 -right-10 w-64 h-64 bg-orange-600/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-10 flex gap-2">
         <div class="w-12 h-12 rounded-2xl bg-black flex items-center justify-center text-white shadow-xl">
             <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
             </svg>
         </div>
         <div class="px-6 py-3 bg-white rounded-2xl border border-gray-100 shadow-xl flex items-center">
             <span class="text-[10px] font-black uppercase tracking-widest text-black">A11Y & SEO Compliant</span>
         </div>
      </div>
    </div>

  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
  }
</style>