---
interface Props {
  title?: string;
  steps: Array<{
    number: string;
    title: string;
    description: string;
  }>;
}

const { title = "How We Work", steps } = Astro.props;
---

<section class="py-32 bg-white text-black relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-24 relative z-10">
    <div class="mb-16">
      <p class="text-[#FB8500] font-black tracking-[0.4em] uppercase text-[10px] mb-4">Process</p>
      <h2 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-none uppercase">
        {title}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="relative group">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-16 h-16 bg-black text-white rounded-full flex items-center justify-center text-2xl font-black group-hover:bg-[#FB8500] transition-colors duration-500">
              {step.number}
            </div>
            <div class="flex-1 pt-2">
              <h3 class="text-xl font-bold uppercase tracking-tight mb-3">{step.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed font-light">
                {step.description}
              </p>
            </div>
          </div>
          {index < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 left-8 w-full h-px bg-gray-200 -z-10" style={`width: calc(100% + 2rem); left: 4rem;`}></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

