---
import { Image } from 'astro:assets';
import HeroImage from '../../../assets/service/hero.jpg';
---

<section class="relative h-[110vh] flex items-center justify-center bg-white overflow-hidden">
  
  <div class="absolute inset-0 z-0">
    <Image 
      src={HeroImage} 
      alt="Background" 
      class="w-full h-full object-cover scale-110 opacity-[0.3] animate-pan-slow"
    />
    
    <div class="absolute inset-0 bg-gradient-to-b from-white via-transparent to-white"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-white via-transparent to-white"></div>
    
    <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] bg-orange-500/[0.04] rounded-full blur-[120px] animate-pulse-slow"></div>
  </div>

  <div class="relative z-10 w-full text-center px-6">
    
    <div class="flex justify-center mb-10">
      <div class="px-5 py-2 border border-black/[0.06] rounded-full bg-white shadow-sm overflow-hidden group">
        <span class="block text-orange-600 font-black tracking-[0.4em] uppercase text-[9px] animate-slide-up">
          EST. 2024 — Agency Elite
        </span>
      </div>
    </div>

    <div class="relative inline-block">
        <h1 class="text-[13vw] md:text-[11vw] font-[1000] leading-[0.75] uppercase tracking-[-0.07em] text-black select-none">
          <span class="block animate-reveal-text opacity-0" style="animation-delay: 0.2s;">Digital</span>
          <span class="block text-transparent stroke-orange-light hover:text-orange-500 transition-all duration-1000 cursor-default opacity-0 animate-reveal-text" style="animation-delay: 0.5s;">
            Solutions.
          </span>
        </h1>
    </div>

    <div class="mt-20 max-w-xl mx-auto flex flex-col items-center gap-12">
      <p class="text-gray-400 text-xs md:text-sm font-bold tracking-[0.25em] leading-relaxed uppercase animate-fade-in opacity-0" style="animation-delay: 1s;">
          Transforming standard code into <br/>
          <span class="text-black">Precision Digital Weapons</span>
      </p>
      
      <div class="relative flex flex-col items-center group cursor-pointer">
        <div class="w-px h-24 bg-gradient-to-b from-black/[0.05] via-orange-500 to-transparent relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-full bg-orange-600 animate-scroll-line"></div>
        </div>
        <span class="mt-6 text-[9px] font-black uppercase tracking-[0.6em] text-black/20 group-hover:text-orange-600 transition-colors">Scroll</span>
      </div>
    </div>
  </div>

  <div class="absolute top-1/2 left-10 -translate-y-1/2 hidden xl:block">
     <div class="rotate-[-90deg] origin-left">
        <span class="text-black/[0.03] font-black text-8xl tracking-tighter uppercase">High Performance</span>
     </div>
  </div>
  
  <div class="absolute bottom-20 right-10 hidden xl:block">
     <div class="flex items-center gap-4">
        <span class="text-orange-500 font-black text-[10px] uppercase tracking-[0.6em]">The Arsenal Pack</span>
        <div class="w-16 h-[2px] bg-orange-500/10"></div>
     </div>
  </div>

</section>

<style>
  /* Refined Stroke for White Background */
  .stroke-orange-light {
    -webkit-text-stroke: 1.5px #ff6900;
  }
  
  .stroke-orange-light:hover {
    -webkit-text-stroke: 1.5px rgba(251, 133, 0, 0);
  }

  /* Reveal Animations */
  @keyframes reveal-text {
    0% { transform: translateY(60px); opacity: 0; filter: blur(15px); }
    100% { transform: translateY(0); opacity: 1; filter: blur(0); }
  }
  .animate-reveal-text {
    animation: reveal-text 1.6s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  /* Faster, Snappier Scroll Line */
  @keyframes scroll-line {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }
  .animate-scroll-line {
    animation: scroll-line 1.8s cubic-bezier(0.76, 0, 0.24, 1) infinite;
  }

  /* Background Pan */
  @keyframes pan-slow {
    0% { transform: scale(1.1) translateX(-1%); }
    100% { transform: scale(1.15) translateX(1%); }
  }
  .animate-pan-slow {
    animation: pan-slow 25s linear infinite alternate;
  }

  /* Simple Fade */
  .animate-fade-in {
    animation: fade-in 1.2s ease-out forwards;
  }
  @keyframes fade-in {
    to { opacity: 1; }
  }

  /* Aura Pulse */
  @keyframes pulse {
    0% { opacity: 0.4; transform: scale(1); }
    100% { opacity: 0.8; transform: scale(1.1); }
  }
  .animate-pulse-slow {
    animation: pulse 10s ease-in-out infinite alternate;
  }
</style>