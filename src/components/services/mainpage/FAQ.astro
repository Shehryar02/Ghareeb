---
const faqs = [
  { 
    question: "Why choose a specialized studio over a large agency?", 
    answer: "Large agencies often treat projects like a factory line. We operate as a high-velocity taskforce. You get direct access to the architects, zero communication lag, and a product built with elite technical standards, not bloated overhead." 
  },
  { 
    question: "What performance benchmarks do you guarantee?", 
    answer: "We aim for the 'Green Zone' across all Core Web Vitals. This means sub-2-second load times and 90+ Lighthouse scores. We don't just ship code; we ship competitive performance advantages." 
  },
  { 
    question: "How do we maintain control over the project?", 
    answer: "Total transparency. We use a real-time 'Deployment Portal' where you can track every sprint, see the live build-in-progress, and communicate directly with the lead engineer at any moment." 
  },
  { 
    question: "Is the code scalable for future expansion?", 
    answer: "Every line is written with 'Modular Architecture.' We use headless technologies and clean-code principles, ensuring that as your business grows, your digital infrastructure scales without needing a total rebuild." 
  }
];
---

<section class="bg-white py-32 relative z-20 overflow-hidden">
  <div class="max-w-5xl mx-auto px-6">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8">
        <div class="max-w-xl">
            <h2 class="text-6xl md:text-8xl font-[1000] uppercase tracking-[-0.06em] text-black leading-none">
                The <span class="text-orange-500 italic">Intel<span class="text-black">.</span></span>
            </h2>
        </div>
        <p class="text-gray-400 font-bold uppercase text-[10px] tracking-[0.5em] mb-2">
            Protocol & Operations FAQ
        </p>
    </div>

    <div class="space-y-4">
      {faqs.map((faq, index) => (
        <div class="faq-item group">
          <button 
            class="faq-trigger w-full flex items-center justify-between p-8 md:p-10 bg-[#fafafa] border border-black/[0.03] rounded-[2rem] transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] hover:bg-black group-hover:shadow-[0_20px_40px_rgba(0,0,0,0.1)] group-hover:-translate-y-1"
          >
            <div class="flex items-center gap-8">
                <span class="text-xs font-black text-orange-500/40 group-hover:text-orange-500 transition-colors">0{index + 1}</span>
                <span class="text-xl md:text-2xl font-black text-black group-hover:text-white transition-colors text-left tracking-tight">
                    {faq.question}
                </span>
            </div>
            
            <div class="relative w-10 h-10 rounded-full border border-black/5 group-hover:border-white/20 flex items-center justify-center transition-all">
                <div class="absolute w-4 h-[2px] bg-black group-hover:bg-white transition-colors"></div>
                <div class="icon-vert absolute h-4 w-[2px] bg-black group-hover:bg-white transition-all duration-500"></div>
            </div>
          </button>
          
          <div class="faq-content max-h-0 overflow-hidden transition-all duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]">
            <div class="p-10 pt-4 text-gray-500 text-lg leading-relaxed max-w-3xl ml-12 border-l-2 border-orange-500/20 mt-4">
               {faq.answer}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll('.faq-item');
  
  items.forEach(item => {
    const trigger = item.querySelector('.faq-trigger');
    const content = item.querySelector('.faq-content') as HTMLElement;
    const vertLine = item.querySelector('.icon-vert');

    trigger?.addEventListener('click', () => {
      const isOpen = content.style.maxHeight !== '0px' && content.style.maxHeight !== '';
      
      // Close all others (Optional: comment out if you want multiple open)
      document.querySelectorAll('.faq-content').forEach(c => (c as HTMLElement).style.maxHeight = '0px');
      document.querySelectorAll('.icon-vert').forEach(v => (v as HTMLElement).style.transform = 'rotate(0deg)');

      // Toggle current
      if (!isOpen) {
        content.style.maxHeight = content.scrollHeight + 'px';
        vertLine?.setAttribute('style', 'transform: rotate(90deg); opacity: 0;');
      } else {
        content.style.maxHeight = '0px';
        vertLine?.setAttribute('style', 'transform: rotate(0deg); opacity: 1;');
      }
    });
  });
</script>