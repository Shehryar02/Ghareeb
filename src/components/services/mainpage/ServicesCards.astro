---
const services = [
  { title: "Business Websites", description: "Professional websites that reflect your brand and drive conversions.", href: "/services/business-websites", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
  { title: "E-Commerce Stores", description: "Powerful online stores with seamless shopping experiences and secure payments.", href: "/services/ecommerce-stores", icon: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" },
  { title: "Custom Web Apps", description: "Tailored web applications designed specifically for your business needs.", href: "/services/custom-web-apps", icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" },
  { title: "Landing Pages", description: "High-converting landing pages optimized for your marketing campaigns.", href: "/services/landing-pages", icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" },
  { title: "Frontend Development", description: "Modern UI/UX development with React, Next.js, and cutting-edge technologies.", href: "/services/frontend-development", icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" },
  { title: "Backend Development", description: "Robust server solutions, APIs, and scalable backend infrastructure.", href: "/services/backend-development", icon: "M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" },
  { title: "Maintenance & Support", description: "Ongoing care to keep your website running smoothly and securely.", href: "/services/maintenance-support", icon: "M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" },
  { title: "Speed Optimization", description: "Transform slow websites into lightning-fast experiences with performance optimization.", href: "/services/speed-optimization", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { title: "CMS Development", description: "Custom content management systems that make content updates easy and efficient.", href: "/services/cms-development", icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" },
  { title: "Deployment & Hosting", description: "Reliable infrastructure and deployment solutions for your applications.", href: "/services/deployment-hosting", icon: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" }
];
---

<section class="bg-[#050505] py-32 pb-48 relative z-20 overflow-hidden">
    <div class="absolute top-[-10%] right-[-10%] w-[800px] h-[800px] bg-orange-500/10 rounded-full blur-[160px] pointer-events-none animate-pulse"></div>
    <div class="absolute bottom-[-10%] left-[-10%] w-[600px] h-[600px] bg-white/[0.02] rounded-full blur-[140px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-24">
      
      <div class="flex flex-col md:flex-row justify-between items-end mb-32 gap-12 relative z-10">
        <div class="max-w-2xl">
            <h2 class="text-7xl md:text-9xl font-[1000] uppercase leading-[0.8] tracking-[-0.05em] text-white mb-10">
                The <span class="text-orange-500 italic">Arsenal<span class="text-white">.</span></span>
            </h2>
            <div class="flex items-center gap-4">
                <span class="text-orange-500 font-black text-xs tracking-[0.5em] uppercase">Tactical Suite 2026</span>
                <div class="h-[1px] flex-grow max-w-[100px] bg-gradient-to-r from-orange-500 to-transparent"></div>
            </div>
        </div>
        <p class="text-gray-400 font-light text-sm max-w-xs leading-relaxed border-l border-orange-500/30 pl-8">
            Engineered for high-stakes digital environments where <span class="text-white font-bold">performance isn't optional.</span>
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {services.map((service, index) => (
          <a 
            href={service.href} 
            class="group relative aspect-[4/5] flex flex-col justify-between p-12 transition-all duration-700 ease-[cubic-bezier(0.19,1,0.22,1)]"
          >
            <div class="absolute inset-0 bg-orange-600/0 group-hover:bg-orange-600/20 rounded-[3.5rem] blur-[60px] scale-90 group-hover:scale-110 transition-all duration-700 pointer-events-none"></div>

            <div class="absolute inset-0 bg-gradient-to-b from-[#111] to-[#080808] border border-white/5 rounded-[3.5rem] transition-all duration-500 group-hover:border-orange-500/40 group-hover:-translate-y-4 shadow-2xl group-hover:shadow-orange-500/10"></div>
            
            <div class="absolute inset-0 rounded-[3.5rem] bg-gradient-to-br from-white/[0.08] via-transparent to-transparent opacity-100 group-hover:opacity-50 pointer-events-none"></div>

            <div class="relative z-10 group-hover:-translate-y-6 transition-transform duration-700 ease-[cubic-bezier(0.19,1,0.22,1)]">
                <div class="flex justify-between items-start mb-12">
                    <div class="w-16 h-16 bg-[#1a1a1a] rounded-[1.5rem] flex items-center justify-center border border-white/5 shadow-[5px_5px_15px_rgba(0,0,0,0.5)] group-hover:bg-orange-500 group-hover:shadow-[0_0_30px_rgba(251,133,0,0.4)] transition-all duration-500 group-hover:-rotate-12 group-hover:scale-110">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="text-orange-500 group-hover:text-white transition-colors duration-500">
                            <path d={service.icon}></path>
                        </svg>
                    </div>
                    <span class="text-6xl font-black text-white/[0.02] group-hover:text-orange-500/10 transition-colors duration-700 italic">
                        0{index + 1}
                    </span>
                </div>

                <div>
                    <h3 class="text-3xl font-black uppercase mb-4 tracking-tighter text-white group-hover:text-orange-500 transition-colors duration-500 leading-none">
                      {service.title}
                    </h3>
                    <p class="text-gray-500 text-[13px] font-medium leading-relaxed group-hover:text-gray-300 transition-colors duration-500 max-w-[90%]">
                      {service.description}
                    </p>
                </div>
            </div>

            <div class="relative z-10 flex items-center justify-between group-hover:-translate-y-4 transition-transform duration-700">
                <div class="flex items-center gap-3">
                    <div class="h-[1px] w-6 bg-orange-500/50 group-hover:w-12 group-hover:bg-orange-500 transition-all duration-700"></div>
                    <span class="text-[10px] font-black uppercase tracking-[0.4em] text-white/30 group-hover:text-white transition-colors">
                        Deploy
                    </span>
                </div>
                <div class="opacity-0 group-hover:opacity-100 transition-all duration-700 group-hover:translate-x-2">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FB8500" stroke-width="2.5">
                        <path d="M5 12h14m-7-7l7 7-7 7"/>
                    </svg>
                </div>
            </div>
          </a>
        ))}
      </div>
    </div>
</section>

