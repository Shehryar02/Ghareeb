---
interface Props {
  title?: string;
  benefits: Array<{
    title: string;
    description: string;
  }>;
}

const { title = "Why Choose Us", benefits } = Astro.props;
---

<section class="py-32 bg-[#0a0a0a] text-white relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
       style="background-image: radial-gradient(#FB8500 0.5px, transparent 0.5px); background-size: 30px 30px;">
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-24 relative z-10">
    <div class="mb-16">
      <p class="text-[#FB8500] font-black tracking-[0.4em] uppercase text-[10px] mb-4">Benefits</p>
      <h2 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-none uppercase">
        {title}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {benefits.map((benefit) => (
        <div class="group relative bg-[#0a0a0a] border-l-4 border-[#FB8500]/50 pl-8 py-6 hover:border-[#FB8500] transition-all duration-500">
          <h3 class="text-2xl font-bold uppercase tracking-tight mb-3">{benefit.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed font-light">
            {benefit.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

