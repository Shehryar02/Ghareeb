---
import { Image } from 'astro:assets';
// Updated asset naming to reflect SEO focus
import SearchImg from "../../../assets/seo-services/top1.jpg";
import AnalyticsImg from "../../../assets/seo-services/top2.jpg";

const techStack = [
  // Semantic HTML / Schema icon
  { name: 'Schema.org', path: 'M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71L12 2z' },
  // Core Web Vitals / Speed icon
  { name: 'Web Vitals', path: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5' },
  // Indexing / Search Console icon
  { name: 'Indexing', path: 'M22 10H2v10h20V10zM18 14h-2v-2h2v2z' },
  // Authority / Backlinks icon
  { name: 'Authority', path: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' }
];
---

<section class="relative w-full min-h-screen flex items-center bg-white py-12 overflow-hidden">
  <div class="absolute inset-0 z-0 opacity-[0.04] pointer-events-none" 
       style="background-image: linear-gradient(#000 1.5px, transparent 1.5px), linear-gradient(90deg, #000 1.5px, transparent 1.5px); background-size: 80px 80px;">
  </div>

  <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center relative z-10">
    
    <div class="max-w-xl">
      <div class="flex items-center gap-4 mb-10">
        <div class="h-[2px] w-12 bg-orange-600"></div>
        <span class="text-[11px] font-black uppercase tracking-[0.5em] text-gray-400">Search Engine Dominance</span>
      </div>
      
      <h1 class="text-7xl lg:text-8xl font-black text-black leading-[0.85] tracking-tighter mb-8">
        TECHNICAL <br/> 
        <span class="text-orange-600">SEO.</span>
      </h1>
      
      <p class="text-lg text-gray-600 font-medium leading-relaxed mb-12">
        We engineer search-first architectures that satisfy Core Web Vitals, semantic data requirements, and aggressive crawler indexing.
      </p>

      <div class="flex items-center gap-8 mb-16">
        <button class="px-10 py-5 bg-black text-white font-bold uppercase tracking-widest hover:bg-orange-600 transition-all shadow-xl">
          Audit Authority
        </button>
        <div class="flex flex-col border-l-2 border-gray-100 pl-6">
            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Page Experience</span>
            <span class="text-sm font-mono font-bold text-black">100/100 LIGHTHOUSE VERIFIED</span>
        </div>
      </div>

      <div class="pt-8 border-t border-gray-100">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-6">Optimization Stack</p>
        <div class="flex items-center gap-8 grayscale opacity-40">
            {techStack.map(logo => (
                <div class="group cursor-help" title={logo.name}>
                    <svg class="w-7 h-7 text-black hover:text-orange-600 transition-colors" viewBox="0 0 24 24" fill="currentColor">
                        <path d={logo.path} />
                    </svg>
                </div>
            ))}
        </div>
      </div>
    </div>

    <div class="relative w-full h-[650px] flex items-center justify-center lg:justify-end">
      
      <div class="relative z-20 w-full max-w-[440px] h-[550px] bg-white rounded-[3rem] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.15)] border border-gray-100 p-4 overflow-hidden group">
        <div class="h-full w-full rounded-[2.5rem] overflow-hidden relative">
            <img src={SearchImg.src} alt="Search Visibility Data" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            
            <div class="absolute bottom-10 left-10 right-10">
                <div class="flex items-center gap-3 mb-4">
                    <span class="px-3 py-1 bg-orange-600 text-[10px] font-black text-white uppercase tracking-widest rounded-full">Active Crawler</span>
                    <span class="text-white/40 font-mono text-[10px]">#INDEX-SITEMAP</span>
                </div>
                <h3 class="text-4xl font-black text-white tracking-tighter uppercase mb-2">Authority Flow</h3>
                <p class="text-white/60 text-sm font-medium leading-relaxed">Optimizing link topology and semantic nesting to maximize domain authority distribution.</p>
            </div>
        </div>
      </div>

      <div class="absolute z-10 -left-12 bottom-12 w-[320px] h-[400px] bg-white rounded-[2.5rem] shadow-2xl border border-gray-100 p-3 hidden xl:block">
        <div class="h-full w-full rounded-[2rem] overflow-hidden relative">
            <img src={AnalyticsImg.src} alt="Velocity Metrics" class="w-full h-full object-cover grayscale" />
            <div class="absolute inset-0 bg-orange-600/10 mix-blend-multiply"></div>
            <div class="absolute inset-0 p-8 flex flex-col justify-end">
                <h4 class="text-xl font-black text-white uppercase tracking-tighter">Core Vitals v4</h4>
                <div class="h-1 w-12 bg-orange-600 mt-2"></div>
            </div>
        </div>
      </div>

      <div class="absolute -top-10 -right-10 w-64 h-64 bg-orange-600/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-10 flex gap-2">
         <div class="w-12 h-12 rounded-2xl bg-black flex items-center justify-center text-white shadow-xl">
             <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
         </div>
         <div class="px-6 py-3 bg-white rounded-2xl border border-gray-100 shadow-xl flex items-center">
             <span class="text-[10px] font-black uppercase tracking-widest text-black">Crawl Budget Optimized</span>
         </div>
      </div>
    </div>

  </div>
</section>