---
/* Simple, Professional White CTA */
---

<section class="bg-white py-32 relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-zinc-200 to-transparent"></div>
  
  <div class="container mx-auto px-6 relative z-10 text-center">
    <div class="max-w-4xl mx-auto">
      
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-100 border border-zinc-200 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-orange-600 animate-pulse"></span>
        <span class="text-[10px] font-bold text-zinc-600 uppercase tracking-widest">Available for Integration</span>
      </div>

      <h2 class="text-zinc-950 text-5xl md:text-7xl font-black tracking-tighter leading-tight mb-8">
        READY TO <span class="text-orange-600 italic">SCALEOUT?</span>
      </h2>

      <p class="text-zinc-500 text-lg md:text-xl font-medium max-w-2xl mx-auto leading-relaxed mb-12">
        Move your infrastructure to a system designed for precision. Schedule a technical walkthrough of our core architecture today.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        
        <button class="group relative w-full sm:w-auto px-10 py-5 bg-zinc-950 rounded-xl overflow-hidden transition-all hover:shadow-2xl hover:shadow-zinc-400 active:scale-95">
          <span class="relative z-10 text-white font-bold uppercase text-xs tracking-widest flex items-center justify-center gap-3">
            Start Migration 
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </span>
          <div class="absolute inset-0 bg-orange-600 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
        </button>

        <button class="w-full sm:w-auto px-10 py-5 border-2 border-orange-600 rounded-xl text-orange-600 font-bold uppercase text-xs tracking-widest hover:bg-orange-50 transition-colors active:scale-95">
          View Documentation
        </button>

      </div>

      <div class="mt-20 flex flex-wrap justify-center items-center gap-x-12 gap-y-6 opacity-40 grayscale">
        <p class="text-[10px] font-black text-zinc-900 uppercase tracking-[0.3em]">Iso 27001 Certified</p>
        <p class="text-[10px] font-black text-zinc-900 uppercase tracking-[0.3em]">SLA Guaranteed</p>
        <p class="text-[10px] font-black text-zinc-900 uppercase tracking-[0.3em]">GDPR Compliant</p>
      </div>

    </div>
  </div>
</section>

<style>
  /* Ensuring sharp, professional rendering */
  h2 {
    letter-spacing: -0.04em;
  }
</style>