---
import { Image } from 'astro:assets';

interface BlogPost {
  id: string;
  title: string;
  img: any;
  description: string;
  category: string;
  date: string;
  time: string;
}

interface Props {
  blogs: BlogPost[];
  archiveLabel?: string;
}

const { blogs, archiveLabel = "Engineering Archive" } = Astro.props;
const genres = ["All", ...new Set(blogs.map(b => b.category))];
---

<section class="bg-[#FCFCFC] text-[#111111] min-h-screen py-12 px-6 md:px-12 font-sans selection:bg-[#FB8500] selection:text-white">
  <nav class="max-w-7xl mx-auto mb-16">
    <div class="flex items-center justify-between border-b-2 border-[#111111] pb-6 mb-8">
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 bg-[#111111] flex items-center justify-center text-[#FB8500] font-black italic rounded-sm">V</div>
        <span class="text-[12px] font-black uppercase tracking-[0.4em]">{archiveLabel}</span>
      </div>
    </div>
    
    <div class="flex gap-4 overflow-x-auto no-scrollbar pb-2">
      {genres.map((genre) => (
        <button 
          class="genre-btn px-5 py-2 border border-gray-100 rounded-full text-[10px] font-black uppercase tracking-widest whitespace-nowrap transition-all hover:border-[#FB8500] hover:text-[#FB8500]"
          data-genre={genre}
        >
          {genre}
        </button>
      ))}
    </div>
  </nav>

  <div class="max-w-7xl mx-auto">
    <div id="blog-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 is-editorial">
      {blogs.map((post, idx) => (
        <a href={`/blog/${post.id}`} 
           class="group flex flex-col blog-card animate-slide-up" 
           data-category={post.category}
           data-order={idx + 1}
           style={`order: ${idx + 1}`}
        >
          <div class="card-image-wrapper relative overflow-hidden rounded-[2.2rem] mb-8 border border-gray-100 transition-all duration-500 group-hover:shadow-2xl group-hover:shadow-orange-500/5">
            <Image src={post.img} alt={post.title} class="w-full h-full object-cover transition-all duration-1000 group-hover:scale-110" />
            <div class="category-badge absolute bottom-4 left-4 bg-white/90 backdrop-blur-md px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest shadow-sm border border-gray-100">
              {post.category}
            </div>
            <div class="featured-label hidden absolute top-6 left-6 bg-[#111111] text-[#FB8500] px-5 py-2 text-[10px] font-black uppercase tracking-widest rounded-full shadow-lg">
              Lead Analysis
            </div>
          </div>

          <div class="px-2">
            <div class="flex items-center gap-4 mb-4 text-[9px] font-bold text-gray-400 uppercase tracking-widest">
              <span class="card-category-text hidden text-[#FB8500]">{post.category}</span>
              <span>{post.date}</span>
              <span class="text-[#FB8500]">•</span>
              <span>{post.time}</span>
            </div>
            <h2 class="card-title text-2xl font-black text-[#111111] tracking-tighter mb-4 leading-tight uppercase group-hover:text-[#FB8500] transition-colors">
              {post.title}
            </h2>
            <p class="card-desc text-gray-500 text-sm leading-relaxed mb-10 line-clamp-2 font-medium">
              {post.description}
            </p>
            
            <div class="card-footer mt-auto flex items-center justify-between pt-4 border-t border-gray-50">
              <span class="text-[10px] font-black uppercase tracking-[0.2em] group-hover:text-[#FB8500] transition-colors">Read Brief</span>
              <div class="w-10 h-10 flex items-center justify-center border border-gray-100 group-hover:bg-[#111111] transition-all rounded-xl">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 group-hover:text-[#FB8500]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.genre-btn');
  const cards = document.querySelectorAll('.blog-card');
  const container = document.getElementById('blog-container');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const selectedGenre = btn.getAttribute('data-genre');
      
      buttons.forEach(b => b.classList.remove('bg-[#111111]', 'text-[#FB8500]', 'border-[#111111]'));
      btn.classList.add('bg-[#111111]', 'text-[#FB8500]', 'border-[#111111]');

      // Toggle Editorial mode only when "All" is selected
      if (selectedGenre === 'All') {
        container?.classList.add('is-editorial');
      } else {
        container?.classList.remove('is-editorial');
      }

      let visibleIndex = 1;
      cards.forEach((card) => {
        const category = card.getAttribute('data-category');
        const isVisible = selectedGenre === 'All' || category === selectedGenre;
        
        if (isVisible) {
          (card as HTMLElement).style.display = 'flex';
          (card as HTMLElement).style.order = visibleIndex.toString();
          // Update data-order for CSS selectors to find
          card.setAttribute('data-order', visibleIndex.toString());
          visibleIndex++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  // Initial trigger
  (document.querySelector('[data-genre="All"]') as HTMLElement)?.click();
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }

  @media (min-width: 1024px) {
    /* Force the 12-column grid and remove Tailwind's default gap */
    .is-editorial {
      display: grid !important;
      grid-template-columns: repeat(12, 1fr) !important;
      grid-template-rows: repeat(3, auto) !important;
      column-gap: 3rem !important;
      row-gap: 0 !important;
    }

    /* THE GIANT (Card 1) - Forces it to span 3 rows of height */
    .is-editorial .blog-card[data-order="1"] {
      grid-column: span 7 !important;
      grid-row: 1 / 4 !important;
      margin-bottom: 2rem !important;
      display: flex !important;
      flex-direction: column !important;
    }
    .is-editorial .blog-card[data-order="1"] .card-image-wrapper { 
      aspect-ratio: 16/10 !important; 
    }
    .is-editorial .blog-card[data-order="1"] .card-title { 
      font-size: 3.5rem !important; 
    }
    .is-editorial .blog-card[data-order="1"] .featured-label { 
      display: block !important; 
    }

    /* THE SIDEBAR STACK (2, 3, 4) */
    .is-editorial .blog-card[data-order="2"],
    .is-editorial .blog-card[data-order="3"],
    .is-editorial .blog-card[data-order="4"] {
      grid-column: span 5 !important;
      flex-direction: row !important;
      gap: 1.5rem !important;
      padding: 1.25rem 0 !important;
      border-bottom: 1px solid black !important;
      margin: 0 !important;
      align-items: flex-start !important;
    }

    /* Remove border from last sidebar item */
    .is-editorial .blog-card[data-order="4"] { 
      border-bottom: none !important; 
    }
    
    /* Ensure Card 2 aligns with the top of the Giant card */
    .is-editorial .blog-card[data-order="2"] { 
      padding-top: 0 !important; 
    }

    /* Force Sidebar Image Size */
    .is-editorial .blog-card[data-order="2"] .card-image-wrapper,
    .is-editorial .blog-card[data-order="3"] .card-image-wrapper,
    .is-editorial .blog-card[data-order="4"] .card-image-wrapper {
      width: 120px !important; 
      height: 120px !important; 
      flex-shrink: 0 !important; 
      margin-bottom: 0 !important;
      border-radius: 1rem !important;
    }

    /* Sidebar Typography */
    .is-editorial .blog-card[data-order="2"] .card-title,
    .is-editorial .blog-card[data-order="3"] .card-title,
    .is-editorial .blog-card[data-order="4"] .card-title {
      font-size: 1.1rem !important;
      line-height: 1.2 !important;
      margin-bottom: 0.5rem !important;
    }

    .is-editorial .blog-card[data-order="2"] .card-desc,
    .is-editorial .blog-card[data-order="3"] .card-desc,
    .is-editorial .blog-card[data-order="4"] .card-desc {
      font-size: 0.85rem !important;
      line-height: 1.4 !important;
      margin-bottom: 0.5rem !important;
    }

    /* Hide unnecessary elements in sidebar */
    .is-editorial .blog-card[data-order="2"] .category-badge,
    .is-editorial .blog-card[data-order="3"] .category-badge,
    .is-editorial .blog-card[data-order="4"] .category-badge,
    .is-editorial .blog-card[data-order="2"] .card-footer,
    .is-editorial .blog-card[data-order="3"] .card-footer,
    .is-editorial .blog-card[data-order="4"] .card-footer { 
      display: none !important; 
    }

    /* BOTTOM GRID (Cards 5+) - Returns to 3-column style */
    .is-editorial .blog-card[data-order="5"],
    .is-editorial .blog-card[data-order="6"],
    .is-editorial .blog-card[data-order="7"] {
      grid-column: span 4 !important;
      grid-row: auto !important;
      margin-top: 4rem !important;
      flex-direction: column !important;
    }
  }
</style>