---
const { post } = Astro.props;

// Words that should trigger the Orange color
const powerWords = ["High-Load", "Scale", "Paint", "Microservices", "Compiler", "React", "Atomic", "Crushing", "Systems"];
const titleWords = post.title ? post.title.split(' ') : [];
---

<header class="max-w-7xl px-6 mx-auto pt-32 pb-12">
  <div class="flex items-center gap-4 mb-10">
    <div class="relative group">
      <div class="absolute -inset-1 bg-gradient-to-r from-[#FB8500] to-orange-300 rounded-full blur opacity-25"></div>
      <span class="relative bg-[#111111] text-[#FB8500] px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-[0.3em] border border-white/10">
        {post.category}
      </span>
    </div>
    
    <div class="h-[1px] w-8 bg-gray-200"></div>
    
    <span class="text-gray-400 text-[10px] font-black uppercase tracking-widest">
      {post.date} <span class="mx-2 text-gray-200">|</span> {post.time} READ
    </span>
  </div>

  <h1 class="text-6xl md:text-[120px] font-black uppercase leading-[0.85] tracking-[-0.04em] text-[#111111]">
    {titleWords.map((word: string) => {
      const cleanWord = word.replace(/[^\w\s]|_/g, "");
      const isPower = powerWords.includes(cleanWord);
      return (
        <span class={isPower ? "text-[#FB8500]" : "text-[#111111]"}>
          {word}{" "}
        </span>
      );
    })}
  </h1>
</header>



