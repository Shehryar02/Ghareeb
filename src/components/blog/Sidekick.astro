---
interface RelatedPost {
  id: string;
  title: string;
  category: string;
  time: string;
  img?: any; // Supporting both strings and Astro Image objects
}

interface Props {
  relatedPosts?: RelatedPost[];
}

const { relatedPosts = [] } = Astro.props;
---

<section class="w-full bg-white border-t border-gray-100 py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 md:gap-0 mb-10 lg:mb-16">
      <div>
        <span class="text-[10px] font-black text-[#FB8500] uppercase tracking-[0.4em] block mb-2">Reference_Library</span>
        <h3 class="text-3xl sm:text-4xl font-black text-[#111111] uppercase tracking-tighter text-balance">Related Records</h3>
      </div>
      <div class="hidden md:block">
        <div class="h-[1px] w-24 bg-gray-100"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {relatedPosts.map((post) => (
        <a href={`/blogs/${post.id}`} class="group flex flex-col">
          
          <div class="relative aspect-[16/10] overflow-hidden rounded-2xl bg-gray-50 mb-8 transition-all duration-500 group-hover:shadow-2xl group-hover:shadow-[#FB8500]/10">
            {post.img && (
              <img 
                src={typeof post.img === 'string' ? post.img : post.img.src} 
                alt={post.title} 
                class="w-full h-full object-cover saturate-[0.4] group-hover:saturate-100 group-hover:scale-105 transition-all duration-700 ease-in-out"
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[#111111]/20 to-transparent opacity-60 group-hover:opacity-0 transition-opacity duration-500"></div>
          </div>

          <div class="flex items-center gap-3 mb-4 px-1">
            <span class="text-[10px] font-black text-[#FB8500] uppercase tracking-widest">{post.category}</span>
            <span class="text-gray-200">•</span>
            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">{post.time}</span>
          </div>

          <h4 class="text-xl sm:text-2xl font-black text-[#111111] uppercase tracking-tighter leading-[1.1] px-1 group-hover:text-[#FB8500] transition-colors duration-300">
            {post.title}
          </h4>
          
          <div class="mt-8 flex items-center gap-2 px-1">
            <div class="h-[2px] w-0 bg-[#111111] group-hover:w-10 transition-all duration-500 ease-out"></div>
            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-[#111111] opacity-0 group-hover:opacity-100 transition-all duration-500">
              Access File
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  section {
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
</style>