---
interface Props {
  post: {
    title: string;
    category: string;
  };
}

const { post } = Astro.props;
---

<section class="w-full bg-[#0A0A0A] border-t border-white/5 py-24 relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.02] pointer-events-none" 
       style="background-image: linear-gradient(#white 1px, transparent 1px), linear-gradient(90deg, #white 1px, transparent 1px); background-size: 50px 50px;">
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      
      <div class="flex flex-col h-full justify-between">
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-2 h-2 bg-[#FB8500] rounded-full animate-pulse"></div>
            <span class="text-[10px] font-black uppercase tracking-[0.5em] text-[#FB8500]">System_Direct</span>
          </div>
          
          <h2 class="text-4xl md:text-6xl font-black text-white uppercase tracking-tighter leading-[0.9] mb-8">
            Consult With Our <br/> Lead Engineers
          </h2>
          
          <p class="text-xl text-white/40 leading-relaxed mb-10 max-w-md font-medium">
            Ready to implement {post.category} optimizations? Contact our technical cell for a direct architecture audit.
          </p>
        </div>

        <div>
          <a 
            href="/contact" 
            class="inline-flex items-center gap-4 bg-[#FB8500] hover:bg-white text-[#0A0A0A] font-black uppercase text-[11px] px-12 py-6 rounded-2xl transition-all duration-500 tracking-[0.2em] group"
          >
            Establish Contact
            <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
          </a>
        </div>
      </div>

      <div class="bg-white/3 border border-white/10 p-12 rounded-[2.5rem] backdrop-blur-xl">
        <div class="mb-10">
          <h4 class="text-white text-2xl font-black uppercase tracking-tight mb-2 italic">Intelligence Sync</h4>
          <p class="text-white/30 text-[10px] uppercase tracking-[0.3em] font-bold">Secure technical updates delivered monthly.</p>
        </div>
        
        <form class="space-y-4" onsubmit="return false;">
          <div class="group relative">
            <input 
              type="email" 
              required
              placeholder="ENTER_CORPORATE_EMAIL" 
              class="w-full bg-black/60 border border-white/10 px-6 py-6 rounded-2xl text-white font-mono text-[10px] focus:outline-none focus:border-[#FB8500] transition-all placeholder:text-white/10"
            />
            <div class="absolute inset-y-0 right-6 flex items-center pointer-events-none opacity-20 group-focus-within:text-[#FB8500] group-focus-within:opacity-100 transition-all font-mono text-[10px]">
              @
            </div>
          </div>
          
          <button class="w-full bg-white text-[#0A0A0A] font-black uppercase text-[11px] py-6 rounded-2xl hover:bg-[#FB8500] transition-all duration-500 tracking-[0.4em]">
            Authorize Access
          </button>
        </form>
        
        <div class="mt-8 flex items-center justify-between text-[8px] font-mono uppercase tracking-[0.3em] text-white/20">
            <span>Protocol: SMTP/SSL</span>
            <span>Verified: 2026.AR</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  section {
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  
  /* Remove default browser styles for focused inputs */
  input:focus {
    box-shadow: 0 0 20px rgba(251, 133, 0, 0.1);
  }
</style>