---
import { Image } from 'astro:assets';
const { post } = Astro.props;
---

<section class="relative w-full min-h-[85vh] flex items-center overflow-hidden bg-[#0A0A0A]">
  
  <div class="absolute inset-0 z-0">
    <Image 
      src={post.img} 
      alt={post.title} 
      class="w-full h-full object-cover saturate-[0.3] opacity-60"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#0A0A0A] via-[#0A0A0A]/80 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0A] via-transparent to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 w-full py-24">
    <div class="max-w-4xl">
      
      <div class="flex items-center gap-4 mb-10 animate-fade-in">
        <div class="px-4 py-1.5 rounded-full border border-white/20 bg-white/5 backdrop-blur-md">
          <span class="text-[10px] font-black text-[#FB8500] uppercase tracking-[0.4em]">
            Dossier_Log // 0{post.id}
          </span>
        </div>
        <div class="h-px w-12 bg-white/20"></div>
        <span class="text-[10px] font-bold text-white/40 uppercase tracking-[0.3em]">
          {post.category}
        </span>
      </div>

      <h1 class="text-6xl md:text-[120px] font-black text-white uppercase tracking-tighter leading-[0.8] mb-12 drop-shadow-2xl">
        {post.title}
      </h1>

      <p class="text-xl md:text-2xl text-white/60 font-medium leading-relaxed max-w-2xl mb-16 border-l-2 border-[#FB8500] pl-8">
        A technical inquiry into high-load structural systems. Verified intelligence for <span class="text-white">Node_Archive_2026</span> protocols.
      </p>

      <div class="flex flex-wrap gap-12 pt-12 border-t border-white/10">
        <div class="space-y-2">
          <p class="text-[9px] font-bold text-white/30 uppercase tracking-widest">Archive_Ref</p>
          <p class="text-xs font-black text-white uppercase tracking-tight italic">EV-001-{post.id}</p>
        </div>
        <div class="space-y-2">
          <p class="text-[9px] font-bold text-white/30 uppercase tracking-widest">Security_Protocol</p>
          <p class="text-xs font-black text-white uppercase tracking-tight">Standard_Access</p>
        </div>
        <div class="flex items-center gap-3 bg-white/5 px-6 py-3 rounded-2xl border border-white/5">
            <div class="w-1.5 h-1.5 rounded-full bg-[#FB8500] animate-pulse"></div>
            <span class="text-[10px] font-black text-white uppercase tracking-widest">Live_Verification_Active</span>
        </div>
      </div>

    </div>
  </div>

  <div class="hidden lg:block absolute right-12 top-1/2 -rotate-90 origin-right pointer-events-none">
    <span class="text-[10px] font-mono text-white/10 uppercase tracking-[1em] whitespace-nowrap">
      ENGINEERING_UNIT_DATA_RECOVERY
    </span>
  </div>
</section>

<style>
  section {
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  h1 {
    text-wrap: balance;
    animation: slideUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .animate-fade-in {
    opacity: 0;
    animation: fadeIn 1s ease-out 0.3s forwards;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>