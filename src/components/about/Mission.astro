---
// Mission.astro - Viewport Triggered Trust Section
---

<section class="relative w-full min-h-screen bg-[#050505] text-white overflow-hidden flex items-center font-sans">
  
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute right-[-10%] top-1/2 -translate-y-1/2 w-[50%] h-[70%] bg-orange-600/[0.08] blur-[120px] rounded-full"></div>
    <div class="absolute left-1/2 top-0 w-[1px] h-full bg-white/5 hidden lg:block"></div>
  </div>

  <div class="relative z-10 w-full max-w-[1440px] mx-auto px-6 md:px-12 flex flex-col lg:flex-row items-center gap-16 lg:gap-0">
    
    <div class="w-full lg:w-1/2 lg:pr-20 py-12 reveal-left">
      <div class="space-y-8">
        <div class="flex items-center gap-3">
          <div class="w-10 h-[1px] bg-orange-500/50"></div>
          <span class="text-orange-500 font-mono text-[10px] uppercase tracking-[0.4em]">Mission Manifesto</span>
        </div>
        
        <h2 class="text-5xl md:text-7xl font-black leading-[0.85] tracking-tighter uppercase">
          The <br/> <span class="text-white/20 outline-text">Philosophy.</span>
        </h2>
        
        <p class="text-gray-300 text-lg md:text-xl leading-relaxed max-w-md font-light">
          Behind every successful interface is a <span class="text-white font-medium">rigorous protocol</span> of engineering and human-centric trust.
        </p>

      </div>
    </div>

    <div class="w-full lg:w-1/2 lg:pl-10 py-12 space-y-6">
      
      <div class="trust-card group relative p-8 bg-white/[0.02] border border-white/5 hover:border-orange-500/40 transition-all duration-500">
        <div class="absolute -left-4 top-1/2 -translate-y-1/2 text-6xl font-black text-white/[0.03] group-hover:text-orange-500/10 transition-colors pointer-events-none font-mono">01</div>
        <div class="relative z-10 flex gap-6">
          <div class="w-1 h-12 bg-orange-500 shadow-[0_0_15px_#f97316]"></div>
          <div class="space-y-2">
            <h3 class="text-2xl font-black uppercase tracking-tight text-white/90 group-hover:text-orange-500 transition-colors">Uncompromising Precision</h3>
            <p class="text-gray-400 text-sm leading-relaxed max-w-sm">Every line of code is audited for performance. We calibrate for psychological impact.</p>
          </div>
        </div>
      </div>

      <div class="trust-card group relative p-8 bg-white/[0.02] border border-white/5 hover:border-orange-500/40 transition-all duration-500">
        <div class="absolute -left-4 top-1/2 -translate-y-1/2 text-6xl font-black text-white/[0.03] group-hover:text-orange-500/10 transition-colors pointer-events-none font-mono">02</div>
        <div class="relative z-10 flex gap-6">
          <div class="w-1 h-12 bg-orange-500 shadow-[0_0_15px_#f97316]"></div>
          <div class="space-y-2">
            <h3 class="text-2xl font-black uppercase tracking-tight text-white/90 group-hover:text-orange-500 transition-colors">Kinetic Energy</h3>
            <p class="text-gray-400 text-sm leading-relaxed max-w-sm">Movement that feels natural. We use motion to guide intuition and build instant trust.</p>
          </div>
        </div>
      </div>

      <div class="trust-card group relative p-8 bg-white/[0.02] border border-white/5 hover:border-orange-500/40 transition-all duration-500">
        <div class="absolute -left-4 top-1/2 -translate-y-1/2 text-6xl font-black text-white/[0.03] group-hover:text-orange-500/10 transition-colors pointer-events-none font-mono">03</div>
        <div class="relative z-10 flex gap-6">
          <div class="w-1 h-12 bg-orange-500 shadow-[0_0_15px_#f97316]"></div>
          <div class="space-y-2">
            <h3 class="text-2xl font-black uppercase tracking-tight text-white/90 group-hover:text-orange-500 transition-colors">Visual Legacy</h3>
            <p class="text-gray-400 text-sm leading-relaxed max-w-sm">We build icons, not trends. Engineered to remain recognizable for decades.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Outlined text for cleaner "Philosophy" look */
  .outline-text {
    -webkit-text-stroke: 1px rgba(255,255,255,0.2);
    color: transparent;
  }

  /* Reveal States */
  .reveal-left, .trust-card {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-left.active {
    opacity: 1;
    transform: translateY(0);
  }

  .trust-card.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Individual card delay logic via JS or manual classes */
</style>

<script>
  const observerOptions = { threshold: 0.2 };
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
        
        // If it's the right side container, stagger the children
        if (entry.target.classList.contains('space-y-6')) {
            const cards = entry.target.querySelectorAll('.trust-card');
            cards.forEach((card, i) => {
                setTimeout(() => card.classList.add('active'), i * 200);
            });
        }
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal-left, .space-y-6').forEach(el => observer.observe(el));
</script>