---
// Values.astro - Ultra-Glassy Static 3D
const coreValues = [
  {
    id: "01",
    label: "Architecture",
    title: "Structural Integrity",
    description: "We eliminate technical debt before it starts. Our systems are documented, type-safe, and engineered for extreme longevity.",
    tag: "Safety_Checked",
    zDepth: "group-hover:translate-z-20"
  },
  {
    id: "02",
    label: "Transparency",
    title: "Absolute Visibility",
    description: "Radical honesty is our default. We provide unfiltered technical access, ensuring zero ambiguity in project trajectory.",
    tag: "Status_Live",
    zDepth: "group-hover:translate-z-32" 
  },
  {
    id: "03",
    label: "Efficiency",
    title: "High Velocity",
    description: "Speed is a primary feature. We leverage edge-computing to ensure sub-second global interaction times.",
    tag: "Edge_Optimized",
    zDepth: "group-hover:translate-z-20"
  }
];
---

<section class="relative w-full py-16 bg-[#FFFFFF] text-slate-900 font-sans overflow-hidden">
  
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-orange-100 rounded-full blur-[120px] opacity-60"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-blue-50 rounded-full blur-[100px] opacity-60"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <div class="mb-24 flex flex-col items-center text-center space-y-4">

      <h2 class="text-6xl md:text-8xl font-black tracking-tighter uppercase leading-[0.8] text-slate-950">
        System <span class="text-orange-600">Ethics.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      {coreValues.map((item) => (
        <div class="group relative perspective-1000 h-full">
          
          <div class={`relative h-full bg-white/20 backdrop-blur-3xl border border-white/60 rounded-[2.5rem] p-10 transition-all duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] transform-gpu group-hover:rotate-x-12 group-hover:rotate-y-[-12deg] ${item.zDepth} shadow-[0_8px_32px_0_rgba(31,38,135,0.07)] group-hover:shadow-[20px_40px_80px_rgba(0,0,0,0.08)] overflow-hidden flex flex-col`}>
            
            <div class="absolute inset-0 border-[1px] border-white/80 rounded-[2.5rem] pointer-events-none"></div>

            <div class="relative z-10">
              <div class="flex justify-between items-start mb-10">
                <span class="text-xs font-mono font-black text-orange-600 tracking-[0.3em] uppercase">Ref_{item.id}</span>
                <span class="text-5xl font-black text-black/5 group-hover:text-orange-200 transition-colors duration-500 select-none">{item.id}</span>
              </div>
              
              <h3 class="text-4xl font-black uppercase tracking-tighter text-slate-950 mb-6 leading-[0.9]">
                {item.title.split(' ').map((word, i) => (
                  <span class={i === 1 ? "text-orange-600" : ""}>{word}<br/></span>
                ))}
              </h3>
              
              <p class="text-slate-500 leading-relaxed mb-10 text-sm font-medium">
                {item.description}
              </p>
            </div>

            <div class="mt-auto relative z-20 transition-transform duration-700 transform-gpu group-hover:translate-z-10">
              <div class="inline-block py-2 px-5 rounded-xl bg-white/40 border border-white/80 shadow-sm transition-all group-hover:bg-[#ea580c] group-hover:text-white group-hover:border-[#ea580c]">
                  <span class="text-[10px] font-mono font-bold uppercase tracking-widest">{item.tag}</span>
              </div>
            </div>

            <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/60 to-transparent opacity-0 group-hover:opacity-100 translate-x-[-150%] group-hover:translate-x-[150%] transition-all duration-1000 ease-in-out"></div>
          </div>
          
          <div class="absolute -inset-2 bg-black/5 blur-2xl rounded-[3rem] opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none -z-10"></div>
        </div>
      ))}
    </div>
  </div>

<div class="mt-32 relative flex flex-col items-center justify-center py-20 px-6 overflow-hidden rounded-[3rem] border border-slate-200 bg-slate-50/50">
  
  <div class="absolute inset-0 [background-image:linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] [background-size:40px_40px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>

  <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-orange-500/50 to-transparent animate-scan"></div>

  <div class="relative z-10 text-center max-w-2xl">
 

    <h3 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-slate-950 mb-6 leading-none">
      Build with <span class="text-orange-600">Absolute Intent.</span>
    </h3>
    
    <p class="text-slate-500 font-medium text-sm md:text-base leading-relaxed mb-12 max-w-lg mx-auto">
      Transcend the digital void. We engineer high-velocity systems that define your visual legacy.
    </p>

    <div class="relative group p-[1px] rounded-full overflow-hidden bg-gradient-to-r from-slate-300 via-orange-500/50 to-slate-300 inline-block">
        <div class="absolute -inset-1 bg-orange-500/10 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <a href="/contact" class="relative flex items-center gap-6 px-4 py-3 bg-white rounded-full hover:bg-slate-50 transition-all duration-300">
            <div class="w-12 h-12 rounded-full bg-[#FB8500] flex items-center justify-center text-white shadow-[0_0_20px_rgba(251,133,0,0.4)] group-hover:rotate-[360deg] transition-transform duration-700">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
            </div>
            
            <div class="pr-8 text-left">
                <p class="text-[9px] font-black tracking-[.3em] text-orange-600 uppercase mb-0.5">Initialize</p>
                <span class="text-slate-950 font-bold text-lg tracking-tight block">Start Journey</span>
            </div>
        </a>
    </div>
  </div>

  <div class="absolute top-4 left-4 w-4 h-4 border-t-2 border-l-2 border-slate-200"></div>
  <div class="absolute bottom-4 right-4 w-4 h-4 border-b-2 border-r-2 border-slate-200"></div>
</div>


</section>




<style>
  .perspective-1000 { 
    perspective: 1500px; 
  }
  
  .transform-gpu { 
    transform-style: preserve-3d; 
    will-change: transform;
  }

  /* Z-Depth layers for spatial feeling */
  .translate-z-20 { transform: translateZ(30px); }
  .translate-z-32 { transform: translateZ(60px); }
</style>