---
// TechStack.astro High-End Orange Columnar Stack
---

<section class="relative w-full py-24 bg-[#FCFCFC] text-slate-900 font-sans overflow-hidden border-t border-gray-100">
  
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="text-center mb-24 space-y-4">
      <h2 class="text-5xl md:text-8xl font-black tracking-tighter text-slate-900 uppercase">
        The <span class="text-orange-600">Technical</span> Stack
      </h2>
      <div class="w-24 h-1 bg-orange-600 mx-auto"></div>
      <p class="text-slate-500 max-w-xl mx-auto font-medium pt-4">
        A high-performance ecosystem engineered for precision and psychological impact.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      
      <div class="flex flex-col items-center">
        <div class="mb-8 text-center">
          <div class="w-16 h-16 bg-orange-600 rounded-2xl flex items-center justify-center shadow-xl shadow-orange-200 mb-4 mx-auto ">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-black uppercase tracking-widest text-sm text-slate-800">Front End</h3>
        </div>

        <div class="w-full bg-white border border-slate-100 rounded-[2.5rem] p-10 shadow-xl shadow-slate-200/50 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-1.5 h-full bg-orange-600"></div>
          <div class="grid grid-cols-2 gap-y-10 gap-x-6">
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/react-2.svg" class="h-10 w-10 object-contain" alt="React" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">React</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/html-1.svg" class="h-10 w-10 object-contain" alt="HTML" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">HTML5</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/astro-1.svg" class="h-10 w-10 object-contain" alt="Astro" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Astro</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/tailwind-css-2.svg" class="h-10 w-10 object-contain" alt="Tailwind" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Tailwind</span>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col items-center">
        <div class="mb-8 text-center">
          <div class="w-16 h-16 bg-orange-600 rounded-2xl flex items-center justify-center shadow-xl shadow-orange-200 mb-4 mx-auto ">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="font-black uppercase tracking-widest text-sm text-slate-800">Back End</h3>
        </div>

        <div class="w-full bg-white border border-slate-100 rounded-[2.5rem] p-10 shadow-xl shadow-slate-200/50 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-1.5 h-full bg-orange-600"></div>
          <div class="grid grid-cols-2 gap-y-10 gap-x-6">
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/nodejs-icon.svg" class="h-10 w-10 object-contain" alt="Node" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Node.js</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/typescript.svg" class="h-10 w-10 object-contain" alt="TS" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">TS</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/python-5.svg" class="h-10 w-10 object-contain" alt="Python" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Python</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/go-6.svg" class="h-10 w-10 object-contain" alt="Go" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Golang</span>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col items-center">
        <div class="mb-8 text-center">
          <div class="w-16 h-16 bg-orange-600 rounded-2xl flex items-center justify-center shadow-xl shadow-orange-200 mb-4 mx-auto ">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
            </svg>
          </div>
          <h3 class="font-black uppercase tracking-widest text-sm text-slate-800">Database</h3>
        </div>

        <div class="w-full bg-white border border-slate-100 rounded-[2.5rem] p-10 shadow-xl shadow-slate-200/50 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-1.5 h-full bg-orange-600"></div>
          <div class="grid grid-cols-2 gap-y-10 gap-x-6">
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/postgresql.svg" class="h-10 w-10 object-contain" alt="Postgres" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Postgres</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/mongodb-icon-1.svg" class="h-10 w-10 object-contain" alt="Mongo" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Mongo</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/redis.svg" class="h-10 w-10 object-contain" alt="Redis" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Redis</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/mysql-6.svg" class="h-10 w-10 object-contain" alt="MySQL" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">MySQL</span>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col items-center">
        <div class="mb-8 text-center">
          <div class="w-16 h-16 bg-orange-600 rounded-2xl flex items-center justify-center shadow-xl shadow-orange-200 mb-4 mx-auto ">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="font-black uppercase tracking-widest text-sm text-slate-800">Server</h3>
        </div>

        <div class="w-full bg-white border border-slate-100 rounded-[2.5rem] p-10 shadow-xl shadow-slate-200/50 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-1.5 h-full bg-orange-600"></div>
          <div class="grid grid-cols-2 gap-y-10 gap-x-6">
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/vercel.svg" class="h-10 w-10 object-contain" alt="Vercel" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Vercel</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/aws-2.svg" class="h-10 w-10 object-contain" alt="AWS" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">AWS</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/nginx-1.svg" class="h-10 w-10 object-contain" alt="Nginx" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Nginx</span>
            </div>
            <div class="flex flex-col items-center gap-3">
                <img src="https://cdn.worldvectorlogo.com/logos/docker.svg" class="h-10 w-10 object-contain" alt="Docker" />
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Docker</span>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>