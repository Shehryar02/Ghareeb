---
// A high-impact, split-screen hero section for the About page
---

<section class="relative w-full min-h-screen bg-white flex flex-col lg:flex-row overflow-hidden font-sans">
  
  <div class="w-full lg:w-1/2 flex items-center justify-center p-6 md:p-16 z-20 mt-16 lg:mt-0">
    <div class="max-w-xl">
      <div class="flex items-center gap-4 mb-8 md:mb-10 group">
        <div class="w-12 h-[2px] bg-black group-hover:w-20 group-hover:bg-orange-500 transition-all duration-500"></div>
        <span class="text-xs font-bold tracking-[0.4em] uppercase text-gray-400">Identity Protocol</span>
      </div>

      <h1 class="text-5xl md:text-8xl font-black text-black leading-[0.9] tracking-tighter mb-6 md:mb-8">
        WE ARE <br/> <span class="text-orange-500">THE CORE.</span>
      </h1>

      <p class="text-gray-600 text-base md:text-xl leading-relaxed mb-8 md:mb-10 font-light">
        Our mission is to bridge the gap between human intuition and digital precision. Through the lens of <strong>G</strong>, we explore the intersection of stark minimalism and radiant energy.
      </p>

      <button class="relative overflow-hidden px-10 py-4 bg-black text-white text-xs font-bold uppercase tracking-widest hover:text-orange-500 transition-colors duration-300">
        <span class="relative z-10">Discover Our Process</span>
        <div class="absolute inset-0 bg-white translate-y-full hover:translate-y-0 transition-transform duration-300"></div>
      </button>
    </div>
  </div>

  <div class="w-full lg:w-1/2 relative flex items-center justify-center min-h-[50vh] lg:min-h-screen bg-gray-50/50">
    
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 50px 50px;"></div>

    <div class="relative w-64 h-64 sm:w-72 sm:h-72 md:w-96 md:h-96 group">
      
      <div class="absolute inset-[-20%] bg-orange-500/20 blur-[80px] rounded-full animate-pulse-slow"></div>

      <div class="absolute inset-0 bg-black rounded-full shadow-[0_50px_100px_rgba(0,0,0,0.4)] border-[1px] border-white/10 overflow-hidden">
        
        <div class="absolute top-[-50%] left-[-50%] w-[200%] h-[200%] bg-gradient-to-br from-white/10 via-transparent to-transparent rotate-12"></div>
        
        <div class="absolute inset-0 border-[12px] border-orange-600/30 rounded-full animate-spin-slow"></div>
        <div class="absolute inset-[4px] border-[2px] border-orange-500 shadow-[0_0_15px_#f97316] rounded-full"></div>
      </div>

      <div class="absolute inset-0 flex items-center justify-center">
        <span class="text-[10rem] sm:text-[12rem] md:text-[16rem] font-black text-white drop-shadow-[0_10px_10px_rgba(0,0,0,0.5)] select-none animate-float">
          G
        </span>
      </div>

      <div class="absolute top-10 right-10 w-3 h-3 bg-orange-500 rounded-full shadow-[0_0_10px_#f97316] animate-bounce"></div>
      <div class="absolute bottom-20 left-0 w-1 h-12 bg-black opacity-20"></div>
    </div>
  </div>

</section>

<style>
  /* Custom Animations for "Realistic" Depth */
  
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.1); }
  }

  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-15px) scale(1.02); }
  }

  .animate-pulse-slow {
    animation: pulse-slow 6s ease-in-out infinite;
  }

  .animate-spin-slow {
    animation: spin-slow 20s linear infinite;
  }

  .animate-float {
    animation: float 5s ease-in-out infinite;
  }

  /* Smooth reveal for text */
  h1 {
    animation: slideRight 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes slideRight {
    from { opacity: 0; transform: translateX(-50px); }
    to { opacity: 1; transform: translateX(0); }
  }
</style>