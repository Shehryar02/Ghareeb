---
// Journey.astro - The Human Protocol
---

<section class="relative w-full py-16 md:py-32 bg-[#050505] text-white overflow-hidden font-sans">
  
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60%] h-[60%] bg-orange-900/10 blur-[180px] rounded-full"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-6">
    
    <div class="text-center mb-16 md:mb-32 space-y-4 md:space-y-6">
      <h2 class="text-sm font-mono text-orange-500 uppercase tracking-[0.5em] reveal-text">Our_Lineage</h2>
      <h3 class="text-4xl sm:text-5xl md:text-8xl font-black tracking-tighter uppercase leading-none">
        Logic Meets <br/> <span class="text-orange-500">Empathy.</span>
      </h3>
      <p class="text-gray-400 max-w-xl mx-auto text-base md:text-lg font-light leading-relaxed">
        We didn't choose this path because it was easy. We chose it because digital precision without human soul is just noise.
      </p>
    </div>

    <div class="relative">
      <div class="absolute left-0 md:left-1/2 top-0 w-[1px] h-full bg-gradient-to-b from-orange-500/50 via-white/10 to-transparent -translate-x-1/2"></div>

      <div class="space-y-16 md:space-y-24">
        
        <div class="relative flex flex-col md:flex-row items-center justify-between journey-item pl-8 md:pl-0">
          <div class="w-full md:w-[45%] mb-2 md:mb-0 text-left md:text-right">
            <span class="text-orange-500 font-mono text-xs">The Genesis</span>
            <h4 class="text-xl md:text-2xl font-bold uppercase mt-2">The Digital Void</h4>
            <p class="text-gray-500 mt-3 md:mt-4 text-sm leading-relaxed">
              We noticed a world of cold, "perfect" websites that felt dead. Our journey began with a single question: <span class="text-white italic">"Where is the heartbeat?"</span>
            </p>
          </div>
          <div class="absolute left-0 md:left-1/2 -translate-x-1/2 w-3 h-3 bg-orange-500 rounded-full shadow-[0_0_15px_#f97316] z-20 mt-1 md:mt-0"></div>
          <div class="hidden md:block w-full md:w-[45%]"></div>
        </div>

        <div class="relative flex flex-col md:flex-row items-center justify-between journey-item pl-8 md:pl-0">
          <div class="hidden md:block w-full md:w-[45%] order-2 md:order-1"></div>
          <div class="absolute left-0 md:left-1/2 -translate-x-1/2 w-3 h-3 bg-white rounded-full z-20 mt-1 md:mt-0"></div>
          <div class="w-full md:w-[45%] order-1 md:order-2 mb-2 md:mb-0 text-left">
            <span class="text-orange-500 font-mono text-xs">The Breakthrough</span>
            <h4 class="text-xl md:text-2xl font-bold uppercase mt-2">Human Centered Code</h4>
            <p class="text-gray-500 mt-3 md:mt-4 text-sm leading-relaxed">
              We developed the <strong class="text-white">G-Protocol</strong>. Not as a set of rules, but as a bridge. We chose minimalism to give your story space to breathe, and orange to give it the energy it deserves.
            </p>
          </div>
        </div>

        <div class="relative flex flex-col md:flex-row items-center justify-between journey-item pl-8 md:pl-0">
          <div class="w-full md:w-[45%] mb-2 md:mb-0 text-left md:text-right">
            <span class="text-orange-500 font-mono text-xs">The Masterpiece</span>
            <h4 class="text-xl md:text-2xl font-bold uppercase mt-2">Meaningful Impact</h4>
            <p class="text-gray-500 mt-3 md:mt-4 text-sm leading-relaxed">
              Every project we take on is a partnership. We don't just "build" for clients; we co-author their visual legacy. Our uniqueness lies in our <span class="text-white">obsession with your "Why."</span>
            </p>
          </div>
          <div class="absolute left-0 md:left-1/2 -translate-x-1/2 w-3 h-3 bg-orange-500 rounded-full shadow-[0_0_15px_#f97316] z-20 mt-1 md:mt-0"></div>
          <div class="hidden md:block w-full md:w-[45%]"></div>
        </div>

      </div>
    </div>

    <div class="mt-20 md:mt-40 p-6 md:p-12 bg-white/[0.02] border border-white/5 backdrop-blur-sm text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-orange-500/50 to-transparent"></div>
        <h4 class="text-xl md:text-2xl font-bold mb-4 md:mb-6 italic">"Technology is just the tool. The connection is the art."</h4>
        <p class="text-gray-400 mb-8 max-w-lg mx-auto text-sm">
            Our journey isn't finished. It starts again with every project we initialize.
        </p>
<div class="relative group p-[1px] rounded-full overflow-hidden bg-gradient-to-r from-white/10 via-[#FB8500]/50 to-white/10 inline-block">
    <!-- Outer Glow Effect on Hover -->
    <div class="absolute -inset-1 bg-[#FB8500]/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    
    <a href="/contact" class="relative flex items-center gap-4 md:gap-6 px-3 md:px-4 py-2 md:py-3 bg-[#0a0a0a] rounded-full hover:bg-black transition-all duration-300">
        <!-- Rotating Icon Circle -->
        <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-[#FB8500] flex items-center justify-center text-black shadow-[0_0_15px_rgba(251,133,0,0.4)] group-hover:rotate-[360deg] transition-transform duration-700">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="md:w-[22px] md:h-[22px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
        </div>
        
        <!-- Text Content -->
        <div class="pr-6 md:pr-8 text-left">
            <p class="text-[8px] md:text-[9px] font-black tracking-[.3em] text-[#FB8500] uppercase mb-0.5">The Heartbeat</p>
            <span class="text-white font-bold text-base md:text-lg tracking-tight block">Join Our Story</span>
        </div>
    </a>
</div>
    </div>

  </div>
</section>

<style>
  .journey-item {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .journey-item.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Text balance for professional headers */
  h3 {
    text-wrap: balance;
  }
</style>

<script>
  const journeyObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.journey-item').forEach(el => journeyObserver.observe(el));

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.journey-item').forEach(el => journeyObserver.observe(el));
  });
</script>