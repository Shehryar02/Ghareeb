---
const centerLinks = [
  { name: 'Home', href: '/', transform: 'rotateY(25deg) translateZ(-50px) scale(0.9)', opacity: 'opacity-50' },
  { name: 'About', href: '/about', transform: 'rotateY(10deg) translateZ(0px) scale(0.95)', opacity: 'opacity-70' },
  { name: 'Services', dropdown: true, transform: 'rotateY(-10deg) translateZ(-70px) scale(1.3)', opacity: 'opacity-100' },
  { name: 'Portfolio', href: '/portfolio', transform: 'rotateY(-25deg) translateZ(-50px) scale(0.9)', opacity: 'opacity-70' },
];

const moreLinks = [
  { name: 'Process', href: '/process' },
  { name: 'Blogs', href: '/blogs' },
  { name: 'FAQs', href: '/faqs' },
];

const serviceLinks = [
  { name: 'All Services', href: '/services' },
  { name: 'Business Websites', href: '/services/business-websites' },
  { name: 'E-Commerce Stores', href: '/services/ecommerce-stores' },
  { name: 'Custom Web Apps', href: '/services/custom-web-apps' },
  { name: 'Landing Pages', href: '/services/landing-pages' },
  { name: 'Frontend Development', href: '/services/frontend-development' },
  { name: 'Backend Development', href: '/services/backend-development' },
  { name: 'Maintenance & Support', href: '/services/maintenance-support' },
  { name: 'Speed Optimization', href: '/services/speed-optimization' },
  { name: 'CMS Development', href: '/services/cms-development' },
  { name: 'Deployment & Hosting', href: '/services/deployment-hosting' },
];
---

<header class="sticky top-0 z-50 w-full bg-primary border-b border-secondary/30 px-4 md:px-10 py-4 md:py-5 antialiased">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    
    <!-- LOGO -->
    <div class="flex-1 flex justify-start z-50">
      <a href="/" class="group">
        <span class="text-white font-serif italic text-xl md:text-2xl tracking-wider transition-all duration-500 group-hover:text-cta">
          Ghareeb<span class="text-cta not-italic font-bold">.</span>
        </span>
      </a>
    </div>

    <!-- DESKTOP NAVIGATION -->
    <nav class="hidden lg:flex flex-2 justify-center perspective-distant">
      <ul class="flex items-center space-x-4">
        {centerLinks.map((item) => (
          <li
            style={{ transform: item.transform, transformStyle: 'preserve-3d' }}
            class={`relative group transition-all duration-300 ${item.opacity} hover:opacity-100 hover:scale-110! hover:rotate-0!`}
          >
            {item.dropdown ? (
              <>
                <!-- SERVICES BUTTON -->
                <button class="text-white font-sans text-[12px] font-medium uppercase tracking-[0.35em] flex items-center gap-2 cursor-default py-2 px-4">
                  {item.name}
                  <svg class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>

                <!-- DROPDOWN LIST - HORIZONTAL ROW -->
                <div class="absolute top-full left-1/2 -translate-x-1/2 pt-6 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 z-50">
                  <div class="bg-primary border border-secondary py-4 px-6 shadow-2xl min-w-max">
                    <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-2">
                      {serviceLinks.map((s) => (
                        <a
                          href={s.href}
                          class="block px-4 py-2 text-neutral/60 font-sans text-[10px] xl:text-[11px] uppercase tracking-widest hover:bg-cta hover:text-primary transition-all whitespace-nowrap text-center"
                        >
                          {s.name}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              </>
            ) : (
              <!-- NORMAL NAV LINK -->
              <a
                href={item.href}
                class="block text-white font-sans text-[12px] font-medium uppercase tracking-[0.35em] py-2 px-4 group"
              >
                {item.name}
                <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-0 h-px bg-cta transition-all duration-500 group-hover:w-full"></span>
              </a>
            )}
          </li>
        ))}

        <!-- MORE DROPDOWN -->
        <li style="transform: rotateY(-35deg) translateZ(-70px) scale(1.0);" class="opacity-30 hover:opacity-100 transition-all duration-700 hover:rotate-0 hover:scale-110">
          <div class="relative group">
            <button class="text-white font-sans text-[12px] font-medium uppercase tracking-[0.2em] flex items-center gap-2 cursor-default py-2 px-4">
              More
              <svg class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-6 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500">
              <ul class="bg-primary border border-secondary min-w-40 py-2 shadow-2xl">
                {moreLinks.map((m) => (
                  <li>
                    <a href={m.href} class="block px-6 py-3 text-neutral/60 font-sans text-[11px] uppercase tracking-widest hover:bg-cta hover:text-primary transition-all">
                      {m.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </li>
      </ul>
    </nav>

    <!-- CONTACT BUTTON -->
    <div class="flex-1 flex justify-end z-50">
      <a
        href="/contact"
        class="group border border-cta rounded-md relative overflow-hidden px-4 md:px-6 py-1.5 text-sm md:text-[18px] font-sans font-bold uppercase tracking-[0.2em] transition-all duration-500"
      >
        <span class="absolute inset-0 bg-cta -translate-x-full transition-transform duration-500 ease-in-out group-hover:translate-x-0"></span>
        <span class="relative z-10 group-hover:text-primary transition-colors duration-500">Contact</span>
      </a>
    </div>

    <!-- MOBILE MENU BUTTON -->
    <button 
      id="mobile-menu-button"
      class="lg:hidden ml-4 p-2 text-white hover:text-cta transition-colors z-50"
      aria-label="Toggle menu"
    >
      <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- MOBILE MENU -->
  <div 
    id="mobile-menu"
    class="lg:hidden fixed inset-0 bg-primary/95 backdrop-blur-md z-40 transform translate-x-full transition-transform duration-300 ease-in-out pt-20"
  >
    <div class="px-6 py-8 space-y-6 overflow-y-auto h-full">
      <!-- Mobile Navigation Links -->
      <nav class="space-y-4">
        {centerLinks.map((item) => (
          <div>
            {item.dropdown ? (
              <div class="mobile-dropdown">
                <button 
                  class="mobile-dropdown-toggle w-full flex items-center justify-between text-white font-sans text-base font-medium uppercase tracking-wider py-3 border-b border-white/10"
                >
                  {item.name}
                  <svg class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div class="mobile-dropdown-content hidden mt-2 space-y-2 pl-4">
                  {serviceLinks.map((s) => (
                    <a
                      href={s.href}
                      class="block text-neutral/60 font-sans text-sm uppercase tracking-widest py-2 hover:text-cta transition-colors"
                    >
                      {s.name}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class="block text-white font-sans text-base font-medium uppercase tracking-wider py-3 border-b border-white/10 hover:text-cta transition-colors"
              >
                {item.name}
              </a>
            )}
          </div>
        ))}

        <!-- More Links -->
        <div class="mobile-dropdown">
          <button 
            class="mobile-dropdown-toggle w-full flex items-center justify-between text-white font-sans text-base font-medium uppercase tracking-wider py-3 border-b border-white/10"
          >
            More
            <svg class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="mobile-dropdown-content hidden mt-2 space-y-2 pl-4">
            {moreLinks.map((m) => (
              <a
                href={m.href}
                class="block text-neutral/60 font-sans text-sm uppercase tracking-widest py-2 hover:text-cta transition-colors"
              >
                {m.name}
              </a>
            ))}
          </div>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  function setupMobileMenu() {
    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    const dropdownToggles = document.querySelectorAll('.mobile-dropdown-toggle');

    if (!menuButton || !mobileMenu) return;

    // Toggle mobile menu
    menuButton.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('translate-x-full');
      
      if (isOpen) {
        mobileMenu.classList.add('translate-x-full');
        menuIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        document.body.style.overflow = '';
      } else {
        mobileMenu.classList.remove('translate-x-full');
        menuIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    });

    // Handle dropdown toggles
    dropdownToggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const content = toggle.nextElementSibling;
        const icon = toggle.querySelector('svg');
        
        if (content) {
          content.classList.toggle('hidden');
          icon.classList.toggle('rotate-180');
        }
      });
    });

    // Close menu when clicking outside
    mobileMenu.addEventListener('click', (e) => {
      if (e.target === mobileMenu) {
        mobileMenu.classList.add('translate-x-full');
        menuIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        document.body.style.overflow = '';
      }
    });

    // Close menu when clicking a link
    const mobileLinks = mobileMenu.querySelectorAll('a');
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('translate-x-full');
        menuIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        document.body.style.overflow = '';
      });
    });
  }

  // Initialize on load and after Astro navigation
  setupMobileMenu();
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>

<style>
  /* Ensure dropdown stays on top */
  .group:hover .absolute {
    z-index: 50;
  }

  /* Smooth transitions for mobile menu */
  #mobile-menu {
    will-change: transform;
  }

  /* Mobile dropdown animations */
  .mobile-dropdown-content {
    transition: all 0.3s ease-in-out;
  }
</style>
