---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Services', href: '/services', dropdown: true },
  { name: 'Portfolio', href: '/portfolio' },
  { name: 'Process', href: '/process' },
  { name: 'Blogs', href: '/blogs' },
  { name: 'FAQs', href: '/faqs' },
];

const serviceLinks = [
  { name: 'All Services', href: '/services', desc: 'Full service overview' },
  { name: 'Business Websites', href: '/services/business-websites', desc: 'Corporate & brand sites' },
  { name: 'E-Commerce Stores', href: '/services/ecommerce-stores', desc: 'Shopify & custom stores' },
  { name: 'Custom Web Apps', href: '/services/custom-web-apps', desc: 'SaaS & enterprise apps' },
  { name: 'Landing Pages', href: '/services/landing-pages', desc: 'High-conversion pages' },
  { name: 'Frontend Development', href: '/services/frontend-development', desc: 'React, Next.js, Vue' },
  { name: 'Backend Development', href: '/services/backend-development', desc: 'APIs & microservices' },
  { name: 'Maintenance & Support', href: '/services/maintenance-support', desc: 'Ongoing care plans' },
  { name: 'Speed Optimization', href: '/services/speed-optimization', desc: 'Core Web Vitals' },
  { name: 'CMS Development', href: '/services/cms-development', desc: 'WordPress & headless' },
  { name: 'Deployment & Hosting', href: '/services/deployment-hosting', desc: 'Cloud infrastructure' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-[70] w-full antialiased">
  <div class="header-backdrop absolute inset-0 bg-[#020D0A]/90 backdrop-blur-2xl border-b border-[#0A2F1F]/30 transition-all duration-500"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-5 md:px-10 lg:px-12">
    <div class="flex items-center justify-between h-[64px] md:h-[76px]">

      <a href="/" class="group flex items-center shrink-0">
        <span class="font-heading text-[22px] md:text-[26px] font-bold text-white tracking-tight transition-colors duration-300 group-hover:text-[#FB8500]">
          Kratecx
        </span>
        <span class="w-[6px] h-[6px] rounded-full bg-[#FB8500] ml-[2px] mb-[3px] self-end group-hover:scale-[1.6] transition-transform duration-300"></span>
      </a>

      <nav class="hidden lg:flex items-center">
        <ul class="flex items-center gap-1">
          {navLinks.map((item, idx) => (
            <li class={`relative ${item.dropdown ? 'group' : ''}`}>
              {item.dropdown ? (
                <>
                  <button class={`nav-link flex items-center gap-1.5 px-4 py-2.5 text-[16px] font-semibold tracking-wide transition-all duration-300 font-heading ${currentPath.startsWith('/services') ? 'text-[#FB8500]' : 'text-white/60 hover:text-white'}`}>
                    {item.name}
                    <svg class="w-3.5 h-3.5 opacity-40 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>

                  <div class="absolute top-full left-1/2 -translate-x-1/2 pt-5 invisible opacity-0 -translate-y-2 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 ease-out">
                    <div class="relative bg-[#020D0A]/96 backdrop-blur-3xl border border-[#0A2F1F]/40 rounded-2xl p-5 shadow-[0_40px_80px_-10px_rgba(0,0,0,0.9)] min-w-[580px] overflow-hidden">
                      <div class="absolute inset-0 bg-[radial-gradient(#FB8500_1px,transparent_1px)] [background-size:24px_24px] opacity-[0.015]"></div>
                      <div class="absolute top-[-50%] right-[-50%] w-full h-full bg-[#FB8500]/[0.03] blur-[80px] rounded-full"></div>
                      
                      <div class="absolute -top-[6px] left-1/2 -translate-x-1/2 w-3 h-3 bg-[#020D0A] border-l border-t border-[#0A2F1F]/40 rotate-45"></div>

                      <div class="relative z-10">
                        <a href="/services" class="group/main flex items-center justify-between p-4 mb-4 rounded-xl bg-gradient-to-r from-[#FB8500]/10 to-transparent border border-[#FB8500]/20 hover:border-[#FB8500]/40 transition-all duration-300">
                          <div>
                            <span class="flex items-center gap-2 text-[14px] font-bold tracking-wide text-[#FB8500] font-heading">
                              <span class="w-1.5 h-1.5 rounded-full bg-[#FB8500] animate-pulse"></span>
                              All Services
                            </span>
                            <span class="block text-[12px] text-white/45 mt-1 font-medium">Explore our complete arsenal of digital capabilities</span>
                          </div>
                          <div class="w-9 h-9 rounded-full bg-[#020D0A] border border-[#FB8500]/30 flex items-center justify-center group-hover/main:bg-[#FB8500] transition-colors duration-300">
                            <svg class="w-4 h-4 text-[#FB8500] group-hover/main:text-[#020D0A] transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                            </svg>
                          </div>
                        </a>

                        <div class="grid grid-cols-2 gap-x-2 gap-y-0.5">
                          {serviceLinks.slice(1).map((s) => (
                            <a
                              href={s.href}
                              class="group/item flex items-start gap-3 p-3 rounded-lg transition-all duration-200 hover:bg-[#0A2F1F]/30 border-l-2 border-transparent hover:border-[#FB8500]"
                            >
                              <div class="mt-0.5">
                                <svg class="w-4 h-4 text-white/15 group-hover/item:text-[#FB8500] transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
                                </svg>
                              </div>
                              <div>
                                <span class="block text-[13px] font-semibold tracking-wide text-white/75 group-hover/item:text-white transition-colors font-heading mb-0.5">{s.name}</span>
                                <span class="block text-[11px] text-white/30 group-hover/item:text-white/50 transition-colors leading-relaxed">{s.desc}</span>
                              </div>
                            </a>
                          ))}
                        </div>
                      </div>
                    </div>
                  </div>
                </>
              ) : (
                <a
                  href={item.href}
                  class={`nav-link relative block px-4 py-2.5 text-[14px] font-light tracking-wide transition-all duration-300 font-heading ${currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? 'text-[#FB8500]' : 'text-white/60 hover:text-white'}`}
                >
                  {item.name}
                  {(currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))) && (
                    <span class="absolute bottom-0.5 left-4 right-4 h-[2px] bg-[#FB8500] rounded-full"></span>
                  )}
                </a>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <div class="flex items-center gap-4">
        <a
          href="/contact"
          class="group relative overflow-hidden bg-[#FB8500] text-[#020D0A] px-6 md:px-8 py-2.5 md:py-3 rounded-full text-[12px] md:text-[13px] font-bold tracking-wide transition-all duration-400 hover:shadow-[0_0_30px_rgba(251,133,0,0.3)] font-heading"
        >
          <span class="relative z-10 group-hover:text-[#020D0A] transition-colors duration-300">Let's Talk</span>
          <div class="absolute inset-0 bg-white -translate-y-full group-hover:translate-y-0 transition-transform duration-400 ease-out rounded-full"></div>
        </a>

        <button
          id="mobile-menu-button"
          class="lg:hidden relative w-10 h-10 flex items-center justify-center text-white hover:text-[#FB8500] transition-colors"
          aria-label="Toggle menu"
        >
          <div id="hamburger" class="w-5 h-3.5 relative">
            <span class="absolute top-0 left-0 w-full h-[1.5px] bg-current rounded-full transition-all duration-300 origin-center"></span>
            <span class="absolute top-1/2 -translate-y-1/2 left-0 w-full h-[1.5px] bg-current rounded-full transition-all duration-300 origin-center"></span>
            <span class="absolute bottom-0 left-0 w-full h-[1.5px] bg-current rounded-full transition-all duration-300 origin-center"></span>
          </div>
        </button>
      </div>
    </div>
  </div>


</header>

<div id="mobile-menu" class="lg:hidden fixed top-[64px] md:top-[76px] left-0 right-0 z-[60] pointer-events-none">
  <div id="mobile-overlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm" style="opacity: 0; transition: opacity 0.3s ease; pointer-events: none;"></div>

  <div id="mobile-panel" class="relative w-full bg-[#020D0A]/98 backdrop-blur-2xl border-b border-[#0A2F1F]/40 shadow-[0_20px_60px_rgba(0,0,0,0.6)]" style="max-height: 0; opacity: 0; transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1), opacity 0.3s ease; overflow: hidden;">
    
    <div class="pt-4 pb-6 px-5 sm:px-6">
      <nav class="space-y-0.5">
        {navLinks.map((item, i) => (
          <div class="mobile-nav-item">
            {item.dropdown ? (
              <div>
                <button class="mobile-dropdown-toggle w-full flex items-center justify-between py-3 border-b border-white/[0.05]">
                  <span class={`text-[15px] font-semibold tracking-wide font-heading ${currentPath.startsWith('/services') ? 'text-[#FB8500]' : 'text-white/70'}`}>{item.name}</span>
                  <svg class="w-4 h-4 text-white/25 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="mobile-dropdown-content overflow-hidden max-h-0 transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]">
                  <div class="py-2 pl-3 space-y-0.5">
                    {serviceLinks.map((s) => (
                      <a href={s.href} class={`flex items-center gap-2 py-2 text-[13px] font-medium hover:text-[#FB8500] transition-colors tracking-wide ${currentPath === s.href ? 'text-[#FB8500]' : 'text-white/35'}`}>
                        <svg class="w-3 h-3 text-white/15 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                        </svg>
                        {s.name}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class={`block py-3 border-b border-white/[0.05] text-[15px] font-semibold tracking-wide transition-colors font-heading ${currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? 'text-[#FB8500]' : 'text-white/70 hover:text-white'}`}
              >
                {item.name}
              </a>
            )}
          </div>
        ))}
      </nav>

      <div class="mt-5">
        <a href="/contact" class="block w-full py-3 bg-[#FB8500] text-[#020D0A] text-center text-[13px] font-bold tracking-wide rounded-xl hover:bg-[#FB8500]/85 transition-colors font-heading">
          Start a Project
        </a>
      </div>

      <div class="mt-4 pb-1 flex items-center gap-2.5">
        <div class="relative flex h-[6px] w-[6px]">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-[6px] w-[6px] bg-emerald-500"></span>
        </div>
        <span class="text-[10px] font-medium text-white/25 tracking-wide">Available for projects</span>
      </div>
    </div>
  </div>
</div>

<div class="h-[64px] md:h-[76px]"></div>

<script is:inline>
  (function() {
    let _scrollHandler = null;
    let _menuOpen = false;

    function initHeader() {
      const header = document.getElementById('site-header');
      const backdrop = header?.querySelector('.header-backdrop');
      const menuBtn = document.getElementById('mobile-menu-button');
      const closeBtn = document.getElementById('mobile-close-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const overlay = document.getElementById('mobile-overlay');
      const panel = document.getElementById('mobile-panel');
      const hamburger = document.getElementById('hamburger');
      const dropdownToggles = document.querySelectorAll('.mobile-dropdown-toggle');

      if (!header || !backdrop) return;

      _menuOpen = false;
      document.body.style.overflow = '';
      if (panel) { panel.style.maxHeight = '0'; panel.style.opacity = '0'; }
      if (overlay) { overlay.style.opacity = '0'; overlay.style.pointerEvents = 'none'; }
      if (mobileMenu) { mobileMenu.classList.add('pointer-events-none'); }
      if (hamburger) { hamburger.classList.remove('menu-open'); }

      let lastScroll = window.scrollY;

      if (_scrollHandler) {
        window.removeEventListener('scroll', _scrollHandler);
      }

      _scrollHandler = function() {
        const y = window.scrollY;
        if (y > 40) {
          backdrop.style.background = 'rgba(2, 13, 10, 0.97)';
          backdrop.style.borderColor = 'rgba(10, 47, 31, 0.5)';
          backdrop.style.backdropFilter = 'blur(30px)';
        } else {
          backdrop.style.background = 'rgba(2, 13, 10, 0.90)';
          backdrop.style.borderColor = 'rgba(10, 47, 31, 0.3)';
          backdrop.style.backdropFilter = 'blur(24px)';
        }

        if (y > lastScroll && y > 180 && !_menuOpen) {
          header.style.transform = 'translateY(-100%)';
        } else {
          header.style.transform = 'translateY(0)';
        }
        lastScroll = y;
      };

      window.addEventListener('scroll', _scrollHandler, { passive: true });
      _scrollHandler();

      function openMenu() {
        _menuOpen = true;
        if (!mobileMenu || !overlay || !panel || !hamburger) return;
        mobileMenu.classList.remove('pointer-events-none');
        overlay.style.opacity = '1';
        overlay.style.pointerEvents = 'auto';
        panel.style.maxHeight = panel.scrollHeight + 'px';
        panel.style.opacity = '1';
        hamburger.classList.add('menu-open');
        document.body.style.overflow = 'hidden';
        header.style.transform = 'translateY(0)';
      }

      function closeMenu() {
        _menuOpen = false;
        if (!mobileMenu || !overlay || !panel || !hamburger) return;
        overlay.style.opacity = '0';
        overlay.style.pointerEvents = 'none';
        panel.style.maxHeight = '0';
        panel.style.opacity = '0';
        hamburger.classList.remove('menu-open');
        document.body.style.overflow = '';
        setTimeout(function() {
          if (!_menuOpen && mobileMenu) mobileMenu.classList.add('pointer-events-none');
        }, 400);
      }

      function toggleMenu() {
        if (_menuOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      }

      if (menuBtn) {
        menuBtn.onclick = function(e) {
          e.stopPropagation();
          toggleMenu();
        };
      }
      if (overlay) {
        overlay.onclick = function() {
          closeMenu();
        };
      }

      if (mobileMenu) {
        var links = mobileMenu.querySelectorAll('a');
        for (var i = 0; i < links.length; i++) {
          links[i].onclick = function() {
            if (_menuOpen) closeMenu();
          };
        }
      }

      for (var t = 0; t < dropdownToggles.length; t++) {
        (function(toggle) {
          toggle.onclick = function(e) {
            e.preventDefault();
            e.stopPropagation();
            var content = toggle.nextElementSibling;
            var icon = toggle.querySelector('svg');
            if (!content) return;

            var isOpen = content.style.maxHeight && content.style.maxHeight !== '0px';
            if (isOpen) {
              content.style.maxHeight = '0px';
              if (icon) icon.style.transform = 'rotate(0deg)';
            } else {
              content.style.maxHeight = content.scrollHeight + 'px';
              if (icon) icon.style.transform = 'rotate(180deg)';
            }
          };
        })(dropdownToggles[t]);
      }
    }

    // Run immediately
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeader);
    } else {
      initHeader();
    }

    // Also run on Astro view transitions
    document.addEventListener('astro:page-load', initHeader);
  })();
</script>

<style>
  #site-header {
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .menu-open span:nth-child(1) {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }
  .menu-open span:nth-child(2) {
    opacity: 0;
    transform: translateY(-50%) scaleX(0);
  }
  .menu-open span:nth-child(3) {
    top: 50%;
    transform: translateY(-50%) rotate(-45deg);
  }

  .mobile-dropdown-content {
    max-height: 0;
    overflow: hidden;
  }

  .nav-link {
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    width: 0;
    height: 1.5px;
    background: #FB8500;
    border-radius: 1px;
    transform: translateX(-50%);
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover::after {
    width: 50%;
  }
</style>
