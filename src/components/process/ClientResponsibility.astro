---
const needs = [
  {
    title: "Brand & Assets",
    requirement: "Visual Identity",
    description: "High-resolution logos, brand guidelines, and existing marketing assets to ensure visual consistency.",
    icon: "M12 4.5v15m7.5-7.5h-15"
  },
  {
    title: "Core Content",
    requirement: "Copy & Media",
    description: "Product details, team photos, and specific text you want featured. Content is the fuel for the design.",
    icon: "M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2z"
  },
  {
    title: "Active Feedback",
    requirement: "Milestone Approval",
    description: "Timely reviews at defined milestones (Wireframes, Design, Development) to keep the project on track.",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
  }
];
---

<section class="bg-[#F8F9FA] py-16 md:py-32 px-6 font-sans antialiased text-slate-900 overflow-hidden relative">
  
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-orange-200/30 blur-[120px] rounded-full -z-10"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-blue-100/40 blur-[100px] rounded-full -z-10"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    <div class="mb-16 md:mb-28 text-center opacity-0 translate-y-6 transition-all duration-1000" id="needs-header">
      <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-white shadow-sm border border-slate-100 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
        </span>
        <span class="text-slate-600 font-bold text-[10px] uppercase tracking-[0.2em]">Workflow Requirements</span>
      </div>
      <h2 class="text-4xl sm:text-6xl md:text-8xl font-black tracking-tighter uppercase leading-[0.85] text-slate-950">
        Client <span class="text-orange-500 italic">Responsibility</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-16 md:mb-32">
      {needs.map((item, index) => (
        <div class="needs-card group relative opacity-0 translate-y-12 transition-all duration-700">
          
          <div class="relative h-full p-8 md:p-10 rounded-[3rem] bg-white/40 border border-white/80 backdrop-blur-2xl shadow-[0_20px_50px_-20px_rgba(0,0,0,0.05)] transition-all duration-500 group-hover:-translate-y-3 group-hover:shadow-[0_40px_80px_-30px_rgba(249,115,22,0.2)] group-hover:border-orange-200">
            
            <div class="absolute top-0 left-0 w-full h-full overflow-hidden rounded-[3rem] pointer-events-none">
                <div class="absolute -top-[100%] -left-[100%] w-[300%] h-[300%] bg-gradient-to-br from-white/20 via-transparent to-transparent rotate-45 transition-all duration-1000 group-hover:top-[-50%] group-hover:left-[-50%]"></div>
            </div>

            <div class="relative z-10">
              <div class="mb-12 relative">
                <div class="w-20 h-20 rounded-3xl bg-white shadow-xl flex items-center justify-center text-orange-500 border border-slate-50 transition-all duration-500 group-hover:scale-110 group-hover:bg-orange-500 group-hover:text-white">
                    <svg viewBox="0 0 24 24" class="w-10 h-10 fill-none stroke-current" stroke-width="1.5">
                        <path d={item.icon} stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <span class="absolute -top-4 -right-2 text-7xl font-black text-slate-900/[0.06] italic">0{index + 1}</span>
              </div>

              <div class="space-y-4">
                <h3 class="text-2xl md:text-3xl font-black uppercase tracking-tighter text-slate-900 group-hover:text-orange-600 transition-colors">
                  {item.title}
                </h3>
                <div class="h-1 w-10 bg-orange-500 rounded-full transition-all duration-500 group-hover:w-20"></div>
                <p class="text-slate-500 text-base md:text-lg leading-relaxed font-medium pt-4">
                  {item.description}
                </p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>


  </div>
</section>

<style>
  /* Lock the entry animation */
  .arrived {
    opacity: 1 !important;
    transform: translateY(0) !important;
    scale: 1 !important;
  }
</style>

<script>
  function initGlassLayout() {
    const header = document.getElementById('needs-header');
    const cards = document.querySelectorAll('.needs-card');

    // Configuration for the entrance trigger
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('arrived');
          // Stop watching once the animation has triggered
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    // Observe header if present
    if (header) observer.observe(header);

    // Observe cards and apply staggered delay
    cards.forEach((card, i) => {
      (card as HTMLElement).style.transitionDelay = `${i * 100}ms`;
      observer.observe(card);
    });
  }

  window.addEventListener('load', initGlassLayout);
  document.addEventListener('astro:page-load', initGlassLayout);
</script>