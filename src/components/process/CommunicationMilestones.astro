---
/**
 * CommunicationMilestone.astro
 * Style: Deep Industrial / Static Precision / High-Contrast Black
 */
const milestones = [
  {
    time: "09:00",
    label: "DAILY_SYNC",
    title: "Strategic Alignment",
    description: "Calibration of mission objectives and rapid resolution of systemic blockers.",
    status: "Priority_Alpha"
  },
  {
    time: "14:00",
    label: "ARCH_REVIEW",
    title: "Technical Vigilance",
    description: "Deep-dive assessment of infrastructure health and deployment integrity.",
    status: "Operational"
  },
  {
    time: "WEEKLY",
    label: "EXEC_REPORT",
    title: "Executive Insights",
    description: "High-level performance auditing and strategic roadmap recalibration.",
    status: "Strategic"
  }
];

const tools = ["Slack", "Jira", "Zoom", "Notion", "Linear"];
---

<section class="bg-white pt-20 md:pt-40 pb-0 px-6 font-sans antialiased relative overflow-hidden">
  
  <div class="absolute inset-0 opacity-[0.015] pointer-events-none" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="max-w-6xl mx-auto relative pb-20 md:pb-40">
    
    <div class="mb-20 md:mb-40 opacity-0 translate-y-8 transition-all duration-1000 ease-out arrived" id="comm-header">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-12 h-[2px] bg-orange-500"></div>
        <span class="text-black/30 font-mono text-[10px] uppercase tracking-[0.6em] font-black">System_Interaction_Log</span>
      </div>
      
      <h2 class="text-5xl sm:text-7xl md:text-9xl font-[1000] tracking-tighter uppercase text-black leading-[0.8]">
        Pulse <br/> <span class="text-orange-500 italic">Protocols.</span>
      </h2>
    </div>

    <div class="relative">
      <div class="absolute left-0 md:left-[160px] top-0 bottom-0 w-[1px] bg-black/[0.08]">
        <div class="absolute top-0 left-[-1px] w-[3px] h-full bg-orange-500/10"></div>
      </div>

      <div class="space-y-12 md:space-y-24 pl-4 md:pl-0">
        {milestones.map((item, i) => (
          <div class="milestone-row opacity-0 translate-y-12 transition-all duration-1000 flex flex-col md:flex-row gap-8 md:gap-24 relative group" style={`transition-delay: ${i * 150}ms`}>
            
            <div class="w-full md:w-[160px] flex md:flex-col justify-between items-baseline md:items-end pt-2">
              <span class="text-3xl md:text-4xl font-[1000] text-black tracking-tighter group-hover:text-orange-500 transition-colors duration-500 pe-5">{item.time}</span>
              <span class="font-mono text-[9px] text-black/20 uppercase tracking-[0.3em] font-black">{item.status}</span>
            </div>

            <div class="flex-grow relative">
              <div class="absolute left-[-33px] top-6 w-4 h-4 rounded-full bg-black border-2 border-orange-500 hidden md:block z-20"></div>

              <div class="p-8 md:p-14 rounded-[2rem] md:rounded-[3rem] border border-white/10 bg-black shadow-[0_40px_80px_-20px_rgba(0,0,0,0.3)] overflow-hidden relative transition-transform duration-500 hover:-translate-y-2">
                
                <div class="flex items-center gap-3 mb-10">
                   <span class="font-mono text-[11px] text-orange-500 font-black tracking-[0.4em] italic">[{item.label}]</span>
                   <div class="h-[1px] w-8 bg-orange-500/30"></div>
                </div>

                <h3 class="text-2xl md:text-4xl font-black text-white uppercase tracking-tighter mb-6 leading-none">
                  {item.title}<span class="text-orange-500">_</span>
                </h3>
                
                <p class="text-white/40 text-[13px] leading-relaxed font-bold uppercase tracking-widest max-w-xl">
                  {item.description}
                </p>

                <div class="absolute bottom-[-20px] right-[-20px] text-6xl md:text-8xl font-black text-white/[0.03] italic select-none">
                  {i + 1}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

</section>

<style>
  /* Entrance Animations */
  .arrived {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }
</style>

<script>
  function initPulseStream() {
    const header = document.getElementById('comm-header');
    const rows = document.querySelectorAll('.milestone-row');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('arrived');
        }
      });
    }, { threshold: 0.1 });

    if (header) observer.observe(header);
    rows.forEach((row) => observer.observe(row));
  }

  document.addEventListener('astro:page-load', initPulseStream);
  document.addEventListener('astro:page-load', initPulseStream);
</script>