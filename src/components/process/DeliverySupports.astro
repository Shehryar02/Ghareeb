---
/**
 * SpecTable.astro
 * Style: Monolithic Grid / Technical Tabular
 */
const phases = [
  {
    id: "01",
    tag: "TRANSFER PRTCL",
    title: "Handover",
    description: "Systematic ingestion of core assets into our managed ecosystem.",
    checklist: ["Production Repository", "System Architecture Blueprint", "UI/UX Asset Manifest"],
  },
  {
    id: "02",
    tag: "LIVE GUARDIAN",
    title: "Extraction",
    description: "Real-time technical shielding and systemic integrity maintenance.",
    checklist: ["24/7 Node Monitoring", "Automated Security Patching", "99.9% Uptime Guarantee"],
  },
  {
    id: "03",
    tag: "GROWTH SYNC",
    title: "Evolution",
    description: "Refining performance metrics for global scalability and UX.",
    checklist: ["Quarterly UX Audits", "Data Intelligence Mining", "Horizontal Infra Scaling"],
  }
];
---

<section class="bg-white py-40 px-6 font-sans antialiased min-h-screen">
  <div class="max-w-7xl mx-auto">
    
    <div class="mb-24 opacity-0 translate-y-4 transition-all duration-1000" id="table-header">
      <h2 class="text-6xl md:text-8xl text-center font-[1000] tracking-tighter uppercase text-black leading-none">
        Surgical <span class="text-orange-500 italic">Continuity</span>
      </h2>
    </div>

    <div class="relative border-t border-black/10 opacity-0 transition-all duration-1000 delay-300" id="spec-grid">
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-black/10">
        
        {phases.map((item) => (
          <div class="group relative pt-12 pb-20 px-8 md:px-12 transition-all duration-500 hover:bg-slate-50">
            
            <div class="flex justify-between items-start mb-20">
              <span class="font-mono text-[12px] text-orange-500 font-black tracking-widest">{item.tag}</span>
              <span class="text-4xl font-[1000] text-black/20 italic tracking-tighter group-hover:text-orange-500 transition-colors">{item.id}</span>
            </div>

            <div class="mb-16">
              <h3 class="text-5xl font-black text-black uppercase tracking-tighter mb-6 group-hover:text-orange-500 transition-colors">
                {item.title}
              </h3>
              <p class="text-black/40 text-[13px] leading-relaxed font-medium uppercase tracking-wider max-w-[280px]">
                {item.description}
              </p>
            </div>

            <div class="space-y-6">
              <div class="flex items-center gap-3 mb-8">
                <span class="font-mono text-[9px] text-black/20 uppercase tracking-[0.4em] font-bold">Deliverables</span>
                <div class="h-px flex-grow bg-black/5"></div>
              </div>

              {item.checklist.map((task) => (
                <div class="flex items-start gap-4 group/item">
                  <div class="mt-1 flex-shrink-0">
                    <svg viewBox="0 0 24 24" class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" stroke-width="3.5">
                      <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="text-[11px] font-bold uppercase tracking-widest text-black/60 group-hover/item:text-black transition-colors">
                    {task}
                  </span>
                </div>
              ))}
            </div>

            <div class="absolute bottom-0 left-0 w-full h-0 bg-orange-500 transition-all duration-500 group-hover:h-1.5"></div>
          </div>
        ))}

      </div>
    </div>
  </div>
</section>

<style>
  .arrived {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }
</style>

<script>
  function initSpecTable() {
    const header = document.getElementById('table-header');
    const grid = document.getElementById('spec-grid');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('arrived');
        }
      });
    }, { threshold: 0.1 });

    if (header) observer.observe(header);
    if (grid) observer.observe(grid);
  }

  document.addEventListener('DOMContentLoaded', initSpecTable);
</script>