---
/**
 * Modern_Split_Process_Hero.astro
 * Style: High-Impact / Black Circle Core / Dark Grid
 */
import { Image } from 'astro:assets';
import ProcessImage from '@/assets/process/process3.png';
---

<section class="relative w-full min-h-screen bg-white flex flex-col lg:flex-row items-stretch overflow-hidden font-sans antialiased">
  
  <div class="w-full lg:w-1/2 flex items-center justify-center p-8 md:p-16 lg:p-24 z-20 bg-white">
    <div class="max-w-xl">
      <div class="flex items-center gap-4 mb-8 group">
        <div class="w-12 h-[2px] bg-black group-hover:w-20 group-hover:bg-orange-500 transition-all duration-500"></div>
        <span class="text-[10px] font-black tracking-[0.5em] uppercase text-gray-400">Process Protocol v2.0</span>
      </div>

      <h1 class="text-6xl md:text-8xl font-[1000] text-black leading-[0.85] tracking-tighter mb-8 uppercase">
        Pixel <br/> 
        <span class="text-orange-500 italic">Perfect</span></h1>

      <p class="text-gray-500 text-lg md:text-xl leading-relaxed mb-10 font-medium max-w-md">
        Streamlined digital experiences built with surgical focus and <span class="text-black font-bold">scalable architecture</span>.
      </p>

      <div class="flex flex-wrap gap-6 items-center">
        <a href="/contact" class="group relative px-10 py-4 bg-black overflow-hidden rounded-sm transition-all duration-300 shadow-2xl shadow-black/10">
          <span class="relative z-10 text-white text-xs font-bold uppercase tracking-[0.2em] group-hover:text-orange-500 transition-colors">
            Get Started
          </span>
          <div class="absolute inset-0 bg-white translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
        </a>
        <a href="/work" class="text-xs font-black uppercase tracking-[0.3em] text-black hover:text-orange-500 transition-colors border-b-2 border-transparent hover:border-orange-500 pb-1">
          View Work
        </a>
      </div>
    </div>
  </div>

  <div class="w-full lg:w-1/2 relative flex items-center justify-center min-h-[60vh] lg:min-h-screen bg-white">
    
    <div class="absolute inset-0 opacity-[0.08]" style="background-image: linear-gradient(rgba(0,0,0,0.8) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.8) 1px, transparent 1px); background-size: 50px 50px;"></div>

    <div class="relative w-72 h-72 md:w-[32rem] md:h-[32rem] group">
      
      <div class="absolute inset-[-10%] bg-orange-500/15 blur-[100px] rounded-full animate-pulse-slow"></div>

      <div class="absolute inset-14 bg-black rounded-full shadow-[0_50px_100px_rgba(0,0,0,0.4)] border-[1px] border-white/10 overflow-hidden flex items-center justify-center">
        
        <div class="absolute inset-2 border-[12px] border-black rounded-full animate-spin-slow"></div>
        
        <div class="absolute inset-[8px] border-[2px] border-orange-500 shadow-[0_0_20px_#f97316] rounded-full"></div>

        <div class="relative z-10 w-3/4 h-auto animate-float">
          <Image 
            src={ProcessImage} 
            alt="Growth Process" 
            class="w-full h-auto object-contain transform group-hover:scale-110 transition-transform duration-1000 invert brightness-200 contrast-125"
          />
        </div>
      </div>

      <div class="absolute -top-6 -right-6 w-16 h-16 border border-black/10 rounded-full flex items-center justify-center animate-spin-slow">
         <div class="w-2 h-2 bg-orange-500 rounded-full shadow-[0_0_10px_#f97316]"></div>
      </div>
    </div>
  </div>

</section>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-15px) scale(1.05); }
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.1; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(1.1); }
  }

  .animate-spin-slow { animation: spin-slow 20s linear infinite; }
  .animate-float { animation: float 6s ease-in-out infinite; }
  .animate-pulse-slow { animation: pulse-slow 8s ease-in-out infinite; }

  h1 { animation: revealUp 1.2s cubic-bezier(0.16, 1, 0.3, 1); }
  @keyframes revealUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Optional: Ensure image pops on black background */
  .invert { filter: invert(0); } /* Adjust if your process image needs color correction for black bg */
</style>