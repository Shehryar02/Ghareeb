---
const steps = [
  { id: "01", title: "Strategic Discovery", desc: "In-depth analysis of project requirements and market positioning." },
  { id: "02", title: "Conceptual Design", desc: "Visualizing the user journey and core architecture framework." },
  { id: "03", title: "Agile Development", desc: "Iterative building with continuous integration and feedback loops." },
  { id: "04", title: "Scalable Deployment", desc: "Final optimization and transition to production environment." },
];
---

<section class="bg-white py-32 px-4 flex flex-col items-center justify-center font-sans relative overflow-hidden">
  
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
    <span class="text-[25vw] font-black text-slate-900/[0.02] tracking-tighter leading-none">METHODOLOGY</span>
  </div>

  <div class="text-center mb-16  animate-fade-down">
    <span class="text-orange-500 font-extrabold text-sm uppercase tracking-[0.4em] mb-6 block">Our Methodology</span>
    <h2 class="text-5xl md:text-[100px] font-black text-black mb-8 tracking-tighter leading-tight">
      The <span class="text-orange-500">Growth Process</span>
    </h2>
    <p class="text-gray-500 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto font-medium">
      A systematic approach to transforming complex challenges into scalable digital solutions through four precision-engineered stages.
    </p>
  </div>

  <div class="relative w-full max-w-6xl min-h-[800px] flex items-center justify-center">
    
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 100px 100px;"></div>

    <svg class="absolute inset-0 w-full h-full text-orange-500/20" viewBox="0 0 1000 1000" fill="none">
      <line x1="500" y1="0" x2="500" y2="1000" stroke="currentColor" stroke-width="0.5" stroke-dasharray="10 10" />
      <line x1="0" y1="500" x2="1000" y2="500" stroke="currentColor" stroke-width="0.5" stroke-dasharray="10 10" />
      <path d="M250 250 L 500 500" stroke="currentColor" stroke-width="2" class="animate-pulse" />
      <path d="M750 250 L 500 500" stroke="currentColor" stroke-width="2" />
      <path d="M250 750 L 500 500" stroke="currentColor" stroke-width="2" />
      <path d="M750 750 L 500 500" stroke="currentColor" stroke-width="2" />
      <circle cx="500" cy="500" r="150" stroke="currentColor" stroke-width="0.5" />
      <circle cx="500" cy="500" r="300" stroke="currentColor" stroke-width="0.5" stroke-dasharray="5 5" />
    </svg>

    <div class="absolute z-30 group">
      <div class="p-4 rounded-full border border-orange-500/10 bg-white/50 backdrop-blur-sm">
        <div class="w-56 h-56 md:w-72 md:h-72 bg-slate-950 rounded-full flex flex-col items-center justify-center shadow-[0_0_80px_rgba(249,115,22,0.2)] relative border-8 border-white group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-2 border border-white/10 rounded-full animate-[spin_10s_linear_infinite]"></div>
          
          <span class="text-white/20 text-[9px] uppercase tracking-[0.7em] mb-4">Core Engine</span>
          <span class="text-white font-black tracking-[0.2em] text-3xl uppercase leading-none">SYSTEM</span>
          <div class="w-12 h-[3px] bg-orange-500 my-6"></div>
          
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            <span class="text-white/60 font-bold tracking-[0.15em] text-[10px] uppercase">Active Protocol</span>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-x-[400px] md:gap-x-[600px] gap-y-72 z-20">
      {steps.map((step) => (
        <div class="flex flex-col items-center group relative">
          
          <div class="absolute -top-10 -z-10 text-[10px] font-mono text-slate-300 opacity-0 group-hover:opacity-100 transition-opacity">
            COORD_X: {Math.random().toFixed(2)} | SEQ: {step.id}
          </div>

          <div class="relative flex items-center justify-center">
            <div class="absolute w-[180%] h-[180%] rounded-full border border-slate-100 bg-slate-50/30 -z-10 group-hover:scale-110 transition-transform duration-700"></div>
            
            <div class="glass-sphere w-24 h-24 md:w-32 md:h-32 rounded-full flex items-center justify-center text-white text-5xl font-black relative z-10 overflow-hidden">
              <span class="relative z-10">{step.id}</span>
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            </div>
          </div>
          
          <div class="mt-12 text-center max-w-[260px]">
            <div class="inline-flex items-center gap-2 mb-4">
                <div class="h-[1px] w-4 bg-orange-500 group-hover:w-8 transition-all"></div>
                <span class="text-orange-600 font-black text-xs uppercase tracking-widest">Phase {step.id}</span>
                <div class="h-[1px] w-4 bg-orange-500 group-hover:w-8 transition-all"></div>
            </div>
            <h3 class="font-black text-slate-900 text-2xl uppercase tracking-tighter mb-4 group-hover:text-orange-500 transition-colors">
              {step.title}
            </h3>
            <p class="text-[13px] text-slate-500 leading-relaxed font-medium">
              {step.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .glass-sphere {
    background: #f97316;
    border: 4px solid #fff;
    box-shadow: 
      0 15px 35px rgba(249, 115, 22, 0.3),
      inset 0 -4px 10px rgba(0, 0, 0, 0.1);
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .group:hover .glass-sphere {
    transform: translateY(-10px) rotate(5deg);
    background: #000;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2);
  }

  /* Fill animation for the background paths */
  path {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: draw 3s ease forwards;
  }

  @keyframes draw {
    to { stroke-dashoffset: 0; }
  }
</style>