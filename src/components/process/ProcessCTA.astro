---
/**
 * Modern Clean CTA
 * Style: Luxury Glass / High Contrast
 * Theme: Pure White Background
 */
---

<section class="bg-white pb-42 px-6 relative overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div 
      id="needs-cta" 
      class="opacity-0 translate-y-12 transition-all duration-1000 ease-out"
    >
      <div class="bg-black rounded-[4rem] p-1 shadow-[0_40px_100px_-20px_rgba(0,0,0,0.3)] overflow-hidden">
        <div class="bg-black rounded-[3.8rem] px-10 py-16 md:px-20 flex flex-col md:flex-row items-center justify-between gap-12 relative overflow-hidden">
          
          <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(#f97316 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>

          <div class="relative z-10 max-w-xl text-center md:text-left">
            <h4 class="text-white text-4xl md:text-5xl font-black uppercase tracking-tighter mb-4 leading-none">
              Ready to build <br/> the <span class="text-orange-500">Infrastructure?</span>
            </h4>
            <p class="text-slate-400 text-lg font-medium italic">
              If you have these pillars ready, we can launch the discovery phase immediately.
            </p>
          </div>

          <a 
            href="#contact" 
            class="group relative z-10 bg-orange-500 px-12 py-6 rounded-2xl text-white font-black uppercase tracking-widest text-sm overflow-hidden transition-all hover:scale-105 active:scale-95 shadow-[0_20px_40px_-10px_rgba(249,115,22,0.5)]"
          >
            <span class="relative z-10">Start Project Now</span>
            <div class="absolute inset-0 bg-white translate-y-full group-hover:translate-y-0 transition-transform duration-300 opacity-20"></div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Ensuring priority for the entrance animation */
  #needs-cta.arrived {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }
</style>

<script>
  const initCtaAnimation = () => {
    const cta = document.getElementById('needs-cta');
    if (!cta) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('arrived');
          observer.unobserve(entry.target);
        }
      });
    }, { 
      threshold: 0.15 
    });

    observer.observe(cta);
  };

  // Run on load and after Astro swaps
  window.addEventListener('DOMContentLoaded', initCtaAnimation);
  document.addEventListener('astro:after-swap', initCtaAnimation);
</script>