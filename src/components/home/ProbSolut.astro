---
// IntegrationSection.astro
const layers = [
  {
    title: "Technical SEO",
    desc: "JSON-LD, Semantic HTML, and Dynamic OpenGraph generation baked into the core.",
    icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z",
    rotation: "md:rotate-y-12 md:translate-x-6"
  },
  {
    title: "Front-End Flow",
    desc: "Astro-powered Islands architecture for zero-latency user interaction.",
    icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
    rotation: "z-20 md:scale-105" 
  },
  {
    title: "Back-End Engine",
    desc: "PostgreSQL and Edge functions providing real-time data with global availability.",
    icon: "M4 7v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V7",
    rotation: "md:-rotate-y-12 md:-translate-x-6"
  }
];

const stackLogos = [
  { name: "Astro", path: "M15.5 2.5l-9 12h5l-1 7 11-13h-6l2-6z" },
  { name: "Tailwind", path: "M12 6.036c-2.287 0-3.43 1.143-3.43 3.429 0 2.285 1.143 3.428 3.43 3.428m0-6.857c2.286 0 3.428 1.142 3.428 3.429 0 2.285-1.142 3.428-3.428 3.428m-8.571-3.429c0-2.285 1.142-3.428 3.428-3.428m0 6.857c-2.286 0-3.428-1.143-3.428-3.428" },
  { name: "Database", path: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" },
  { name: "Edge", path: "M13 10V3L4 14h7v7l9-11h-7z" }
];
---

<section class="py-32 px-6 lg:px-32 bg-white overflow-hidden relative" id="integration-section">
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
       style="background-image: radial-gradient(#000 1.5px, transparent 1.5px); background-size: 60px 60px;">
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    <div id="reveal-text-zone" class="text-center mb-24 opacity-0 translate-y-10 transition-all duration-1000 ease-out">
      <div class="flex items-center justify-center gap-3 mb-6">
        <span class="h-[1px] w-8 bg-[#FB8500]"></span>
        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-black/40">Infrastructure v4.0</span>
        <span class="h-[1px] w-8 bg-[#FB8500]"></span>
      </div>

      <h2 class="text-6xl md:text-8xl font-black font-inter text-black uppercase tracking-[-0.04em] leading-[0.85] mb-8">
        <span class="block mb-2">Triple <span class="">Threat.</span></span>
        <span class="relative inline-block text-black">
           <span class=" text-cta outline-text">Single</span> Stack.
        </span>
      </h2>

      <p class="text-gray-400 max-w-xl mx-auto font-medium text-lg leading-relaxed tracking-tight">
        Proprietary infrastructure <span class="text-black font-bold">engineered</span> for high-output delivery and absolute architectural clarity.
      </p>
    </div>

    <div id="reveal-cards-zone" class="perspective-container relative grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 items-stretch">
      {layers.map((layer, i) => (
        <div 
          class={`integration-layer group relative cursor-pointer transition-all duration-700 ease-out ${layer.rotation}`}
          style={`--index: ${i};`}
        >
          <div class="absolute inset-x-12 inset-y-16 bg-[#FB8500] opacity-0 blur-[20px] rounded-full group-hover:opacity-20 transition-opacity duration-300"></div>
          
          <div class="relative h-full bg-white/70 backdrop-blur-md border border-black/10 p-10 flex flex-col justify-between rounded-[2.5rem] shadow-sm group-hover:shadow-2xl transition-all duration-300 will-change-transform">
            <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-white/90 to-transparent opacity-30 pointer-events-none"></div>

            <div class="relative z-10">
              <div class="flex justify-between items-start mb-12">
                 <div class={`p-3 rounded-xl shadow-lg transition-colors duration-200 ${i === 1 ? 'bg-cta text-white' : 'bg-black text-white group-hover:bg-[#FB8500] group-hover:text-black'}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d={layer.icon} />
                    </svg>
                 </div>
                 <div class="font-mono text-[9px] tracking-widest text-black/30 font-bold italic">SYS_0{i + 1}</div>
              </div>
              
              <h3 class="text-2xl font-black text-black uppercase mb-4 tracking-tighter leading-tight">{layer.title}</h3>
              <p class="text-black/60 text-sm leading-relaxed font-medium group-hover:text-black transition-colors">
                  {layer.desc}
              </p>
            </div>

            <div class="mt-10 flex items-center gap-2">
              <div class="h-1 w-8 bg-[#FB8500] rounded-full group-hover:w-12 transition-all duration-300"></div>
              <div class="h-1 w-1 bg-black/10 rounded-full"></div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-24 flex flex-col md:flex-row justify-between items-center gap-12 border-t border-black/5 pt-12">
        <div class="flex items-center gap-8">
            <div class="flex -space-x-3">
                {stackLogos.map((logo) => (
                    <div class="w-12 h-12 bg-white border border-black/10 rounded-2xl shadow-sm flex items-center justify-center p-2.5 transition-all hover:-translate-y-2 hover:z-30 hover:border-black/30 group/logo">
                      <svg viewBox="0 0 24 24" class="w-full h-full text-black/40 group-hover/logo:text-[#FB8500] transition-colors" fill="none" stroke="currentColor" stroke-width="2">
                        <path d={logo.path} stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </div>
                ))}
            </div>
            <div>
              <p class="text-black font-black text-sm uppercase tracking-tighter leading-none">Standardized Architecture</p>
              <p class="text-[9px] text-black/40 font-bold uppercase tracking-widest mt-1 italic">Vetted Enterprise Stack</p>
            </div>
        </div>
        
        <a href="/contact" class="group relative flex items-center gap-6 px-4 py-3 bg-white/40 backdrop-blur-md border border-black/[0.15] rounded-full hover:border-[#FB8500]/30 hover:bg-white/80 transition-all duration-500 shadow-sm">
            <div class="relative w-12 h-12 rounded-full bg-black flex items-center justify-center text-[#FB8500] group-hover:bg-[#FB8500] group-hover:text-black transition-all duration-500 overflow-hidden">
                <svg xmlns="http://www.w3.org/2000/svg" class="relative z-10 w-6 h-6 group-hover:rotate-[360deg] transition-transform duration-700 ease-in-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
            </div>
            <div class="pr-8">
                <p class="text-[9px] font-black tracking-[0.25em] text-black/40 uppercase mb-0.5 group-hover:text-[#FB8500]">Project Inquiry</p>
                <span class="text-black font-black text-xl tracking-tighter uppercase leading-none">Deploy Now</span>
            </div>
        </a>
    </div>
  </div>
</section>

<style>
  /* Zone Trigger States */
  .text-revealed {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  .cards-revealed .integration-layer {
    opacity: 1;
    /* This activates the 3D staggered entrance */
  }

  .outline-text {
    -webkit-text-stroke: 1.5px #FB8500;
  }

  .text-stroke-thin {
    color: white;
    -webkit-text-stroke: 1px black;
  }

  .perspective-container {
    perspective: 1200px;
    transform-style: preserve-3d;
  }

  /* Cards Animation Logic */
  .integration-layer {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s ease-out, transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
    transition-delay: calc(var(--index) * 150ms);
  }

  /* Specific 3D Positions when scrolled into view */
  .cards-revealed .integration-layer:nth-child(1) { transform: rotateY(30deg) translateZ(0); }
  .cards-revealed .integration-layer:nth-child(2) { transform: scale(1.05) translateZ(40px); }
  .cards-revealed .integration-layer:nth-child(3) { transform: rotateY(-30deg) translateZ(0); }

  /* Hover interactivity */
  .integration-layer:hover {
    transform: translateY(-10px) rotateY(0deg) translateZ(100px) !important;
    z-index: 50 !important;
    transition: transform 0.4s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .backdrop-blur-md {
    backdrop-filter: blur(10px) saturate(110%);
    -webkit-backdrop-filter: blur(10px) saturate(110%);
  }

  .integration-layer * {
    -webkit-font-smoothing: antialiased;
    backface-visibility: hidden;
  }
</style>

<script>
  function setupScrollAnimations() {
    const textZone = document.querySelector('#reveal-text-zone');
    const cardsZone = document.querySelector('#reveal-cards-zone');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (entry.target.id === 'reveal-text-zone') {
            entry.target.classList.add('text-revealed');
          } else if (entry.target.id === 'reveal-cards-zone') {
            entry.target.classList.add('cards-revealed');
          }
          observer.unobserve(entry.target);
        }
      });
    }, { 
      threshold: 0.2,
      rootMargin: "0px 0px -50px 0px" 
    });

    if (textZone) observer.observe(textZone);
    if (cardsZone) observer.observe(cardsZone);
  }

  setupScrollAnimations();
  document.addEventListener('astro:after-swap', setupScrollAnimations);
</script>