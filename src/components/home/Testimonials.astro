---
// ArchitectTestimonials.astro
const testimonials = [
  {
    quote: "The architecture fundamentally changed how we handle global transactions. Sub-100ms latency is now our baseline.",
    author: "Sarah Jenkins",
    role: "CTO, Global Finance",
    metric: "0.08s",
    label: "Avg Latency",
    size: "large" 
  },
  {
    quote: "Expert-level understanding of the Astro ecosystem.",
    author: "Marcus Thorne",
    role: "Founder, Vanguard",
    metric: "+310%",
    label: "Traffic",
    size: "small"
  },
  {
    quote: "Precision engineering. The attention to detail is something you rarely see in modern web dev.",
    author: "Elena Rodriguez",
    role: "Product Lead, Apex",
    metric: "100/100",
    label: "Vitals",
    size: "full"
  }
];
---

<section class="py-32 bg-white overflow-hidden font-inter">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Centered Header Section -->
    <div class="text-center mb-24 relative z-10">
      <p class="text-[14px] font-mono font-black uppercase tracking-[0.5em] text-[#FB8500] mb-6">
        Engineering Success
      </p>
      <h2 class="text-7xl md:text-9xl font-black text-black uppercase tracking-tighter leading-[0.8] mb-8">
        The <span class="text-[#FB8500] italic">Standard.</span>
      </h2>
      <p class="text-black/60 max-w-2xl mx-auto font-medium text-lg md:text-xl leading-relaxed tracking-tight">
        <span class="text-black font-bold">A proven track record</span> 
        of transforming complex technical requirements into 
        <span class="text-[#FB8500] font-bold">high-performance revenue assets.</span>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-stretch">
      {testimonials.map((t) => (
        <div class={`relative group overflow-hidden rounded-[3rem] bg-[#f8f8f8] border border-black/5 transition-all duration-700 hover:shadow-2xl hover:-translate-y-2 
          ${t.size === 'large' ? 'md:col-span-8' : t.size === 'full' ? 'md:col-span-12' : 'md:col-span-4'}`}>
          
          {t.size === 'full' && (
            <div class="absolute inset-0 opacity-[0.03] pointer-events-none">
              <svg width="100%" height="100%"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="black" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)" /></svg>
            </div>
          )}

          <div class="absolute -right-4 -top-8 text-[12rem] font-black text-black/[0.03] select-none uppercase tracking-tighter group-hover:text-[#FB8500]/5 transition-colors">
            {t.label.split(' ')[0]}
          </div>

          <div class="relative p-10 md:p-14 h-full flex flex-col justify-between z-10">
            <div>
              <div class="flex items-center gap-3 mb-12">
                <span class="h-px w-8 bg-[#FB8500]"></span>
                <span class="text-[10px] font-black uppercase tracking-widest text-[#FB8500]">{t.label}</span>
              </div>
              
              <h3 class={`${t.size === 'full' ? 'text-4xl md:text-6xl max-w-4xl' : t.size === 'large' ? 'text-3xl md:text-5xl' : 'text-2xl'} font-bold font-inter text-black leading-[1.1] mb-12`}>
                "{t.quote}"
              </h3>
            </div>

            <div class="flex items-end justify-between gap-4">
              <div>
                <p class="text-sm font-black text-black uppercase tracking-widest">{t.author}</p>
                <p class="text-[10px] text-black/40 font-bold uppercase tracking-tighter">{t.role}</p>
              </div>

              <div class="bg-white border-2 border-[#FB8500] px-6 py-4 rounded-2xl shadow-sm group-hover:bg-[#FB8500] group-hover:scale-110 transition-all duration-500">
                <p class="text-2xl md:text-3xl font-black text-black group-hover:text-white tracking-tighter">
                  {t.metric}
                </p>
              </div>
            </div>
          </div>

          <div class="absolute inset-0 bg-gradient-to-tr from-[#FB8500]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        </div>
      ))}

      <!-- Final CTA Block -->
      <div class="md:col-span-12 bg-black rounded-[3rem] p-12 md:p-20 flex flex-col md:flex-row items-center justify-between gap-8 mt-6 overflow-hidden relative">
        <div class="relative z-10 text-center md:text-left">
          <h4 class="text-white text-3xl md:text-5xl font-black uppercase tracking-tighter leading-none mb-4">
            Engineer your <span class="text-[#FB8500]">breakthrough.</span>
          </h4>
          <p class="text-white/40 font-medium uppercase tracking-[0.2em] text-[10px]">Ready to build the next market-dominant asset?</p>
        </div>

        <!-- Updated Button to match Apple Carousel style -->
        <a href="#contact" class="relative z-10 inline-flex items-center gap-4 px-12 py-6 bg-[#FB8500] text-black font-black uppercase text-[10px] tracking-[0.2em] rounded-full hover:bg-white transition-all transform hover:-translate-y-1 active:scale-95 shadow-2xl">
          Get Started Now
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  h2, h3 {
    letter-spacing: -0.05em;
  }
</style>