---
// Services.astro
const services = [
  {
    title: "Custom Web Apps",
    id: "WA-01",
    description: "Tailor-made digital solutions built with precision. Scalable, high-performance applications designed to solve complex business logic.",
    features: ["React/Next.js", "State Management", "Enterprise Scale"],
    icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
  },
  {
    title: "Landing Pages",
    id: "LP-02",
    description: "High-conversion entry points engineered for speed. We turn traffic into revenue with ultra-optimized, SEO-first single pages.",
    features: ["Conversion Focus", "A/B Ready", "Mobile First"],
    icon: "M13 2L3 14h9l-1 8 10-12h-9l1-8z"
  },
  {
    title: "Frontend Development",
    id: "FE-03",
    description: "Breath-taking user interfaces powered by Astro. Optimized for 100/100 Lighthouse scores and immediate interactivity.",
    features: ["Lighthouse 100", "Astro Islands", "Motion Design"],
    icon: "M17 18h1a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1M7 18H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1M9 20h6v-4H9v4Z"
  },
  {
    title: "Backend Development",
    id: "BE-04",
    description: "Resilient server-side engines. High-concurrency logic and secure database scaling for mission-critical apps.",
    features: ["Edge Functions", "API Design", "PostgreSQL"],
    icon: "M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"
  },
  {
    title: "Maintenance & Support",
    id: "MS-05",
    description: "Continuous surveillance and iterative improvements. We ensure your digital assets evolve as fast as the market.",
    features: ["Uptime Monitoring", "Security Patching", "Cloud Backups"],
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
  },
  {
    title: "Speed Optimization",
    id: "SO-06",
    description: "Aggressive performance tuning. We strip the friction from your existing site to drastically lower bounce rates.",
    features: ["Core Web Vitals", "Asset Compression", "Query Tuning"],
    icon: "M13 10V3L4 14h7v7l9-11h-7z"
  }
];

const initialServices = services.slice(0, 3);
const extraServices = services.slice(3);
---

<section 
  class="py-20 md:py-32 bg-[#050505] text-white relative overflow-hidden" 
  id="services-section" 
  data-animate="false"
  data-expanded="false"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-24 relative z-10">
    
    <div class="mb-10 flex flex-col items-center text-center">
      <p class="text-[#FB8500] font-mono text-[10px] md:text-xs font-bold tracking-[0.2em] md:tracking-[0.5em] uppercase mb-4 md:mb-6 opacity-80">
        Core Competencies
      </p>
      <h2 class="text-5xl sm:text-6xl md:text-8xl font-black uppercase tracking-[-0.05em] leading-[0.85] text-white">
        Technical <br/> 
        <span class="text-[#FB8500] italic inline-block mt-2">Capabilities.</span>
      </h2>
      <div class="w-40 md:w-60 h-1 bg-[#FB8500] mt-6 md:mt-8 rounded-full opacity-50"></div>
    </div>

            <p class="text-gray-400 text-center max-w-2xl mx-auto text-base md:text-lg font-light">
            Solving technical bottlenecks to transform high-conversion shops and digital storefronts into scalable, revenue-driven assets.
        </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 mt-12 md:mt-16 mb-6">
      {initialServices.map((service) => (
        <a href={`/services#${service.id}`} class="service-card group relative bg-neutral-900/30 border border-white/10 p-5 sm:p-6 md:p-8 rounded-2xl overflow-hidden">
          <div class="absolute inset-0 bg-orange-500/0 group-hover:bg-orange-500/5 transition-all duration-500"></div>
          <div class="relative z-10 h-full flex flex-col">
            <div class="flex justify-between items-start mb-6 sm:mb-8 md:mb-12">
              <div class="icon-box w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 text-orange-500 group-hover:bg-orange-500 group-hover:text-black">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="md:w-6 md:h-6"><path d={service.icon}></path></svg>
              </div>
            </div>
            <h3 class="text-sm sm:text-base md:text-2xl font-black uppercase tracking-tight mb-2 sm:mb-3 md:mb-4 group-hover:text-orange-500 transition-all duration-500 leading-tight">{service.title}</h3>
            <p class="text-neutral-400 text-[11px] sm:text-xs md:text-sm leading-relaxed mb-6 sm:mb-8 md:mb-10 flex-grow">{service.description}</p>
            <div class="flex flex-wrap gap-1.5 md:gap-2">
              {service.features.map(f => (
                <span class="text-[7px] md:text-[8px] font-bold uppercase tracking-widest bg-white/5 px-1.5 md:px-2 py-0.5 md:py-1 rounded text-neutral-500 group-hover:text-white transition-all duration-500">{f}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="expand-wrapper">
      <div class="expand-inner">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 pt-4 pb-12">
          {extraServices.map((service) => (
            <a href={`/services#${service.id}`} class="secondary-card group relative bg-neutral-900/30 border border-white/10 p-5 sm:p-6 md:p-8 rounded-2xl overflow-hidden">
              <div class="absolute inset-0 bg-orange-500/0 group-hover:bg-orange-500/5 transition-all duration-500"></div>
              <div class="relative z-10 h-full flex flex-col">
                <div class="flex justify-between items-start mb-6 sm:mb-8 md:mb-12">
                  <div class="icon-box w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 text-orange-500 group-hover:bg-orange-500 group-hover:text-black">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="md:w-6 md:h-6"><path d={service.icon}></path></svg>
                  </div>
                  <span class="id-tag font-mono text-[8px] md:text-[9px] text-neutral-600 tracking-widest uppercase">{service.id}</span>
                </div>
                <h3 class="text-sm sm:text-base md:text-2xl font-black uppercase tracking-tight mb-2 sm:mb-3 md:mb-4 group-hover:text-orange-500 transition-all duration-500 leading-tight">{service.title}</h3>
                <p class="text-neutral-400 text-[11px] sm:text-xs md:text-sm leading-relaxed mb-6 sm:mb-8 md:mb-10 flex-grow">{service.description}</p>
                <div class="flex flex-wrap gap-1.5 md:gap-2">
                  {service.features.map(f => (
                    <span class="text-[7px] md:text-[8px] font-bold uppercase tracking-widest bg-white/5 px-1.5 md:px-2 py-0.5 md:py-1 rounded text-neutral-500 group-hover:text-white group-hover:bg-orange-500/20 transition-all duration-500">{f}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="flex justify-center group relative p-[1.5px] rounded-full overflow-hidden bg-gradient-to-r from-white/10 via-[#FB8500]/50 to-white/10 max-w-fit mx-auto mt-4">
      <div class="absolute -inset-2 bg-[#FB8500]/15 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <button id="toggle-services" class="relative flex items-center gap-6 md:gap-12 pl-2 md:pl-4 pr-6 md:pr-10 py-2 md:py-3 bg-[#0a0a0a] rounded-full hover:bg-black transition-all duration-500">
        <div id="btn-icon-wrapper" class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-[#FB8500] flex items-center justify-center text-black shadow-[0_0_15px_rgba(251,133,0,0.4)] transition-transform duration-500 ease-out">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-[22px] md:h-[22px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </div>
        <div class="flex flex-col text-left">
          <p class="text-[9px] md:text-[10px] font-black tracking-[.25em] text-[#FB8500] uppercase mb-0.5">Full Stack</p>
          <span id="btn-text" class="text-white font-bold text-base md:text-lg tracking-tight whitespace-nowrap">View All Capabilities</span>
        </div>
      </button>
    </div>
  </div>
</section>

<style>
  /* 1. Base Transitions (The Smoothness Core) */
  .service-card, .secondary-card {
    opacity: 0;
    transform: translateY(20px);
    transition: 
      opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      background-color 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .service-card:hover, .secondary-card:hover {
    transform: translateY(-8px);
    border-color: rgba(251, 133, 0, 0.5);
  }

  .icon-box {
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .id-tag {
    transition: color 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* 2. Entrance Sequence */
  #services-section[data-animate="true"] .service-card {
    opacity: 1;
    transform: translateY(0);
  }

  /* 3. Height Expansion Logic */
  .expand-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden; 
  }

  #services-section[data-expanded="true"] .expand-wrapper {
    grid-template-rows: 1fr;
    overflow: visible; /* Prevents card clipping on hover */
  }

  .expand-inner {
    min-height: 0;
  }

  /* 4. Secondary Card Entrance Delay */
  .secondary-card {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease;
  }

  #services-section[data-expanded="true"] .secondary-card {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  #services-section[data-expanded="true"] .secondary-card:nth-child(1) { transition-delay: 100ms; }
  #services-section[data-expanded="true"] .secondary-card:nth-child(2) { transition-delay: 200ms; }
  #services-section[data-expanded="true"] .secondary-card:nth-child(3) { transition-delay: 300ms; }
</style>

<script>
  function initServices() {
    const section = document.querySelector('#services-section');
    const toggleBtn = document.querySelector('#toggle-services');
    const btnText = document.querySelector('#btn-text');
    const iconWrapper = document.querySelector('#btn-icon-wrapper');

    if (!section || !toggleBtn) return;

    // Entrance Animation on Scroll
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        section.setAttribute('data-animate', 'true');
        observer.unobserve(section);
      }
    }, { threshold: 0.15 });
    observer.observe(section);

    // Expansion Logic
    toggleBtn.addEventListener('click', () => {
      const isExpanded = section.getAttribute('data-expanded') === 'true';
      const newState = !isExpanded;
      
      section.setAttribute('data-expanded', newState.toString());
      
      // Smooth Text Swap
      btnText.style.opacity = '0';
      setTimeout(() => {
        btnText.textContent = newState ? 'Show Fewer' : 'View All Capabilities';
        btnText.style.opacity = '1';
      }, 200);

      // Rotate Icon Wrapper
      if (iconWrapper) {
        iconWrapper.style.transform = newState ? 'rotate(180deg)' : 'rotate(0deg)';
      }
    });
  }

  // Handle Initial Load + Astro View Transitions
  initServices();
  document.addEventListener('astro:page-load', initServices);
</script>