---
// Services.astro
const services = [
  {
    title: "Front-End Architecture",
    id: "FE-01",
    description: "Ultra-performance interfaces engineered with Astro. Optimized for 100/100 Lighthouse scores and immediate user interactivity.",
    features: ["Core Web Vitals", "Astro Islands", "Zero-JS Default"],
    icon: "M17 18h1a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1M7 18H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1M9 20h6v-4H9v4Z"
  },
  {
    title: "Robust Back-End Systems",
    id: "BE-02",
    description: "High-concurrency server logic and secure database scaling. We build resilient engines for mission-critical applications.",
    features: ["Edge Computing", "PostgreSQL", "Real-time Sync"],
    icon: "M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"
  },
  {
    title: "SEO-First Engineering",
    id: "SEO-03",
    description: "Deep technical SEO integration. We ensure your site is not just seen, but understood and ranked by global search algorithms.",
    features: ["JSON-LD Schema", "Semantic Tags", "Crawl Optimization"],
    icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
  }
];
---

<section 
  class="py-32 bg-[#0a0a0a] text-white relative overflow-hidden" 
  id="services-section" 
  data-animate="false"
>
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
       style="background-image: radial-gradient(#FB8500 0.5px, transparent 0.5px); background-size: 30px 30px;">
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-24 relative z-10">
    
    <div class="mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div class="header-content">
        <p class="text-[#FB8500] font-black tracking-[0.4em] uppercase text-[10px] mb-4">Service Capabilities</p>
        <h2 class="text-6xl md:text-8xl font-extrabold tracking-tighter leading-none uppercase">
          Digital <br/> <span class="text-transparent stroke-white-effect">Weaponry.</span>
        </h2>
      </div>
      <div class="h-px w-full md:w-32 bg-white/20 mb-4 hidden md:block line-divider"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
      {services.map((service, index) => (
        <div 
          class={`service-card group relative bg-[#0a0a0a] border p-10 flex flex-col justify-between border-[#FB8500]/50
          ${index === 0 ? 'md:col-span-8' : index === 1 ? 'md:col-span-4' : 'md:col-span-12'}`}
        >
          <div class="absolute top-0 right-0 w-0 h-0 border-t-40 border-t-[#FB8500] border-l-[40px] border-l-transparent opacity-0 group-hover:opacity-100 transition-all duration-500"></div>

          <div>
            <div class="flex justify-between items-start mb-16">
              <div class="text-[#FB8500] group-hover:scale-110 group-hover:rotate-12 transition-transform duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d={service.icon}></path>
                </svg>
              </div>
              <span class="text-[10px] font-mono text-white/30 tracking-tighter">{service.id}</span>
            </div>

            <h3 class="text-3xl font-bold uppercase tracking-tight mb-6">{service.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-12 max-w-sm font-light">
              {service.description}
            </p>
          </div>

          <div class="flex flex-wrap gap-4 pt-8 border-t border-white/5">
            {service.features.map(f => (
              <span class="text-[9px] font-black uppercase tracking-widest text-white/40 group-hover:text-[#FB8500] transition-colors">
                // {f}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 group cta-footer relative overflow-hidden bg-[#FB8500] rounded-sm transition-all duration-700">
        <a href="/services" class="flex flex-col md:flex-row items-center justify-between p-12 relative z-10">
            <div>
                <h4 class="text-black text-4xl font-black uppercase tracking-tighter leading-none mb-2">Explore Technical Details</h4>
                <p class="text-black/60 text-xs font-bold uppercase tracking-widest">View our full tech-stack and implementation philosophy</p>
            </div>
            <div class="mt-8 md:mt-0 w-20 h-20 bg-black rounded-full flex items-center justify-center text-[#FB8500] group-hover:rotate-45 transition-transform duration-500 shadow-xl group-hover:shadow-black/50">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
        </a>
        
        <div class="absolute top-1/2 left-0 -translate-y-1/2 overflow-hidden w-full pointer-events-none opacity-10">
            <div class="whitespace-nowrap animate-marquee text-black text-[10vw] font-black uppercase">
                FULL STACK ENGINEERING • SEO ARCHITECTURE • BACKEND SYSTEMS • 
            </div>
        </div>
    </div>

  </div>
</section>

<style>
  /* 1. Base Styles & Stroke Effect */
  .stroke-white-effect {
    -webkit-text-stroke: 1px white;
  }

  /* 2. Initial State (Hidden) */
  #services-section[data-animate="false"] .header-content,
  #services-section[data-animate="false"] .service-card,
  #services-section[data-animate="false"] .cta-footer {
    opacity: 0;
    transform: translateY(40px);
  }

  #services-section[data-animate="false"] .line-divider {
    transform: scaleX(0);
    opacity: 0;
  }

  /* 3. Global Transition Settings */
  .header-content, 
  .service-card, 
  .cta-footer, 
  .line-divider {
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  /* 4. Revealed State (Triggered by JS) */
  #services-section[data-animate="true"] .header-content,
  #services-section[data-animate="true"] .service-card,
  #services-section[data-animate="true"] .cta-footer {
    opacity: 1;
    transform: translateY(0);
  }

  #services-section[data-animate="true"] .line-divider {
    opacity: 1;
    transform: scaleX(1);
    transform-origin: left;
  }

  /* 5. Staggered Delays (Everything appears together but in sequence) */
  #services-section[data-animate="true"] .header-content { transition-delay: 100ms; }
  #services-section[data-animate="true"] .line-divider    { transition-delay: 400ms; }
  
  /* Staggering the 3 cards */
  #services-section[data-animate="true"] .service-card:nth-child(1) { transition-delay: 300ms; }
  #services-section[data-animate="true"] .service-card:nth-child(2) { transition-delay: 450ms; }
  #services-section[data-animate="true"] .service-card:nth-child(3) { transition-delay: 600ms; }
  
  #services-section[data-animate="true"] .cta-footer { transition-delay: 800ms; }

  /* 6. Marquee & Hover Effects */
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .animate-marquee {
    display: inline-block;
    animation: marquee 20s linear infinite;
  }

  .service-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(600px circle at var(--mouse-x) var(--mouse-y), rgba(251, 133, 0, 0.08), transparent 40%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }

  .service-card:hover::after {
    opacity: 1;
  }
</style>

<script>
  function setupObserver() {
    const section = document.querySelector('#services-section');
    
    if (!section) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Trigger the animation for the whole section
          section.setAttribute('data-animate', 'true');
          // Once triggered, we don't need to observe anymore
          observer.unobserve(section);
        }
      });
    }, { 
      threshold: 0.1, // Trigger when 10% of the section is visible
      rootMargin: "0px 0px -50px 0px" 
    });

    observer.observe(section);

    // Card Mouse Tracking
    const cards = document.querySelectorAll('.service-card');
    cards.forEach((card) => {
cards.forEach((card) => {
      // Ensure the card is actually an HTMLElement
      if (card instanceof HTMLElement) {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          // Using style.setProperty is safe here because we checked the instance
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        });
      }
    });
    });
  }

  // Handle standard load and Astro View Transitions
  setupObserver();
  document.addEventListener('astro:after-swap', setupObserver);
</script>