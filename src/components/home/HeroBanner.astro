---
// Reliable Unsplash URLs for Futuristic Tech & Architecture
const slides = [
  // "https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=1920&auto=format&fit=crop", // Deep space/tech
  // "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=1920&auto=format&fit=crop", // Cyber security
  "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1920&auto=format&fit=crop",  // Modern Architecture
  "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1920&auto=format&fit=crop",  // Modern Architecture
  "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1920&auto=format&fit=crop",  // Modern Architecture
];
---

<section class="py-12 relative w-full min-h-screen bg-black overflow-hidden flex items-center justify-center">
  
  <div class="absolute inset-0 z-0">
    {slides.map((img, index) => (
      <div 
        class="absolute inset-0 opacity-0 animate-crossfade"
        style={`animation-delay: ${index * 3}s; z-index: ${10 - index};`}
      >
        <img 
          src={img} 
          alt="Background Slide" 
          class="w-full h-full object-cover animate-slow-zoom" 
          loading={index === 0 ? "eager" : "lazy"}
        />
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black"></div>
      </div>
    ))}
  </div>

  <div class="relative z-20 text-center px-6 max-w-6xl">
    <div class="flex items-center justify-center gap-2 sm:gap-4 mb-6 sm:mb-8 opacity-0 animate-fade-in" style="animation-delay: 0.2s;">
        <span class="h-[1px] w-6 sm:w-10 bg-orange-500"></span>
        <span class="font-mono text-[10px] sm:text-[14px] uppercase tracking-[0.2em] sm:tracking-[0.5em] text-orange-400 font-bold text-center">Development for Growing Businesses</span>
        <span class="h-[1px] w-6 sm:w-10 bg-orange-500"></span>
    </div>

<h1 class="relative z-10 text-5xl sm:text-7xl md:text-[140px] font-black tracking-[-0.04em] leading-[0.85] mb-8 sm:mb-12 opacity-0 animate-fade-in" style="animation-delay: 0.4s;">
  
  <span class="text-white text-outline  drop-shadow-[0_4px_30px_rgba(0,0,0,0.9)]">
    YOUR VISION
  </span> <br />

  <span class="text-white bg-clip-text pe-6 drop-shadow-[0_4px_20px_rgba(0,0,0,0.6)]">
    ELEVATED
  </span> <br />

  <span class="text-orange-400 font-extrabold ">
    SCALED.
  </span>

</h1>
    
    <div class="opacity-0 animate-fade-in" style="animation-delay: 0.6s;">
        <p class="text-white/50 text-lg sm:text-xl md:text-2xl italic font-medium max-w-xl mx-auto mb-10 sm:mb-14 leading-relaxed px-4 sm:px-0">
          "Modernizing digital infrastructure for market-leading results."
        </p>

<div class="group relative inline-block p-[1.5px] rounded-full overflow-hidden bg-gradient-to-r from-white/5 via-[#FB8500]/50 to-white/5 shadow-2xl">
    <div class="absolute -inset-2 bg-[#FB8500]/10 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    
    <a href="/contact" class="relative flex items-center justify-between gap-6 sm:gap-16 pl-2 sm:pl-4 pr-6 sm:pr-10 py-2 sm:py-3.5 bg-[#0a0a0a] rounded-full hover:bg-black transition-all duration-300">
        
        <div class="w-10 h-10 sm:w-14 sm:h-14 rounded-full bg-[#FB8500] flex items-center justify-center text-black shadow-[0_0_20px_rgba(251,133,0,0.3)] group-hover:rotate-[360deg] transition-transform duration-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-7 sm:h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
        </div>
        
        <div class="flex flex-col text-left">
            <p class="text-[9px] sm:text-[11px] font-black tracking-[.2em] sm:tracking-[.3em] text-[#FB8500] uppercase mb-1">
                Ready to Scale?
            </p>
            <span class="text-white font-bold text-base sm:text-xl tracking-tight whitespace-nowrap">
                Start Your Journey
            </span>
        </div>
        
    </a>
</div>
    </div>
  </div>

</section>

<style>
  /* Outlined text effect */
  .text-outline {
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.3);
    color: transparent;
    transition: all 0.5s ease;
  }
  
  
  /* h1:hover .text-outline {
    -webkit-text-stroke: 1.5px rgba(249, 115, 22, 1);
  } */

  /* Reveal animation */
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s forwards cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Smooth Crossfade Logic */
  @keyframes crossfade {
    0% { opacity: 0; visibility: hidden; }
    5%, 33% { opacity: 1; visibility: visible; }
    38%, 100% { opacity: 0; visibility: hidden; }
  }
  .animate-crossfade {
    animation: crossfade 9s infinite linear;
  }

  /* Subtle zoom effect */
  @keyframes slow-zoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.15); }
  }
  .animate-slow-zoom {
    animation: slow-zoom 15s infinite alternate ease-in-out;
  }
</style>