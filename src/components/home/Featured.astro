---
// ApplePremiumCarousel.astro
const projects = [
  {
    tag: "FinTech Architecture",
    title: "Apex Ledger",
    desc: "Engineered a high-frequency banking dashboard for sub-100ms latency and real-time asset tracking.",
    image: "",
    link: "#"
  },
  {
    tag: "E-Commerce Engine",
    title: "Vanguard Store",
    desc: "A headless commerce solution handling 50k+ daily transactions with a focus on conversion optimization.",
    image: "",
    link: "#"
  },
  {
    tag: "Search Dominance",
    title: "SEO Core v4",
    desc: "Custom semantic HTML architecture that boosted organic reach by 300% for enterprise-scale platforms.",
    image: "",
    link: "#"
  }
];
---

<section class="py-32 bg-white overflow-hidden relative" id="apple-hover-carousel">
  <div id="zone-left" class="absolute left-0 top-0 w-[20%] h-full z-30"></div>
  <div id="zone-right" class="absolute right-0 top-0 w-[20%] h-full z-30"></div>

  <div class="max-w-7xl mx-auto px-6 mb-16 flex flex-col md:flex-row justify-between items-start md:items-end relative z-10 gap-8">
    <div class="max-w-3xl">
      <p class="text-[10px] font-black uppercase tracking-[0.4em] text-[#FB8500] mb-4">Precision Engineering</p>
      <h2 class="text-6xl md:text-8xl font-black text-black uppercase tracking-tighter leading-[0.85]">
        Digital <br />
        <span class="text-[#FB8500]">Mastery.</span>
      </h2>
    </div>
    
    <div class="flex gap-4 mb-4">
      {projects.map((_, i) => (
        <div class="carousel-indicator h-1.5 w-16 bg-black/5 rounded-full overflow-hidden">
          <div class="indicator-progress h-full bg-[#FB8500] w-0 transition-all duration-300"></div>
        </div>
      ))}
    </div>
  </div>

  <div class="relative w-full overflow-visible">
    <div id="apple-track" class="flex transition-transform duration-[1000ms] cubic-bezier(0.23, 1, 0.32, 1)">
      {projects.map((project, i) => (
        <div class="apple-card min-w-[85vw] md:min-w-[70vw] lg:min-w-[65vw] px-6 transition-all duration-[1000ms]" data-index={i}>
          <div class="relative rounded-[3rem] overflow-hidden aspect-[16/10] bg-black group border-[1px] border-black/10 shadow-2xl ring-1 ring-black/5">
            
            <img src={project.image}  class="w-full h-full object-cover opacity-70 grayscale-[20%] transition-transform duration-1000 group-hover:scale-105" />
            
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/30 to-transparent flex flex-col justify-end p-8 md:p-20">
              <p class="text-[#FB8500] font-black uppercase tracking-[0.3em] text-[11px] mb-4 drop-shadow-md">
                {project.tag}
              </p>
              <h3 class="text-white text-4xl md:text-7xl font-black uppercase tracking-tighter mb-6 leading-none drop-shadow-lg">
                {project.title}
              </h3>
              
              <div class="apple-reveal opacity-0 translate-y-8 transition-all duration-700 delay-300">
                <p class="text-white text-lg md:text-2xl max-w-2xl mb-10 font-medium leading-relaxed drop-shadow-sm">
                  {project.desc}
                </p>
                <a href={project.link} class="inline-flex items-center gap-4 px-10 py-5 bg-[#FB8500] text-black font-black uppercase text-xs tracking-[0.2em] rounded-full hover:bg-white transition-all shadow-xl">
                    Explore Study
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Base Card State (Inactive) */
  .apple-card {
    opacity: 0.3;
    transform: scale(0.88);
    filter: blur(12px);
    pointer-events: none;
  }

  /* Active Card State */
  .apple-card.is-active {
    opacity: 1;
    transform: scale(1);
    filter: blur(0);
    pointer-events: auto;
  }

  .apple-card.is-active .apple-reveal {
    opacity: 1;
    transform: translateY(0);
  }

  .indicator-progress.is-active {
    width: 100%;
  }

  /* Hide scrollbar for the track */
  #apple-track {
    will-change: transform;
  }
</style>

<script>
  function initHoverCarousel() {
    // 1. Cast elements to HTMLElement so TS knows they have 'style' and 'offsetLeft'
    const track = document.getElementById('apple-track') as HTMLElement | null;
    const cards = document.querySelectorAll('.apple-card') as NodeListOf<HTMLElement>;
    const indicators = document.querySelectorAll('.indicator-progress') as NodeListOf<HTMLElement>;
    const zoneLeft = document.getElementById('zone-left') as HTMLElement | null;
    const zoneRight = document.getElementById('zone-right') as HTMLElement | null;
    
    let currentIndex = 0;
    let isMoving = false;
    
    // 2. Fix 'interval' red line by typing it for the browser environment
    let interval: number | undefined | ReturnType<typeof setInterval> = undefined;

    function updateCarousel() {
      if (!track || cards.length === 0) return;
      isMoving = true;
      
      const viewportCenter = window.innerWidth / 2;
      const currentCard = cards[currentIndex];
      
      if (!currentCard) return;

      const cardOffset = currentCard.offsetLeft;
      const cardWidth = currentCard.offsetWidth;
      
      const move = viewportCenter - cardOffset - (cardWidth / 2);
      
      track.style.transform = `translateX(${move}px)`;
      
      cards.forEach((card, i) => card.classList.toggle('is-active', i === currentIndex));
      indicators.forEach((ind, i) => ind.classList.toggle('is-active', i === currentIndex));
      
      setTimeout(() => { isMoving = false; }, 1100); 
    }

    // 3. Fix 'direction' red line by defining its allowed string values
    function startAutoMove(direction: 'left' | 'right') {
      if (interval) return;
      interval = setInterval(() => {
        if (isMoving) return;
        
        if (direction === 'right' && currentIndex < cards.length - 1) {
          currentIndex++;
          updateCarousel();
        } else if (direction === 'left' && currentIndex > 0) {
          currentIndex--;
          updateCarousel();
        } else {
          stopAutoMove();
        }
      }, 10);
      // Here to change the delay of hover
    }

    function stopAutoMove() {
      if (interval) {
        clearInterval(interval as number);
        interval = undefined;
      }
    }

    zoneRight?.addEventListener('mouseenter', () => startAutoMove('right'));
    zoneRight?.addEventListener('mouseleave', stopAutoMove);
    zoneLeft?.addEventListener('mouseenter', () => startAutoMove('left'));
    zoneLeft?.addEventListener('mouseleave', stopAutoMove);

    window.addEventListener('resize', updateCarousel);
    
    // Initial call
    setTimeout(updateCarousel, 100);
  }

  // Initialize on load and on Astro view transitions
  initHoverCarousel();
  document.addEventListener('astro:after-swap', initHoverCarousel);
</script>