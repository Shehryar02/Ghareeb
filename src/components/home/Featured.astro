---
// ApplePremiumCarousel.astro
const projects = [
  {
    tag: "FinTech Architecture",
    title: "Apex Ledger",
    desc: "Engineered a high-frequency banking dashboard for sub-100ms latency and real-time asset tracking.",
    image: "https://images.unsplash.com/photo-1551288049-bbda4833effb?q=80&w=1200",
    link: "#"
  },
  {
    tag: "E-Commerce Engine",
    title: "Vanguard ",
    desc: "A headless commerce solution handling 50k+ daily transactions with a focus on conversion optimization.",
    image: "https://images.unsplash.com/photo-1563013544-824ae1b704d3?q=80&w=1200",
    link: "#"
  },
  {
    tag: "Search Dominance",
    title: "SEO Core v4",
    desc: "Custom semantic HTML architecture that boosted organic reach by 300% for enterprise-scale platforms.",
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=1200",
    link: "#"
  }
];
---

<section class="py-24 bg-white overflow-hidden relative" id="apple-hover-carousel">
  <div id="zone-left" class="absolute left-0 top-0 w-[15%] h-full z-30 cursor-west-resize"></div>
  <div id="zone-right" class="absolute right-0 top-0 w-[15%] h-full z-30 cursor-east-resize"></div>

  <div class="max-w-7xl mx-auto px-6 mb-20 relative z-10 text-center">
    <p class="text-[14px] font-mono font-black uppercase tracking-[0.5em] text-[#FB8500] mb-6">
      Precision Engineering
    </p>
    
    <h2 class="text-7xl md:text-9xl font-black text-black uppercase tracking-tighter leading-[0.85] mb-8">
      Digital <span class="text-[#FB8500] italic">Mastery.</span>
    </h2>

    <p class="text-black/60 max-w-2xl mx-auto font-medium text-lg md:text-xl leading-relaxed tracking-tight text-center">
      <span class="text-black font-bold">A proven track record</span> 
      of transforming complex technical requirements into 
      <span class="text-[#FB8500] font-bold">high-performance revenue assets.</span>
    </p>

    <div class="flex justify-center gap-4 mt-12">
      {projects.map((_, i) => (
        <div class="carousel-indicator h-1 w-20 bg-black/5 rounded-full overflow-hidden">
          <div class="indicator-progress h-full bg-[#FB8500] w-0 transition-all duration-500"></div>
        </div>
      ))}
    </div>
  </div>

  <div class="relative w-full overflow-visible">
    <div id="apple-track" class="flex transition-transform duration-[1000ms] ease-[cubic-bezier(0.23,1,0.32,1)]">
      {projects.map((project, i) => (
        <div class="apple-card min-w-[90vw] md:min-w-[75vw] lg:min-w-[70vw] px-4 transition-all duration-1000" data-index={i}>
          <div class="relative rounded-[3rem] overflow-hidden aspect-[16/9] bg-black group border border-black/5 shadow-2xl">
            <img src={project.image} alt={project.title} class="w-full h-full object-cover opacity-50 grayscale-[20%] transition-transform duration-1000 group-hover:scale-105" />
            
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent flex flex-col justify-end p-10 md:p-20">
              <p class="text-[#FB8500] font-black uppercase tracking-[0.4em] text-[10px] md:text-xs mb-4">
                {project.tag}
              </p>
              <h3 class="text-white text-5xl md:text-8xl font-black uppercase tracking-tighter mb-8 leading-none">
                {project.title}
              </h3>
              
              <!-- THE REVEAL SECTION -->
              <div class="apple-reveal opacity-0 translate-y-10 transition-all duration-700 delay-300">
                <p class="text-white/70 text-lg md:text-2xl max-w-2xl mb-12 font-medium leading-relaxed">
                  {project.desc}
                </p>
                <a href={project.link} class="inline-flex items-center gap-4 px-12 py-5 bg-[#FB8500] text-black font-black uppercase text-[10px] tracking-[0.2em] rounded-full hover:bg-white transition-all transform hover:-translate-y-1 active:scale-95 shadow-2xl">
                    Explore Case Study
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .apple-card {
    opacity: 0.15;
    transform: scale(0.85);
    filter: blur(8px);
    pointer-events: none;
    transition: all 1.2s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .apple-card.is-active {
    opacity: 1;
    transform: scale(1);
    filter: blur(0);
    pointer-events: auto;
  }

  /* REVEAL LOGIC FIX */
  .apple-card.is-active .apple-reveal {
    opacity: 1;
    transform: translateY(0);
  }

  .indicator-progress.is-active {
    width: 100%;
  }

  #apple-track {
    will-change: transform;
    display: flex;
    align-items: center;
  }
</style>

<script>
  function initHoverCarousel() {
    const track = document.getElementById('apple-track');
    const cards = document.querySelectorAll('.apple-card');
    const indicators = document.querySelectorAll('.indicator-progress');
    const zoneLeft = document.getElementById('zone-left');
    const zoneRight = document.getElementById('zone-right');
    
    let currentIndex = 1; // Starts on the second project
    let isMoving = false;
    let interval: any = null;

    function updateCarousel() {
      if (!track || cards.length === 0) return;
      isMoving = true;
      
      const viewportCenter = window.innerWidth / 2;
      const currentCard = cards[currentIndex] as HTMLElement;
      const cardOffset = currentCard.offsetLeft;
      const cardWidth = currentCard.offsetWidth;
      
      const move = viewportCenter - cardOffset - (cardWidth / 2);
      
      track.style.transform = `translateX(${move}px)`;
      
      cards.forEach((card, i) => card.classList.toggle('is-active', i === currentIndex));
      indicators.forEach((ind, i) => ind.classList.toggle('is-active', i === currentIndex));
      
      setTimeout(() => { isMoving = false; }, 1000); 
    }

    function startAutoMove(direction: 'left' | 'right') {
      if (interval) return;
      interval = setInterval(() => {
        if (isMoving) return;
        if (direction === 'right' && currentIndex < cards.length - 1) {
          currentIndex++;
          updateCarousel();
        } else if (direction === 'left' && currentIndex > 0) {
          currentIndex--;
          updateCarousel();
        } else {
          stopAutoMove();
        }
      }, 200); 
    }

    function stopAutoMove() {
      if (interval) {
        clearInterval(interval);
        interval = null;
      }
    }

    zoneRight?.addEventListener('mouseenter', () => startAutoMove('right'));
    zoneRight?.addEventListener('mouseleave', stopAutoMove);
    zoneLeft?.addEventListener('mouseenter', () => startAutoMove('left'));
    zoneLeft?.addEventListener('mouseleave', stopAutoMove);

    window.addEventListener('resize', updateCarousel);
    setTimeout(updateCarousel, 150);
  }

  initHoverCarousel();
  document.addEventListener('astro:after-swap', initHoverCarousel);
</script>