---
// strategy.astro - Refined Diagonal Blueprint with Viewport Trigger & Color Reveal
const strategy = {
  header: {
    phase: "Phase 02 // Strategic Rollout",
    title: "Operational",
    highlight: "Tactics",
    desc: "A systematic conversion of identified constraints into high-yield gym infrastructure."
  },
  steps: [
    {
      id: "01",
      title: "The Digital Foundation",
      subtitle: "LOGISTIC AUTOMATION",
      desc: "Replacing manual friction with passive biometric capture. We eliminate the 'Human Latency Gap' at the source.",
      image: "https://images.unsplash.com/photo-1593079831268-3381b0db4a77?q=80&w=800",
      logo: "https://www.svgrepo.com/show/303128/intel-logo.svg"
    },
    {
      id: "02",
      title: "Synthesis Engine",
      subtitle: "NEURAL ANALYSIS",
      desc: "Raw data is processed into predictive fatigue models, allowing for pre-injury intervention and optimized load scaling.",
      image: "https://images.unsplash.com/photo-1576678927484-cc907957088c?q=80&w=800",
      logo: "https://www.svgrepo.com/show/303106/nvidia-logo.svg"
    },
    {
      id: "03",
      title: "Floor Deployment",
      subtitle: "AUTONOMOUS FEEDBACK",
      desc: "Live tactical adjustments pushed directly to coach dashboards, ensuring 100% training accuracy across all sessions.",
      image: "https://images.unsplash.com/photo-1517836357463-d25dfeac3438?q=80&w=800",
      logo: "https://www.svgrepo.com/show/443313/tesla.svg"
    }
  ]
};
---

<section class="bg-[#050505] text-white py-32 px-6 font-sans overflow-hidden relative">
  
  {/* BACKGROUND WATERMARK */}
  <div class="absolute top-20 right-[-10%] opacity-[0.02] pointer-events-none select-none">
     <h2 class="text-[25rem] font-black uppercase tracking-tighter">STRAT</h2>
  </div>

  <div class="max-w-7xl mx-auto relative">
    
    {/* 1. HEADER */}
    <div class="reveal mb-40 flex flex-col md:flex-row justify-between items-end gap-12">
      <div class="max-w-2xl">
        <span class="text-orange-500 font-mono text-[10px] font-bold tracking-[0.6em] uppercase mb-6 block">
          {strategy.header.phase}
        </span>
        <h2 class="text-7xl md:text-9xl font-black uppercase tracking-tighter leading-[0.8]">
          {strategy.header.title}<br/>
          <span class="italic text-transparent bg-clip-text bg-gradient-to-r from-neutral-300 to-neutral-700">
            {strategy.header.highlight}.
          </span>
        </h2>
      </div>
      <p class="text-neutral-500 text-lg font-medium italic max-w-xs border-l border-orange-600/50 pl-8 pb-2">
        "{strategy.header.desc}"
      </p>
    </div>

    {/* 2. THE DIAGONAL STAIRCASE */}
    <div class="relative">
      {strategy.steps.map((step, index) => (
        <div 
          class="reveal relative mb-32 md:mb-48 flex flex-col md:flex-row items-center gap-12"
          style={`margin-left: ${index * 12}%;`}
        >
          {/* IMAGE BLOCK */}
          <div class="relative w-full md:w-[450px] aspect-video rounded-2xl overflow-hidden group shadow-2xl border border-white/10">
              <img 
                src={step.image} 
                alt={step.title} 
                class="reveal-img w-full h-full object-cover grayscale brightness-50 transition-all duration-[2000ms] ease-in-out"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
              <div class="absolute top-6 left-6 w-10 h-10 bg-white/10 backdrop-blur-md rounded-lg p-2 border border-white/20">
                  <img src={step.logo} class="w-full h-full object-contain invert opacity-50" alt="Tech Provider" />
              </div>
          </div>

          {/* TEXT BLOCK */}
          <div class="md:max-w-md relative">
             <div class="flex items-center gap-4 mb-4">
                <span class="text-orange-600 font-mono text-xl font-black italic">0{step.id}</span>
                <div class="h-px w-12 bg-orange-600/30"></div>
                <span class="text-[9px] font-black text-neutral-500 tracking-[0.3em] uppercase">{step.subtitle}</span>
             </div>
             <h3 class="text-4xl font-black uppercase tracking-tight mb-6 leading-none">{step.title}</h3>
             <p class="text-neutral-400 text-sm leading-relaxed mb-8">{step.desc}</p>
             {index < strategy.steps.length - 1 && (
               <div class="hidden md:block absolute top-[130%] left-[-50px] w-px h-32 bg-gradient-to-b from-orange-600 to-transparent"></div>
             )}
          </div>
        </div>
      ))}
    </div>

    {/* 3. STRATEGIC FINALE */}
    <div class="reveal mt-40 flex flex-col md:flex-row items-center gap-12 lg:gap-24">
       
       <div class="w-full md:w-1/2 relative group">
          <div class="relative rounded-3xl overflow-hidden border border-white/10 shadow-2xl">
              <img 
                src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=1200" 
                class="reveal-img w-full h-64 md:h-[500px] object-cover grayscale brightness-50 contrast-125 transition-all duration-[2000ms] ease-in-out" 
                alt="Elite Athlete Autonomy"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-black via-transparent to-transparent"></div>
          </div>

          <div class="absolute -right-6 top-12 flex flex-col gap-4">
              {[
                { label: "COACH_EFFICIENCY", val: "+240%" },
                { label: "DATA_PRECISION", val: "99.9%" },
                { label: "MEMBER_RETENTION", val: "+32%" }
              ].map((stat, i) => (
                <div 
                  class="stat-pill bg-black/90 backdrop-blur-md border border-orange-500/30 p-5 rounded-xl translate-x-12 opacity-0 transition-all duration-700"
                  style={`transition-delay: ${600 + (i * 150)}ms`}
                >
                  <p class="text-[8px] font-mono text-orange-500 uppercase tracking-widest mb-1">{stat.label}</p>
                  <p class="text-2xl font-black text-white italic leading-none">{stat.val}</p>
                </div>
              ))}
          </div>
       </div>

       <div class="w-full md:w-1/2">
          <div class="relative p-1 border-t border-l border-white/10 rounded-tl-[4rem]">
             <div class="bg-black border border-white/5 p-12 md:p-20 rounded-tl-[3.5rem] rounded-br-3xl text-right relative overflow-hidden">
                <div class="absolute -bottom-10 -left-10 w-64 h-64 bg-orange-600/5 blur-[80px] rounded-full"></div>
                <span class="text-orange-500 font-mono text-[10px] tracking-[0.6em] uppercase mb-10 block relative z-10">Verification // Successful</span>
                <h4 class="text-6xl md:text-8xl font-black uppercase tracking-tighter leading-[0.85] mb-10 relative z-10">
                  Complete <span class="text-orange-600 italic">Autonomy.</span>
                </h4>
                <p class="text-neutral-400 font-medium text-xl italic mb-12 max-w-md ml-auto relative z-10 leading-snug">
                  "The transition from a coach-led bottleneck to an intelligence-driven facility is now absolute."
                </p>
                <div class="inline-flex items-center gap-5 px-8 py-4 bg-white/[0.03] rounded-full border border-white/10 relative z-10">
                   <div class="w-2.5 h-2.5 rounded-full bg-green-500 shadow-[0_0_15px_rgba(34,197,94,0.6)] animate-pulse"></div>
                   <span class="text-[11px] font-mono text-neutral-200 tracking-[0.2em] uppercase font-bold">Protocol_Lock // Deployment_Active</span>
                </div>
             </div>
          </div>
       </div>
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1.2s ease-out, transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Target the images within an active reveal section */
  .reveal.active .reveal-img {
    filter: grayscale(0) brightness(1);
  }

  .reveal.active .stat-pill {
    opacity: 1;
    transform: translateX(0);
  }

  section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url('https://www.transparenttextures.com/patterns/stardust.png');
    opacity: 0.2;
    pointer-events: none;
  }
</style>

<script>
  const observerOptions = {
    threshold: 0.2
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
        // Once animated, we can stop observing to save resources
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal').forEach(el => {
    observer.observe(el);
  });
</script>