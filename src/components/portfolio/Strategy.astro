---
interface Props {
  header: { phase: string; title: string; highlight: string; desc: string };
  steps: { id: string; title: string; subtitle: string; desc: string; image: string; logo: string }[];
  finale: {
    image: string;
    stats: { label: string; val: string }[];
    title: string;
    highlightWord: string;
    quote: string;
  };
}

const { header, steps, finale } = Astro.props;
---

<section id="strategy" class="bg-[#050505] text-white py-32 px-6 font-sans overflow-hidden relative">
  
  <div class="absolute top-20 right-[-10%] opacity-[0.02] pointer-events-none select-none">
     <h2 class="text-[25rem] font-black uppercase tracking-tighter">STRAT</h2>
  </div>

  <div class="max-w-7xl mx-auto relative">
    
    <div class="reveal mb-24 md:mb-40 flex flex-col lg:flex-row justify-between items-start lg:items-end gap-12">
      <div class="lg:w-2/3">
        <span class="text-orange-500 font-mono text-[9px] md:text-[10px] font-bold tracking-[0.4em] md:tracking-[0.6em] uppercase mb-4 md:mb-6 block">
          {header.phase}
        </span>
        <h2 class="text-5xl sm:text-6xl md:text-8xl lg:text-9xl font-black uppercase tracking-tighter leading-[0.9] md:leading-[0.8] break-words">
          {header.title}<br/>
          <span class="italic text-transparent bg-clip-text bg-gradient-to-r from-neutral-300 to-neutral-700">
            {header.highlight}.
          </span>
        </h2>
      </div>
      <div class="lg:w-1/3 flex lg:justify-end mt-4 lg:mt-0">
        <p class="text-neutral-500 text-base md:text-lg font-medium italic max-w-sm border-l border-orange-600/50 pl-4 md:pl-8 pb-2">
          "{header.desc}"
        </p>
      </div>
    </div>

    <div class="relative w-full overflow-hidden">
      {steps.map((step, index) => (
        <div 
          class="reveal relative mb-24 md:mb-48 flex flex-col md:flex-row items-center gap-8 md:gap-12 md:[margin-left:var(--md-ml)] w-full"
          style={`--md-ml: ${index * 12}%;`}
        >
          <div class="relative w-[calc(100%+3rem)] -ml-6 md:w-[450px] md:ml-0 aspect-video md:rounded-2xl overflow-hidden group shadow-2xl border-y md:border border-white/10 shrink-0">
              <img 
                src={step.image} 
                alt={step.title} 
                class="reveal-img w-full h-full object-cover grayscale brightness-50 transition-all duration-[2000ms] ease-in-out"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
              <div class="absolute top-6 left-6 w-10 h-10 bg-white/10 backdrop-blur-md rounded-lg p-2 border border-white/20">
                  <img src={step.logo} class="w-full h-full object-contain invert opacity-50" alt="Tech" />
              </div>
          </div>

          <div class="md:max-w-md relative w-full">
             <div class="flex items-center gap-3 md:gap-4 mb-4">
                <span class="text-orange-600 font-mono text-lg md:text-xl font-black italic">0{step.id}</span>
                <div class="h-px w-8 md:w-12 bg-orange-600/30"></div>
                <span class="text-[8px] md:text-[9px] font-black text-neutral-500 tracking-[0.2em] md:tracking-[0.3em] uppercase">{step.subtitle}</span>
             </div>
             <h3 class="text-3xl md:text-4xl font-black uppercase tracking-tight mb-4 md:mb-6 leading-none break-words">{step.title}</h3>
             <p class="text-neutral-400 text-sm leading-relaxed mb-6 md:mb-8">{step.desc}</p>
             {index < steps.length - 1 && (
               <div class="hidden md:block absolute top-[130%] left-[-50px] w-px h-32 bg-gradient-to-b from-orange-600 to-transparent"></div>
             )}
          </div>
        </div>
      ))}
    </div>

    <div class="reveal mt-24 md:mt-40 flex flex-col md:flex-row items-center gap-12 lg:gap-24 overflow-hidden md:overflow-visible">
       
       <div class="w-full md:w-1/2 relative group px-2 md:px-0">
          <div class="relative rounded-2xl md:rounded-3xl overflow-hidden border border-white/10 shadow-2xl w-full">
              <img 
                src={finale.image}
                class="reveal-img w-full h-64 md:h-[500px] object-cover grayscale brightness-50 contrast-125 transition-all duration-[2000ms] ease-in-out" 
                alt="Strategic Result"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-black via-transparent to-transparent"></div>
          </div>

          <div class="absolute right-0 md:-right-6 top-6 md:top-12 flex flex-col gap-3 md:gap-4 pr-4 md:pr-0">
              {finale.stats.map((stat, i) => (
                <div 
                  class="stat-pill bg-black/90 backdrop-blur-md border border-orange-500/30 p-3 md:p-5 rounded-xl translate-x-12 opacity-0 transition-all duration-700 shadow-xl"
                  style={`transition-delay: ${600 + (i * 150)}ms`}
                >
                  <p class="text-[7px] md:text-[8px] font-mono text-orange-500 uppercase tracking-widest mb-1">{stat.label}</p>
                  <p class="text-xl md:text-2xl font-black text-white italic leading-none">{stat.val}</p>
                </div>
              ))}
          </div>
       </div>

       <div class="w-full md:w-1/2">
          <div class="relative p-1 border-t border-l border-white/10 rounded-tl-[3rem] md:rounded-tl-[4rem]">
             <div class="bg-black border border-white/5 p-8 md:p-20 rounded-tl-[2.5rem] md:rounded-tl-[3.5rem] rounded-br-3xl text-left md:text-right relative overflow-hidden">
                <div class="absolute -bottom-10 -left-10 w-64 h-64 bg-orange-600/5 blur-[80px] rounded-full"></div>
                <span class="text-orange-500 font-mono text-[9px] md:text-[10px] tracking-[0.3em] md:tracking-[0.6em] uppercase mb-6 md:mb-10 block relative z-10">Verification // Successful</span>
                <h4 class="text-4xl sm:text-6xl md:text-8xl font-black uppercase tracking-tighter leading-[0.9] md:leading-[0.85] mb-6 md:mb-10 relative z-10 break-words">
                  {finale.title}<span class="text-orange-600 italic">{finale.highlightWord}</span>
                </h4>
                <p class="text-neutral-400 font-medium text-base md:text-xl italic mb-8 md:mb-12 max-w-md ml-0 md:ml-auto relative z-10 leading-snug">
                  "{finale.quote}"
                </p>
                <div class="inline-flex items-center gap-3 md:gap-5 px-6 md:px-8 py-3 md:py-4 bg-white/[0.03] rounded-full border border-white/10 relative z-10 w-full sm:w-auto justify-center md:justify-start">
                   <div class="w-2 md:w-2.5 h-2 md:h-2.5 rounded-full bg-green-500 shadow-[0_0_15px_rgba(34,197,94,0.6)] animate-pulse shrink-0"></div>
                   <span class="text-[9px] md:text-[11px] font-mono text-neutral-200 tracking-[0.1em] md:tracking-[0.2em] uppercase font-bold text-center">Protocol_Lock // Deployment_Active</span>
                </div>
             </div>
          </div>
       </div>
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1.2s ease-out, transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal.active .reveal-img {
    filter: grayscale(0) brightness(1);
  }

  .reveal.active .stat-pill {
    opacity: 1;
    transform: translateX(0);
  }

  section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url('https://www.transparenttextures.com/patterns/stardust.png');
    opacity: 0.2;
    pointer-events: none;
  }
</style>

<script>
  const observerOptions = {
    threshold: 0.2
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal').forEach(el => {
    observer.observe(el);
  });
</script>
