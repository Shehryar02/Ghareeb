---
interface Props {
  header: { protocol: string; title: string; highlight: string; desc: string };
  constraints: { label: string; value: string; tag: string }[];
  gallery: string[];
  verdict: { headline: string; highlightWord: string; quote: string };
}

const { header, constraints, gallery, verdict } = Astro.props;
---

<section class="relative bg-white text-black py-24 px-6 font-sans overflow-hidden selection:bg-orange-600 selection:text-white">
  
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-orange-50/50 to-transparent pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-16 items-start mb-10">
      <div class="lg:col-span-7">
        <span class="text-orange-600 font-mono text-[10px] md:text-xs font-bold tracking-[0.3em] md:tracking-[0.4em] uppercase mb-4 md:mb-6 block">
          {header.protocol}
        </span>
        <h2 class="text-5xl sm:text-6xl md:text-8xl lg:text-[7rem] font-black uppercase tracking-tighter text-black leading-[0.9] md:leading-[0.85] mb-6 md:mb-8 italic break-words">
          {header.title} <br/>
          <span class="text-orange-500">{header.highlight}.</span>
        </h2>
        <p class="text-lg md:text-xl font-bold text-neutral-400 italic mb-8">{header.desc}</p>
        
        <div class="relative h-80 mt-12 hidden md:block">
            <div class="absolute top-12 left-56 w-36 h-48 rounded-2xl overflow-hidden shadow-lg brightness-50 rotate-[12deg] z-0 border border-neutral-200">
                <img src={gallery[2]} class="w-full h-full object-cover" alt="Context" />
            </div>

            <div class="absolute top-8 left-32 w-40 h-56 rounded-2xl overflow-hidden shadow-xl brightness-75 rotate-[6deg] z-10 border-2 border-white">
                <img src={gallery[1]} class="w-full h-full object-cover" alt="Process" />
                <div class="absolute inset-0 bg-orange-900/10 mix-blend-multiply"></div>
            </div>

            <div class="absolute top-0 left-0 w-48 h-64 rounded-2xl overflow-hidden shadow-2xl hover:grayscale-0 transition-all duration-700 rotate-[-4deg] z-20 border-2 border-white">
                <img src={gallery[0]} class="w-full h-full object-cover" alt="Reality" />
                <div class="absolute inset-0 bg-orange-600/10 mix-blend-multiply"></div>
            </div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 relative z-20 lg:col-span-5 lg:mt-64">
        {constraints.map((item) => (
          <div class="group relative bg-black rounded-3xl p-6 md:p-8 border border-white/5 overflow-hidden transition-all hover:border-orange-500/50 hover:-translate-y-2 duration-500">
             <div class="relative z-10">
                <span class="text-orange-500 font-mono text-[9px] tracking-[0.3em] uppercase block mb-3 md:mb-4">{item.tag}</span>
                <h3 class="text-white text-lg md:text-xl font-black uppercase tracking-tight leading-none mb-4 md:mb-6">{item.label}</h3>
                <span class="text-4xl md:text-5xl font-black italic text-white group-hover:text-orange-500 transition-colors">{item.value}</span>
             </div>
             <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-orange-600/10 blur-2xl rounded-full group-hover:bg-orange-600/20 transition-all"></div>
          </div>
        ))}
      </div>
    </div>

    <div class="max-w-3xl mx-auto relative rounded-[2rem] bg-black p-8 md:p-16 border border-orange-600/30 shadow-2xl mt-12 md:mt-0">
       
       <div class="absolute inset-0 bg-gradient-to-b from-orange-600/5 to-transparent pointer-events-none"></div>
       
       <div class="relative z-10 flex flex-col items-center text-center">
          
          <div class="flex items-center gap-3 mb-6 md:mb-8">
              <span class="h-[1px] w-6 md:w-8 bg-orange-600/50"></span>
              <span class="text-orange-500 font-mono text-[9px] md:text-[10px] font-bold tracking-[0.3em] md:tracking-[0.5em] uppercase">The Verdict</span>
              <span class="h-[1px] w-6 md:w-8 bg-orange-600/50"></span>
          </div>

          <h4 class="text-white text-3xl md:text-5xl font-black uppercase tracking-tight leading-none mb-6">
            {verdict.headline}<span class="text-orange-500 italic">{verdict.highlightWord}</span>
          </h4>

          <div class="w-12 md:w-16 h-1 bg-orange-600 mb-8 md:mb-10 rounded-full"></div>

          <p class="text-neutral-300 text-lg md:text-2xl font-medium tracking-tight mb-8 md:mb-12 max-w-xl italic leading-relaxed">
            "{verdict.quote}"
          </p>
       </div>
    </div>

  </div>

  <style>
    @keyframes scan {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }
  </style>
</section>
