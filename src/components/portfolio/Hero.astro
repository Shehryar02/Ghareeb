---
interface Props {
  title: string;
  subtitle: string;
  tech: string;
  images: { id: string; title: string; img: string }[];
}

const { title, subtitle, tech, images } = Astro.props;
---

<section class="relative min-h-screen py-20 bg-[#050505] flex flex-col items-center justify-center px-4 overflow-hidden">
  
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]"></div>

  <div class="relative z-10 w-full max-w-[1100px] flex flex-col items-center">
    
    <div class="text-center mb-8">
      <div class="inline-flex items-center gap-3 mb-8">
        <span class="h-[1px] w-8 bg-[#FB8500]"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.5em] text-gray-500">Case Study</span>
        <span class="h-[1px] w-8 bg-[#FB8500]"></span>
      </div>
      
      <h1 class="text-5xl sm:text-7xl md:text-9xl font-black leading-[0.9] md:leading-[0.75] tracking-[-0.06em] uppercase text-white break-words">
        {title.split(' ').slice(0, -1).join(' ')} <span class="text-[#FB8500]">{title.split(' ').pop()}</span>
      </h1>
      
      <p class="mt-6 md:mt-8 max-w-2xl mx-auto text-base sm:text-lg md:text-2xl font-light tracking-tight text-gray-400 px-2">
        {subtitle}
      </p>
      
      <div class="mt-6 inline-flex items-center gap-3 px-6 py-2 bg-white/[0.03] border border-white/10 rounded-full">
        <div class="w-2 h-2 rounded-full bg-[#FB8500] animate-pulse"></div>
        <span class="text-[10px] font-mono font-bold text-gray-400 uppercase tracking-[0.3em]">{tech}</span>
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-center w-full gap-8 md:gap-10 relative z-20 mt-12">
      {
        images.map((item, index) => (
          <div
            class={`group relative transition-all duration-500 
            ${
              index === 1
                ? "z-30 w-full md:w-[38%] scale-100 md:scale-105"
                : "z-10 w-[90%] md:w-[28%] opacity-80 md:opacity-60 hover:opacity-100"
            }`}
          >
            <div class="relative aspect-video md:aspect-[4/3] w-full rounded-2xl overflow-hidden border border-white/10 bg-neutral-900 shadow-xl transition-all duration-500 ease-out group-hover:scale-[1.02] md:group-hover:scale-[1.03] group-hover:border-[#FB8500]/50 group-hover:shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
              
              <img
                src={item.img}
                alt={item.title}
                class="w-full h-full object-cover opacity-80 transition-all duration-700 group-hover:opacity-100"
              />

              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent" />

              <div class="absolute bottom-6 left-6 z-20 transition-transform duration-500 group-hover:translate-x-1">
                <p class="text-[10px] font-bold text-[#FB8500] uppercase tracking-[0.2em]">
                  {item.title} // {item.id}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
