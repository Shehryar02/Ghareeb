---
// portfolio-grid.astro
const portfolios = [
  {
    title: "Performance Lab",
    client: "Elite Athletics",
    outcome: "+210% Yield",
    img: "https://images.unsplash.com/photo-1517836357463-d25dfeac3438?q=80&w=800",
    id: "PROJ_01"
  },
  {
    title: "Velocity HQ",
    client: "Speed Science",
    outcome: "Zero Latency",
    img: "https://images.unsplash.com/photo-1541534741688-6078c6bfb5c5?q=80&w=800",
    id: "PROJ_02"
  },
  {
    title: "The Iron Logic",
    client: "Foundry Gym",
    outcome: "Scale Autonomy",
    img: "https://images.unsplash.com/photo-1594381898411-846e7d193883?q=80&w=800",
    id: "PROJ_03"
  }
];
---

<section class="bg-white py-6 px-6">
  <div class="max-w-7xl mx-auto">
    
    {/* Section Header */}
    <div class="flex justify-between items-end mb-20 border-b-2 border-black pb-8">
        <div>
            <span class="text-orange-600 font-mono text-[10px] font-bold tracking-[0.5em] uppercase block mb-4">Case_Archive</span>
            <h2 class="text-6xl font-black text-black uppercase tracking-tighter italic">Next Projects.</h2>
        </div>
    </div>

    {/* The Thumbnail Grid */}
    <div class="grid md:grid-cols-3 gap-8">
      {portfolios.map((item) => (
        <a href={`/portfolio/${item.id}`} class="group relative block overflow-hidden bg-black rounded-3xl">
            
            {/* Image Layer */}
            <div class="aspect-[4/5] overflow-hidden">
                <img 
                    src={item.img} 
                    alt={item.title} 
                    class="w-full h-full object-cover grayscale brightness-50 group-hover:grayscale-0 group-hover:scale-105 transition-all duration-[1.2s] ease-in-out"
                />
            </div>

            {/* Absolute Overlay Content */}
            <div class="absolute inset-0 p-10 flex flex-col justify-between pointer-events-none">
                
                {/* Top Row: Meta */}
                <div class="flex justify-between items-start opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                    <span class="text-white font-mono text-[9px] tracking-[0.3em] uppercase">{item.id}</span>
                    <div class="w-8 h-8 rounded-full border border-white/20 flex items-center justify-center">
                        <svg class="w-3 h-3 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </div>
                </div>

                {/* Bottom Row: Data */}
                <div>
                    <span class="text-orange-500 font-mono text-[8px] font-black tracking-widest uppercase mb-1 block">Client: {item.client}</span>
                    <h3 class="text-3xl font-black text-white uppercase italic leading-none mb-4 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                        {item.title}
                    </h3>
                    
                    {/* Outcome Badge */}
                    <div class="inline-block bg-white text-black px-4 py-1.5 rounded-full">
                        <p class="text-[9px] font-black uppercase tracking-widest">{item.outcome}</p>
                    </div>
                </div>
            </div>

            {/* Hover Glitch Line */}
            <div class="absolute bottom-0 left-0 w-full h-1 bg-orange-600 scale-x-0 group-hover:scale-x-100 transition-transform duration-700 origin-left"></div>
        </a>
      ))}
    </div>
  </div>
</section>