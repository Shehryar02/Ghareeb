---
// Contact.astro - Professional High-Contrast Console
---

<section class="relative w-full py-16 lg:py-24 bg-white flex items-center justify-center p-4 lg:p-6 reveal-scale">
  
  <div class="max-w-6xl w-full bg-[#050505] rounded-3xl lg:rounded-[3rem] overflow-hidden shadow-[0_50px_100px_rgba(0,0,0,0.5)] flex flex-col lg:flex-row min-h-[700px] border border-white/5">
    
    <div class="w-full lg:w-1/2 relative p-8 md:p-12 lg:p-20 flex flex-col justify-between border-b lg:border-b-0 lg:border-r border-white/10 bg-[radial-gradient(circle_at_center,_#111_0%,_#050505_100%)]">
      
      <div class="flex items-center gap-2">
        <div class="w-1.5 h-6 bg-[#ea580c]"></div>
        <span class="text-[10px] font-mono font-bold text-white/60 tracking-[0.3em] uppercase">Connect</span>
      </div>

      <div class="flex flex-col items-center text-center">
        <div class="w-20 h-20 mb-10 text-[#ea580c]">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-display tracking-[-0.05em] text-white leading-tight mb-4">
          Elevate Your <br/> <span class="text-white/30">Architecture.</span>
        </h1>
        <p class="text-sm text-white/40 max-w-xs font-medium leading-relaxed">
          Partner with us to engineer high-velocity systems built for longevity.
        </p>
      </div>

      <div class="flex items-center gap-4">
        <span class="text-[9px] font-mono text-white/20 uppercase tracking-widest">Global HQ</span>
        <div class="h-[1px] w-12 bg-white/10"></div>
        <span class="text-[9px] font-mono text-white/20 uppercase tracking-widest">Available 2025</span>
      </div>
    </div>

    <div class="w-full lg:w-1/2 p-8 md:p-12 lg:p-16 flex flex-col justify-center bg-[#080808]">
      
      <div class="mb-12">
         <h2 class="text-2xl font-bold text-white tracking-tight uppercase">Let's Build Together</h2>
         <p class="text-white/40 text-xs mt-2">Submit your project details for a priority review.</p>
      </div>

      <form class="space-y-6">
        <div class="group relative">
          <label class="absolute -top-2.5 left-4 px-2 bg-[#080808] text-[10px] font-bold text-white uppercase tracking-wider z-10">Full Name</label>
          <input type="text" required class="w-full bg-transparent border border-[#ea580c]/40 rounded-xl px-5 py-4 text-sm text-white focus:border-[#ea580c] focus:ring-1 focus:ring-[#ea580c] outline-none transition-all placeholder:text-white/5" placeholder="Enter your name" />
        </div>

        <div class="group relative">
          <label class="absolute -top-2.5 left-4 px-2 bg-[#080808] text-[10px] font-bold text-white uppercase tracking-wider z-10">Email Address</label>
          <input type="email" inputmode="email" required class="w-full bg-transparent border border-[#ea580c]/40 rounded-xl px-5 py-4 text-sm text-white focus:border-[#ea580c] focus:ring-1 focus:ring-[#ea580c] outline-none transition-all placeholder:text-white/5" placeholder="email@example.com" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Custom Select: Service -->
          <div class="group relative custom-select" data-id="service">
            <label class="absolute -top-2.5 left-4 px-2 bg-[#080808] text-[10px] font-bold text-white uppercase tracking-wider z-20">Service</label>
            <input type="hidden" name="service" value="System Architecture" />
            <button type="button" class="select-btn w-full bg-transparent border border-[#ea580c]/40 rounded-xl px-5 py-4 text-sm text-white/80 focus:border-[#ea580c] focus:ring-1 focus:ring-[#ea580c] outline-none transition-all cursor-pointer flex justify-between items-center text-left relative z-10">
              <span class="selected-text">System Architecture</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="rgba(234,88,12,0.8)" stroke-width="2" class="w-4 h-4 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div class="select-dropdown absolute top-[calc(100%+4px)] left-0 w-full bg-[#080808] border border-white/10 rounded-lg overflow-hidden opacity-0 invisible translate-y-[-10px] transition-all duration-300 z-50 shadow-2xl">
              <ul class="flex flex-col">
                <li class="px-5 py-3 text-sm text-white/80 hover:bg-[#2563eb] hover:text-white cursor-pointer transition-colors border-b border-white/5 last:border-b-0" data-value="System Architecture">System Architecture</li>
                <li class="px-5 py-3 text-sm text-white/80 hover:bg-[#2563eb] hover:text-white cursor-pointer transition-colors border-b border-white/5 last:border-b-0" data-value="Performance Audit">Performance Audit</li>
                <li class="px-5 py-3 text-sm text-white/80 hover:bg-[#2563eb] hover:text-white cursor-pointer transition-colors border-b border-white/5 last:border-b-0" data-value="Product Design">Product Design</li>
              </ul>
            </div>
          </div>

          <!-- Custom Select: Budget -->
          <div class="group relative custom-select" data-id="budget">
            <label class="absolute -top-2.5 left-4 px-2 bg-[#080808] text-[10px] font-bold text-white uppercase tracking-wider z-20">Budget</label>
            <input type="hidden" name="budget" value="$10k - $25k" />
            <button type="button" class="select-btn w-full bg-transparent border border-[#ea580c]/40 rounded-xl px-5 py-4 text-sm text-white/80 focus:border-[#ea580c] focus:ring-1 focus:ring-[#ea580c] outline-none transition-all cursor-pointer flex justify-between items-center text-left relative z-10">
              <span class="selected-text">$10k - $25k</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="rgba(234,88,12,0.8)" stroke-width="2" class="w-4 h-4 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div class="select-dropdown absolute top-[calc(100%+4px)] left-0 w-full bg-[#080808] border border-white/10 rounded-lg overflow-hidden opacity-0 invisible translate-y-[-10px] transition-all duration-300 z-50 shadow-2xl">
              <ul class="flex flex-col">
                <li class="px-5 py-3 text-sm text-white/80 hover:bg-[#2563eb] hover:text-white cursor-pointer transition-colors border-b border-white/5 last:border-b-0" data-value="$10k - $25k">$10k - $25k</li>
                <li class="px-5 py-3 text-sm text-white/80 hover:bg-[#2563eb] hover:text-white cursor-pointer transition-colors border-b border-white/5 last:border-b-0" data-value="$25k - $50k">$25k - $50k</li>
                <li class="px-5 py-3 text-sm text-white/80 hover:bg-[#2563eb] hover:text-white cursor-pointer transition-colors border-b border-white/5 last:border-b-0" data-value="$50k+">$50k+</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="group relative">
          <label class="absolute -top-2.5 left-4 px-2 bg-[#080808] text-[10px] font-bold text-white uppercase tracking-wider z-10">Project Brief</label>
          <textarea rows="4" class="w-full bg-transparent border border-[#ea580c]/40 rounded-xl px-5 py-4 text-sm text-white focus:border-[#ea580c] focus:ring-1 focus:ring-[#ea580c] outline-none transition-all resize-none placeholder:text-white/5" placeholder="Briefly describe your goals..."></textarea>
        </div>

        <button type="submit" class="w-full py-5 bg-[#ea580c] text-white rounded-xl font-bold uppercase text-[11px] tracking-[0.3em] transition-all hover:bg-[#ff6a1a] hover:shadow-[0_15px_30px_rgba(234,88,12,0.3)] active:scale-[0.98]">
          Send Message
        </button>

        <p class="text-center text-[9px] font-mono text-white/10 uppercase tracking-[0.4em] mt-4">Confidential Transmission</p>
      </form>
    </div>

  </div>
</section>

<style>
  input:focus, textarea:focus {
    background-color: rgba(234, 88, 12, 0.03);
  }

  .custom-select.is-open .select-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .custom-select.is-open .select-btn svg {
    transform: rotate(180deg);
  }

  .custom-select.is-open .select-btn {
    background-color: rgba(234, 88, 12, 0.03);
    border-color: #ea580c;
  }
</style>

<script>
  function initCustomSelects() {
    const selects = document.querySelectorAll('.custom-select:not(.initialized)');

    selects.forEach(select => {
      select.classList.add('initialized');
      const btn = select.querySelector('.select-btn') as HTMLElement;
      const text = select.querySelector('.selected-text') as HTMLElement;
      const input = select.querySelector('input[type="hidden"]') as HTMLInputElement;
      const options = select.querySelectorAll('.select-dropdown li');

      // Toggle dropdown
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        
        // Close other open selects
        document.querySelectorAll('.custom-select.is-open').forEach(other => {
          if (other !== select) other.classList.remove('is-open');
        });

        select.classList.toggle('is-open');
      });

      // Handle selection
      options.forEach(option => {
        option.addEventListener('click', () => {
          const value = option.getAttribute('data-value');
          if (value) {
            text.textContent = option.textContent;
            input.value = value;
            select.classList.remove('is-open');
          }
        });
      });
    });
  }

  // Close on click outside - attach only once
  if (!(window as any).customSelectsInitialized) {
    document.addEventListener('click', (e) => {
      document.querySelectorAll('.custom-select.is-open').forEach(select => {
        if (!select.contains(e.target as Node)) {
          select.classList.remove('is-open');
        }
      });
    });
    (window as any).customSelectsInitialized = true;
  }

  document.addEventListener('astro:page-load', initCustomSelects);
</script>