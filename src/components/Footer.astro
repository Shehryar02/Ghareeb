---

<footer class="relative bg-[#111111] text-white font-sans overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[#FB8500] via-[#FB8500]/60 to-[#FB8500]"></div>

  <div class="max-w-[1400px] mx-auto px-6 md:px-10 pt-16 pb-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 lg:gap-14">

      {columns.map((col) => (
        <div>
          <h4 class="text-[18px] font-heading font-semibold  text-white/90 mb-5 pb-2 border-b border-white/10 inline-block pr-6">
            {col.title}
          </h4>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-[13px] text-white/50 hover:text-[#FB8500] transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div>
        <h4 class="text-[18px] font-heading font-semibold  text-white/90 mb-5 pb-2 border-b border-white/10 inline-block pr-6">
          Talk to Us
        </h4>
        <ul class="space-y-3.5">
          {contactInfo.map((item) => (
            <li class="flex items-start gap-2.5">
              {item.icon === 'phone' && (
                <svg class="w-4 h-4 text-[#FB8500] mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              )}
              {item.icon === 'email' && (
                <svg class="w-4 h-4 text-[#FB8500] mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              )}
              {item.icon === 'location' && (
                <svg class="w-4 h-4 text-[#FB8500] mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              )}
              {item.href ? (
                <a href={item.href} class="text-[13px] text-white/50 hover:text-[#FB8500] transition-colors duration-200 break-words">
                  {item.label}
                </a>
              ) : (
                <span class="text-[13px] text-white/50 leading-relaxed break-words">{item.label}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/[0.06]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10 py-5">
      <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1">
        {locations.map((city, i) => (
          <span class="flex items-center gap-2">
            <span class="text-[12px] text-white/35 font-medium">{city}</span>
            {i < locations.length - 1 && (
              <span class="text-white/15 text-[10px]">|</span>
            )}
          </span>
        ))}
      </div>
    </div>
  </div>

  <div class="border-t border-white/[0.06] bg-[#0a0a0a]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10 py-5">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">

        <span class="text-[11px] text-white/30 font-medium order-2 md:order-1">
          All Rights Reserved &copy; {year} Kratecx
        </span>

        <div class="flex items-center gap-3 order-1 md:order-2">
          {socials.map((s) => (
            <a href="#" aria-label={s.name} class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:border-[#FB8500]/50 hover:bg-[#FB8500]/10 transition-all duration-200 group/s">
              <svg class="w-3.5 h-3.5 fill-white/40 group-hover/s:fill-[#FB8500] transition-colors" viewBox="0 0 24 24">
                <path d={s.path}/>
              </svg>
            </a>
          ))}
        </div>

        <div class="flex items-center gap-4 order-3">
          {legalLinks.map((link, i) => (
            <span class="flex items-center gap-4">
              <a href={link.href} class="text-[11px] text-white/30 hover:text-white/60 transition-colors font-medium">
                {link.name}
              </a>
              {i < legalLinks.length - 1 && (
                <span class="text-white/10 text-[8px] hidden md:inline">|</span>
              )}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
</style>
